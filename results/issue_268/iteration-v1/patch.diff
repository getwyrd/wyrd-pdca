+/// POSIX `EIO` (errno 5) — the OS errno a block-layer read fault raises (a dead
+/// sector, a `dm-error` target). Named here rather than from `libc` so the seam
+/// crate stays free of OS-abstraction dependencies.
+const EIO: i32 = 5;
+
+/// Whether `err`'s source chain carries a block-layer read fault — a
+/// [`std::io::Error`] with `raw_os_error() == Some(5)` (POSIX `EIO`: a dead sector /
+/// `dm-error` target, where the device physically cannot return the bytes).
+///
+/// This is a **permanent durability fault**: retrying the same fetch cannot help —
+/// distinct from an [`IntegrityFault`] (the bytes are present but corrupt) and from a
+/// transient fault (the server is temporarily unreachable). A consumer reads around it
+/// — treats the shard as missing and rebuilds from ≥`k` survivors — rather than
+/// retrying. See [`is_permanent_read_fault`] for the combined permanent-fault predicate.
+///
+/// Walks [`source`](std::error::Error::source) so the fault is found whether the
+/// backend surfaces the raw `io::Error` directly or wraps it in its own error type,
+/// mirroring how [`is_integrity_fault`] walks the chain for a corruption fault.
+pub fn is_block_read_fault(err: &(dyn std::error::Error + 'static)) -> bool {
+    let mut next = Some(err);
+    while let Some(e) = next {
+        if let Some(io) = e.downcast_ref::<std::io::Error>() {
+            if io.raw_os_error() == Some(EIO) {
+                return true;
+            }
+        }
+        next = e.source();
+    }
+    false
+}
+
+/// Whether `err` is a **permanent durability fault** — one where retrying the same
+/// fetch cannot help and a consumer should read around it and rebuild from ≥`k`
+/// survivors. Two permanent shapes:
+///
+/// * a **corruption / integrity** fault ([`IntegrityFault`]): the stored bytes failed
+///   their self-describing checksum; and
+/// * a **block-layer read fault** (`EIO` / dead sector — [`is_block_read_fault`]):
+///   the OS reported the read failed at the device.
+///
+/// A **transient** fault (unreachable / timed out / busy) matches neither and is
+/// propagated to the retry policy instead. This predicate is the single decision point
+/// for the permanent-vs-transient split that the [`IntegrityFault`] seam contract
+/// (ADR-0010) requires to survive the whole path from the store to the consumer —
+/// including across the gRPC seam, where a `Status` carries only `Code` + `String`.
+pub fn is_permanent_read_fault(err: &(dyn std::error::Error + 'static)) -> bool {
+    is_integrity_fault(err) || is_block_read_fault(err)
+}
