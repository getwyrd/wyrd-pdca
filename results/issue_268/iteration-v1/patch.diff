diff --git a/crates/chunkstore-grpc/tests/read_fault_seam.rs b/crates/chunkstore-grpc/tests/read_fault_seam.rs
new file mode 100644
index 0000000..af98a34
--- /dev/null
+++ b/crates/chunkstore-grpc/tests/read_fault_seam.rs
@@ -0,0 +1,203 @@
+//! Issue #268 — block-layer read fault (`EIO` / dead sector) from a remote D
+//! server must cross the gRPC seam as a **permanent durability fault**, not a
+//! transient one.
+//!
+//! A block-layer read fault raised by the inner store's `get_fragment` was
+//! previously flattened to a string and collapsed into `Status::internal` by
+//! the server, which the client reconstructed as `TransportError::Rpc` —
+//! classified as transient. `is_permanent_read_fault` found no `io::Error(EIO)`
+//! in the chain, so the reconstruction loop retried the chunk forever instead of
+//! reading around it and rebuilding from ≥k survivors.
+//!
+//! **Fix:** `ChunkStoreService::get_fragment` now emits `Code::DataLoss` for
+//! block-layer read faults (`wyrd_traits::is_block_read_fault`) in addition to
+//! integrity faults. The client's existing `DataLoss` → [`IntegrityFault`] mapping
+//! already makes `is_permanent_read_fault` return `true`, so both permanent shapes
+//! are read around without any client-side change.
+//!
+//! This file drives a **real tonic client↔server over an in-process channel**
+//! (the same seam the existing `tier2_integration.rs` exercises), with a
+//! fault-injecting inner store — the acceptance requires exercising the WIRE
+//! seam, not a mock of the `ChunkStore` trait.
+
+use std::io;
+
+use async_trait::async_trait;
+use bytes::Bytes;
+use tokio_stream::wrappers::TcpListenerStream;
+use tonic::transport::Server;
+use wyrd_chunkstore_grpc::{ChunkStoreServer, ChunkStoreService, GrpcChunkStore, TransportError};
+use wyrd_traits::{ChunkStore, FragmentId, Health, Result};
+
+// ─── fault-injecting fakes ───────────────────────────────────────────────────
+
+/// A store whose `get_fragment` always returns an EIO block-layer read fault
+/// (errno 5, POSIX `EIO`): simulates a dead sector / `dm-error` target.
+struct EioStore;
+
+#[async_trait]
+impl ChunkStore for EioStore {
+    async fn put_fragment(&self, _id: FragmentId, _fragment: Bytes) -> Result<()> {
+        Ok(())
+    }
+
+    async fn get_fragment(&self, _id: FragmentId) -> Result<Option<Bytes>> {
+        // io::Error::from_raw_os_error(5) is POSIX EIO — a block-layer read fault
+        // the device could not service. `raw_os_error() == Some(5)` is what
+        // `wyrd_traits::is_block_read_fault` and the server-side check match on.
+        Err(Box::new(io::Error::from_raw_os_error(5)))
+    }
+
+    async fn list_fragments(&self) -> Result<Vec<FragmentId>> {
+        Ok(vec![])
+    }
+
+    async fn delete_fragment(&self, _id: FragmentId) -> Result<()> {
+        Ok(())
+    }
+
+    async fn health(&self) -> Result<Health> {
+        Ok(Health::Healthy)
+    }
+}
+
+/// A store whose `get_fragment` returns a generic (non-EIO) error — simulating a
+/// server-internal failure that is NOT a block-layer read fault and therefore must
+/// remain transient (a `TransportError`), not be promoted to permanent.
+struct GenericErrorStore;
+
+#[async_trait]
+impl ChunkStore for GenericErrorStore {
+    async fn put_fragment(&self, _id: FragmentId, _fragment: Bytes) -> Result<()> {
+        Ok(())
+    }
+
+    async fn get_fragment(&self, _id: FragmentId) -> Result<Option<Bytes>> {
+        Err(Box::new(io::Error::other(
+            "generic server-internal failure",
+        )))
+    }
+
+    async fn list_fragments(&self) -> Result<Vec<FragmentId>> {
+        Ok(vec![])
+    }
+
+    async fn delete_fragment(&self, _id: FragmentId) -> Result<()> {
+        Ok(())
+    }
+
+    async fn health(&self) -> Result<Health> {
+        Ok(Health::Healthy)
+    }
+}
+
+// ─── helpers ─────────────────────────────────────────────────────────────────
+
+fn fid() -> FragmentId {
+    FragmentId {
+        chunk: 0xDEAD_BEEF_CAFE_0000_0000_0000_0000_0268_u128,
+        index: 0,
+    }
+}
+
+/// Stand up a tonic D-server service wrapping `store`, bound to an ephemeral
+/// loopback port, and return a connected `GrpcChunkStore` client. The listener is
+/// bound (and thus accepting into the OS backlog) before the client dials, so there
+/// is no startup race — the same pattern `round_trip.rs` uses.
+async fn connect_to<S: ChunkStore + 'static>(
+    store: S,
+) -> (GrpcChunkStore, tokio::task::JoinHandle<()>) {
+    let service = ChunkStoreService::new(store);
+    let listener = tokio::net::TcpListener::bind("127.0.0.1:0")
+        .await
+        .expect("bind loopback");
+    let addr = listener.local_addr().expect("local addr");
+    let server = tokio::spawn(async move {
+        Server::builder()
+            .add_service(ChunkStoreServer::new(service))
+            .serve_with_incoming(TcpListenerStream::new(listener))
+            .await
+            .expect("serve");
+    });
+    let client = GrpcChunkStore::connect(format!("http://{addr}"))
+        .await
+        .expect("connect");
+    (client, server)
+}
+
+// ─── tests ───────────────────────────────────────────────────────────────────
+
+/// Issue #268 — the PRIMARY regression test.
+///
+/// A `get_fragment` that fails at the device with an `EIO` block-layer read fault
+/// must cross the gRPC seam as a **permanent** fault — `is_permanent_read_fault`
+/// returns `true` — so `reconstruction::assess` reads around it and rebuilds from
+/// ≥k survivors instead of retrying.
+///
+/// **Red pre-fix:** the server emitted `INTERNAL` (not `DATA_LOSS`), the client
+/// produced `TransportError::Rpc`, `is_integrity_fault` and `is_block_read_fault`
+/// both returned `false` (no `IntegrityFault` / no `io::Error(EIO)` in the chain),
+/// and `is_permanent_read_fault` returned `false` — the chunk was classified transient.
+///
+/// **Green post-fix:** the server emits `DATA_LOSS`, the client produces
+/// `IntegrityFault`, `is_integrity_fault` returns `true`, `is_permanent_read_fault`
+/// returns `true` — the chunk is classified permanent and read around.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn remote_eio_block_read_fault_is_classified_permanent_over_grpc() {
+    let (client, server) = connect_to(EioStore).await;
+
+    let err = client
+        .get_fragment(fid())
+        .await
+        .expect_err("EIO block-read fault must surface as an error, not Ok(None)");
+
+    // Binding condition (brief §Success criterion): the permanent-vs-transient
+    // classification must survive the wire round-trip. `is_permanent_read_fault`
+    // must return true so `reconstruction::assess` reads around this shard.
+    assert!(
+        wyrd_traits::is_permanent_read_fault(err.as_ref()),
+        "remote EIO block-read fault must be classified as a permanent durability fault \
+         (wyrd_traits::is_permanent_read_fault); the reconstruction loop reads around \
+         permanent faults and retries transient ones. Got: {err}"
+    );
+
+    // The error must NOT be a `TransportError` — that is the transient shape the
+    // retry policy acts on. A permanent fault is distinguishable from a transient one.
+    assert!(
+        err.downcast_ref::<TransportError>().is_none(),
+        "remote EIO block-read fault must NOT be carried as a TransportError (transient); \
+         it must be distinguishable from a truly transient fault. Got: {err}"
+    );
+
+    server.abort();
+}
+
+/// Invariant guard: a generic server-internal error (not EIO, not an integrity
+/// fault) must remain classified as **transient** — `TransportError`, not a
+/// permanent fault. Without this invariant, a temporarily-overloaded or buggy
+/// D server would be misclassified as a dead sector, triggering unnecessary
+/// re-placement and suppressing the retry that would have succeeded.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn remote_generic_error_stays_transient_over_grpc() {
+    let (client, server) = connect_to(GenericErrorStore).await;
+
+    let err = client
+        .get_fragment(fid())
+        .await
+        .expect_err("a generic server error must surface as an error, not Ok(None)");
+
+    // A non-EIO, non-integrity error is NOT a permanent fault.
+    assert!(
+        !wyrd_traits::is_permanent_read_fault(err.as_ref()),
+        "a generic (non-EIO) server error must NOT be classified as a permanent fault; \
+         the retry policy handles it. Got: {err}"
+    );
+
+    // It must be a `TransportError` — the correct transient shape.
+    assert!(
+        err.downcast_ref::<TransportError>().is_some(),
+        "a generic server error must be carried as a TransportError (transient). Got: {err}"
+    );
+
+    server.abort();
+}
