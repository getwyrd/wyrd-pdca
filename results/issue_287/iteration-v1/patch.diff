+// ---- criterion 4: identity-fallback placement protects committed fragments (issue #287) ----
+
+/// **Regression for issue #287.** A committed inode whose `ChunkRef` carries
+/// `placement: vec![]` (a pre-M3 / mixed-era record decoded with `#[serde(default)]`,
+/// `metadata.rs:93`) must have its identity-fallback fragments included in GC's
+/// reference set, so GC does NOT delete a fragment that a stale orphan record points at.
+///
+/// The read path resolves every fragment through `fragment_dserver` (`read.rs:99-105`):
+/// `placement.get(index).copied().unwrap_or(u64::from(index))`. For an empty placement
+/// vector and index 0 this resolves to D-server 0. GC's `referenced_fragments` must
+/// apply the same fallback; without it the set is empty for this chunk and the stale
+/// orphan causes `delete_fragment` — silent data loss on a live committed object.
+///
+/// Flippable: revert the identity-fallback expansion in `referenced_fragments`
+/// (`gc.rs:189`) back to the original `chunk.placement.iter().enumerate()` loop and
+/// this test goes red (GC reclaims the live fragment).
+#[tokio::test]
+async fn identity_fallback_placement_protects_committed_fragment_from_orphan_reclaim() {
+    let meta = MemMeta::default();
+    let d0 = MemDServer::default();
+
+    // A committed inode whose ChunkRef has placement: vec![] (pre-M3 / mixed-era).
+    // The read path resolves fragment 0 → D-server 0 via identity fallback
+    // (`read.rs:fragment_dserver`, `read.rs:99-105`): `placement.get(0)` returns
+    // `None`, so `unwrap_or(u64::from(0))` → D-server 0.
+    let chunk: ChunkId = 0xF6_00;
+    d0.put(frag(chunk, 0)).await;
+    let record = InodeRecord {
+        size: 5,
+        chunk_map: vec![ChunkRef {
+            id: chunk,
+            scheme: EcScheme::None,
+            len: 5,
+            placement: vec![], // pre-M3: empty placement, identity fallback applies
+        }],
+        state: InodeState::Committed,
+        version: 1,
+    };
+    metadata::create(&meta, ROOT, "fallback-obj", 10, &record)
+        .await
+        .unwrap();
+
+    // A stale orphan record for the same fragment (D-server 0, index 0), grace expired.
+    // Pre-fix: `referenced_fragments` iterates `placement.iter()` (empty) → reference
+    // set is empty → the orphan triggers `delete_fragment` → data loss.
+    // Post-fix: `referenced_fragments` applies the identity fallback → (dserver=0,
+    // index=0) is in the reference set → GC skips the fragment.
+    mark_orphaned(&meta, 0, frag(chunk, 0), 0).await.unwrap();
+
+    let coord = MemCoordination::new();
+    let (zone, custodian) = elect(&coord).await;
+    let fleet: [(DServerId, &dyn ChunkStore); 1] = [(0, &d0)];
+    let ctx = GcContext {
+        meta: &meta,
+        fleet: &fleet,
+        grace_window_millis: 0,
+    };
+
+    // now = 1_000_000: far past the orphan grace window. The only protection is the
+    // identity-fallback reference the committed chunk map implies — the SAFETY GATE.
+    let outcome = reconcile_step(&zone, &custodian, Some(&ctx), None, None, None, 1_000_000)
+        .await
+        .unwrap();
+
+    assert_eq!(
+        outcome,
+        Reconciled::Satisfied,
+        "a committed pre-M3 chunk's identity-fallback fragment must not be reclaimed by GC"
+    );
+    assert!(
+        d0.get_fragment(frag(chunk, 0)).await.unwrap().is_some(),
+        "identity-fallback fragment of a committed chunk is NEVER passed to delete_fragment (issue #287)"
+    );
+}
+
 // ---- criterion 3: grace window honoured (the flippable timing invariant) ----
 
 #[tokio::test]
