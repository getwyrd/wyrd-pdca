+/// Admission-control and backpressure configuration for the d-server's gRPC
+/// transport — the knobs that make the request-admission path **fail closed
+/// under pressure** (architecture §8.9,
+/// `docs/design/architecture/08-crosscutting-concepts.md:98-107`) instead of
+/// degrading into unbounded contention and thread-pool exhaustion.
+///
+/// Beyond [`max_concurrent_requests`](Self::max_concurrent_requests) admitted per
+/// connection the server sheds the excess with a retryable `RESOURCE_EXHAUSTED`
+/// "busy" signal (when [`load_shed`](Self::load_shed) is set, the default), so an
+/// overloaded client is told to back off and retry rather than having its requests
+/// queue without bound and contend for runtime threads.
+/// [`request_timeout`](Self::request_timeout) bounds the work a single request can
+/// pin, so a hung handler is cut loose with a deadline status rather than holding
+/// an admission slot forever.
+///
+/// **Tuning to the device's useful queue depth.** The admission limit should track
+/// how many concurrent I/Os the backing store serves *usefully*: a single HDD
+/// spindle saturates at a shallow queue (tune it *down*, e.g. 8–16), while an
+/// SSD/NVMe device sustains a much deeper queue (tune it *up*, e.g. 256+). The
+/// [`Default`] is a moderate middle ground ([`DEFAULT_MAX_CONCURRENT_REQUESTS`]) —
+/// it is **not** a fixed constant; operators set it per deployment.
+#[derive(Debug, Clone)]
+pub struct AdmissionControl {
+    /// Maximum concurrent in-flight requests admitted **per connection**; beyond
+    /// it the excess is shed (see [`load_shed`](Self::load_shed)).
+    pub max_concurrent_requests: usize,
+    /// Shed (`true`) rather than buffer (`false`) the over-limit excess. `true` is
+    /// the fail-closed posture: an over-limit request is rejected immediately with
+    /// a retryable `RESOURCE_EXHAUSTED` status instead of contending for threads.
+    pub load_shed: bool,
+    /// Hard per-request timeout: a handler that runs longer is cut with a deadline
+    /// status, freeing its admission slot.
+    pub request_timeout: Duration,
+    /// Maximum concurrent HTTP/2 inbound streams per connection — caps the
+    /// transport-level request fan-in.
+    pub max_concurrent_streams: u32,
+    /// Disable Nagle's algorithm: gRPC frames are small and latency-sensitive, so
+    /// coalescing them adds delay for no throughput gain.
+    pub tcp_nodelay: bool,
+    /// HTTP/2 server keepalive ping interval; `None` disables keepalive.
+    pub http2_keepalive_interval: Option<Duration>,
+}
+
+impl Default for AdmissionControl {
+    fn default() -> Self {
+        Self {
+            max_concurrent_requests: DEFAULT_MAX_CONCURRENT_REQUESTS,
+            load_shed: true,
+            request_timeout: DEFAULT_REQUEST_TIMEOUT,
+            max_concurrent_streams: DEFAULT_MAX_CONCURRENT_STREAMS,
+            tcp_nodelay: true,
+            http2_keepalive_interval: Some(DEFAULT_HTTP2_KEEPALIVE_INTERVAL),
+        }
+    }
+}
