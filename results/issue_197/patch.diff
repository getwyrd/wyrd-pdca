+}
+
+async fn read_inode_id(meta: &MemMeta, id: InodeId) -> InodeRecord {
     let bytes = meta
-        .get(&metadata::inode_key(1))
+        .get(&metadata::inode_key(id))
         .await
         .unwrap()
