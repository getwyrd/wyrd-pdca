+//! The zone-local failure-domain-aware placement selector.
+//!
+//! Re-exported from [`wyrd_core::placement`], its shared home: the **write
+//! fan-out** (which lives in `core`) and custodian **re-placement** use one
+//! primitive, so a chunk's `n` fragments occupy `n` distinct failure domains on
+//! both write and repair (proposal 0005 §"Failure-domain-aware placement"). The
+//! model is thin on purpose — an opaque [`DomainId`] per D server plus the
+//! distinctness invariant of [`select_distinct_domains`] — so M6's placement
+//! *policy* service layers on rather than replaces it.
+
+pub use wyrd_core::placement::{
+    select_distinct_domains, Candidate, DomainId, Placement, PlacementError, ServerId,
+};
diff --git a/crates/custodian/src/telemetry.rs b/crates/custodian/src/telemetry.rs
new file mode 100644
index 0000000..d4140cb
--- /dev/null
+++ b/crates/custodian/src/telemetry.rs
@@ -0,0 +1,80 @@
+//! The backend-agnostic OpenTelemetry seam (proposal 0005 §"The durability
+//! plane", ADR-0012).
+//!
+//! Durability metrics are emitted through the [`MetricExporter`] trait, which
+//! names **no** concrete backend (ADR-0010). Production wires a
+//! `tracing-opentelemetry` layer exposing **both** a Prometheus-scrapeable
+//! endpoint and an OTLP push behind this trait; the
+//! `tracing-opentelemetry`/`opentelemetry-otlp`/Prometheus-exporter dependency +
+//! `deny.toml` audit is a sign-off NEEDS-HUMAN item (proposal 0005 Impact, ADR-0003).
+//! Tests wire [`InMemoryExporter`] to assert emission **in-process**. Either way
+//! the custodian emits a **first metric from its first commit** (ADR-0011) and
+//! hardcodes no backend. Each metric is also surfaced as a `tracing` event — the
+//! ingestion point the OTel layer subscribes to.
+
+use std::sync::Mutex;
+
+/// The first custodian metric: a gauge that is `1` while a custodian is up. Its
+/// emission from the first commit is what proves the durability plane is wired
+/// (ADR-0011), so every later loop emits from its own first commit.
+pub const CUSTODIAN_UP: &str = "custodian_up";
+
+/// One emitted metric sample.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct Metric {
+    /// The metric name (e.g. [`CUSTODIAN_UP`]).
+    pub name: &'static str,
+    /// The metric value.
+    pub value: u64,
+}
+
+/// The backend-agnostic exporter seam. Concrete exporters — a Prometheus-scrapeable
+/// endpoint, an OTLP pusher, or the in-process [`InMemoryExporter`] — implement
+/// this; the custodian never names one (ADR-0010, ADR-0012).
+pub trait MetricExporter: Send + Sync {
+    /// Record one emitted metric sample.
+    fn record(&self, metric: Metric);
+}
+
+/// Emit the custodian's first metric(s) through `exporter` (ADR-0011: telemetry
+/// from the custodian's first commit). The sample is also raised as a `tracing`
+/// event — the seam the production OTel layer (Prometheus + OTLP) subscribes to.
+pub fn emit_startup_metrics(exporter: &dyn MetricExporter) {
+    let metric = Metric {
+        name: CUSTODIAN_UP,
+        value: 1,
+    };
+    tracing::info!(
+        metric = metric.name,
+        value = metric.value,
+        "custodian telemetry seam online"
+    );
+    exporter.record(metric);
+}
+
+/// An in-process exporter that records samples into a buffer, so emission is
+/// assertable in-process at C4-verify. Production wires the OTel (Prometheus +
+/// OTLP) exporter behind the same [`MetricExporter`] trait.
+#[derive(Default)]
+pub struct InMemoryExporter {
+    samples: Mutex<Vec<Metric>>,
+}
+
+impl InMemoryExporter {
+    /// A snapshot of the samples recorded so far.
+    pub fn samples(&self) -> Vec<Metric> {
+        self.samples
+            .lock()
+            .expect("exporter mutex poisoned")
+            .clone()
+    }
+}
+
+impl MetricExporter for InMemoryExporter {
+    fn record(&self, metric: Metric) {
+        self.samples
+            .lock()
+            .expect("exporter mutex poisoned")
+            .push(metric);
+    }
+}
diff --git a/crates/custodian/tests/skeleton.rs b/crates/custodian/tests/skeleton.rs
new file mode 100644
index 0000000..6aaf5be
--- /dev/null
+++ b/crates/custodian/tests/skeleton.rs
@@ -0,0 +1,114 @@
+//! M3.3 custodian-skeleton acceptance (proposal 0005 PR-sequence step 3).
+//!
+//! Demonstrates the three load-bearing seams of the slice:
+//!   1. a single active custodian is **elected and fenced** — a deposed leader's
+//!      reconciliation action is **rejected** (stale fencing token);
+//!   2. the **failure-domain selector** places `n` fragments across `n` distinct
+//!      domains where the topology offers `>= n`, and refuses otherwise;
+//!   3. the **exporter emits a first custodian metric** through a backend-agnostic
+//!      seam, observable in-process.
+
+use std::collections::HashSet;
+
+use pollster::block_on;
+use wyrd_coordination_mem::MemCoordination;
+use wyrd_custodian::leadership::{Custodian, LeadershipFence};
+use wyrd_custodian::selector::{select_distinct_domains, Candidate, DomainId, ServerId};
+use wyrd_custodian::telemetry::{emit_startup_metrics, InMemoryExporter, CUSTODIAN_UP};
+
+/// (1) A single active custodian is elected via the existing
+/// `Coordination::elect_leader`, fenced by its `Leadership` token; a deposed
+/// custodian's coordination action is rejected.
+#[test]
+fn elected_custodian_is_fenced_and_a_deposed_leader_is_rejected() {
+    let coord = MemCoordination::new();
+    let mut fence = LeadershipFence::new();
+
+    // The first custodian wins leadership and, as the current term, reconciles.
+    let leader = block_on(Custodian::elect(&coord, "zone-a")).expect("elect leader");
+    fence.install(leader.leadership());
+    assert!(
+        leader.reconcile_tick(&fence).is_ok(),
+        "the active leader holds the current term and may act"
+    );
+
+    // A new custodian wins a fresh, strictly-higher term; `leader` is now deposed.
+    let successor = block_on(Custodian::elect(&coord, "zone-a")).expect("elect successor");
+    fence.install(successor.leadership());
+    assert!(
+        successor.leadership().token > leader.leadership().token,
+        "each election term carries a strictly-rising fencing token"
+    );
+
+    // The new leader acts; the deposed one's action MUST be rejected.
+    assert!(
+        successor.reconcile_tick(&fence).is_ok(),
+        "the new leader holds the current term"
+    );
+    assert!(
+        leader.reconcile_tick(&fence).is_err(),
+        "a deposed custodian's action MUST be rejected by its stale fencing token"
+    );
+}
+
+/// (2) The selector places `n` fragments across `n` distinct failure domains when
+/// the topology offers `>= n` domains.
+#[test]
+fn selector_places_fragments_across_n_distinct_domains() {
+    // Five servers spanning four distinct domains (two share `rack-a`).
+    let candidates = vec![
+        Candidate::new(ServerId(0), DomainId::new("rack-a")),
+        Candidate::new(ServerId(1), DomainId::new("rack-a")),
+        Candidate::new(ServerId(2), DomainId::new("rack-b")),
+        Candidate::new(ServerId(3), DomainId::new("rack-c")),
+        Candidate::new(ServerId(4), DomainId::new("rack-d")),
+    ];
+    let n = 3;
+
+    let chosen = select_distinct_domains(&candidates, n).expect("topology has >= n domains");
+    assert_eq!(chosen.len(), n, "one placement per fragment");
+
+    let distinct_domains: HashSet<_> = chosen.iter().map(|p| p.domain.clone()).collect();
+    assert_eq!(
+        distinct_domains.len(),
+        n,
+        "the n fragments must occupy n DISTINCT failure domains"
+    );
+    let distinct_servers: HashSet<_> = chosen.iter().map(|p| p.server).collect();
+    assert_eq!(
+        distinct_servers.len(),
+        n,
+        "each fragment on a distinct server"
+    );
+}
+
+/// (2b) The selector refuses rather than collapse two fragments into one domain
+/// when the topology offers fewer than `n` distinct domains.
+#[test]
+fn selector_refuses_when_topology_has_too_few_domains() {
+    let candidates = vec![
+        Candidate::new(ServerId(0), DomainId::new("rack-a")),
+        Candidate::new(ServerId(1), DomainId::new("rack-a")),
+        Candidate::new(ServerId(2), DomainId::new("rack-b")),
+    ];
+    assert!(
+        select_distinct_domains(&candidates, 3).is_err(),
+        "only 2 distinct domains exist; placing 3 distinctly is impossible"
+    );
+}
