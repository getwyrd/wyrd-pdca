+/// (3) The exporter emits a first custodian metric through a backend-agnostic
+/// seam, observable in-process — no concrete backend named.
+#[test]
+fn exporter_emits_first_custodian_metric_with_no_backend_hardcoded() {
+    let exporter = InMemoryExporter::default();
+    emit_startup_metrics(&exporter);
+
+    let samples = exporter.samples();
+    assert!(
+        samples
+            .iter()
+            .any(|m| m.name == CUSTODIAN_UP && m.value == 1),
+        "the custodian must emit its first metric ({CUSTODIAN_UP}) from startup"
+    );
+}
