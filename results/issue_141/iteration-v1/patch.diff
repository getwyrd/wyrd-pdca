diff --git a/crates/custodian/src/leadership.rs b/crates/custodian/src/leadership.rs
new file mode 100644
index 0000000..5121e14
--- /dev/null
+++ b/crates/custodian/src/leadership.rs
@@ -0,0 +1,101 @@
+//! Single active custodian leadership, fenced (proposal 0005 §"Single active
+//! custodian, fenced").
+//!
+//! One active leader per zone, elected via the **existing**
+//! [`Coordination::elect_leader`], which returns a fenced [`Leadership`] token.
+//! Two guards make a deposed-but-still-running custodian safe (proposal 0005):
+//! the **fencing token** rejects its coordination actions, and — for the later
+//! mutating slices — its location-update commit is version-conditional. This
+//! skeleton implements the first guard: a [`LeadershipFence`] tracks the zone's
+//! current term, and a custodian whose token is stale against it is refused.
+//!
+//! A real coordination backend (etcd) enforces the fence server-side; the
+//! in-memory backend always grants leadership (a lone process is always the
+//! leader) but hands out a strictly-rising token per term, so the fence here is
+//! the faithful zone-local model of "stale token ⇒ rejected".
+
+use wyrd_traits::{Coordination, FencingToken, Leadership, Result};
+
+use crate::reconcile::TickReport;
+
+/// A single active custodian for a zone, holding the [`Leadership`] token its
+/// election term was granted.
+pub struct Custodian {
+    zone: String,
+    leadership: Leadership,
+}
+
+impl Custodian {
+    /// Campaign to become the single active custodian for `zone`, via the existing
+    /// [`Coordination::elect_leader`], taking the fenced [`Leadership`] token of
+    /// the granted term.
+    pub async fn elect(coord: &dyn Coordination, zone: &str) -> Result<Self> {
+        let leadership = coord.elect_leader(&leader_key(zone)).await?;
+        Ok(Self {
+            zone: zone.to_owned(),
+            leadership,
+        })
+    }
+
+    /// The zone this custodian was elected for.
+    pub fn zone(&self) -> &str {
+        &self.zone
+    }
+
+    /// The fenced leadership token of this custodian's term.
+    pub fn leadership(&self) -> Leadership {
+        self.leadership
+    }
+
+    /// Run one reconciliation tick, **refused if this custodian has been deposed**
+    /// — i.e. its leadership token is stale against the zone's current term
+    /// (`fence`). This is the fencing guard that makes a deposed-but-running
+    /// custodian safe (proposal 0005 §"Single active custodian, fenced"): only the
+    /// holder of the current term may act.
+    pub fn reconcile_tick(&self, fence: &LeadershipFence) -> Result<TickReport> {
+        crate::reconcile::reconcile_once(self, fence)
+    }
+}
+
+/// The coordination key the zone's custodian leadership is campaigned under.
+fn leader_key(zone: &str) -> String {
+    format!("custodian/{zone}/leader")
+}
+
+/// The zone's view of the **current** leadership term: the highest fencing token
+/// granted so far. It is what a deposed custodian's action is checked against.
+#[derive(Debug, Default, Clone, Copy)]
+pub struct LeadershipFence {
+    current: FencingToken,
+}
+
+impl LeadershipFence {
+    /// A fence with no term installed yet (no leader has acted).
+    pub fn new() -> Self {
+        Self::default()
+    }
+
+    /// Install a newly granted leadership term. Monotonic: a later term fences an
+    /// earlier one, and re-installing an older term never lowers the fence.
+    pub fn install(&mut self, leadership: Leadership) {
+        self.current = self.current.max(leadership.token);
+    }
+
+    /// The current term's fencing token.
+    pub fn current_term(&self) -> FencingToken {
+        self.current
+    }
+
+    /// Check that `leadership` is the current term; reject a deposed leader whose
+    /// token is stale (strictly less than the current term).
+    pub fn guard(&self, leadership: Leadership) -> Result<()> {
+        if leadership.token < self.current {
+            return Err(format!(
+                "deposed custodian: stale fencing token {} < current term {}",
+                leadership.token, self.current
+            )
+            .into());
+        }
+        Ok(())
+    }
+}
