index 0000000..35c9f36
--- /dev/null
+++ b/crates/core/src/placement.rs
@@ -0,0 +1,134 @@
+//! Failure-domain-aware placement selector (proposal 0005 §"Failure-domain-aware
+//! placement", §7.3) — the zone-local primitive **shared by the write fan-out and
+//! by custodian re-placement**, so a chunk's `n` fragments occupy `n` distinct
+//! failure domains wherever the topology offers `>= n` of them.
+//!
+//! It lives in `core` on purpose: the write fan-out itself lives here
+//! ([`crate::write::write_fragments`]), and the L4 `custodian` crate re-exports
+//! this module (`wyrd_custodian::selector`) — one definition, two consumers, no
+//! cross-crate cycle (proposal 0005 Open questions: "where it lives — core vs.
+//! custodian, re-exported"). The boundary with L2 / M6 is deliberate: M3 owns
+//! enforcement on write and repair with zone-local labels; the placement *policy*
+//! service is M6 and layers on top.
+//!
+//! The model is kept deliberately thin (proposal 0005): each D server carries an
+//! **opaque** failure-domain id ([`DomainId`]) — the selector uses only its
+//! identity (equality), never parsing rack/power/switch structure — plus the
+//! **distinctness invariant** enforced by [`select_distinct_domains`]. The
+//! selection *algorithm* below is illustrative (greedy first-fit by domain); the
+//! load-bearing contract is the distinctness invariant on its output.
+
+use std::collections::HashSet;
+use std::fmt;
+
+/// A stable D-server identity (proposal 0005 §"Stable D-server identity"): a
+/// server is referenced by a stable id, not its endpoint URL, so a placement
+/// record survives a rebind. Opaque to the selector.
+#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
+pub struct ServerId(pub u64);
+
+/// An **opaque** failure-domain label (rack / power / switch, §7.3). The selector
+/// compares it only by identity; it never interprets the contents, so M6's
+/// placement policy can refine the labelling without changing this primitive.
+#[derive(Clone, Debug, PartialEq, Eq, Hash)]
+pub struct DomainId(String);
+
+impl DomainId {
+    /// Wrap an opaque domain label (the value surfaced through D-server
+    /// registration). The selector treats it purely as an identity.
+    pub fn new(label: impl Into<String>) -> Self {
+        Self(label.into())
+    }
+}
+
+/// A candidate D server for placement: its stable id and the failure domain it
+/// sits in.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct Candidate {
+    /// The stable D-server id.
+    pub server: ServerId,
+    /// The opaque failure domain the server occupies.
+    pub domain: DomainId,
+}
+
+impl Candidate {
+    /// A candidate `server` sitting in failure `domain`.
+    pub fn new(server: ServerId, domain: DomainId) -> Self {
+        Self { server, domain }
+    }
+}
+
+/// One chosen placement: a fragment is placed on `server`, which sits in `domain`.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct Placement {
+    /// The stable id of the server a fragment is placed on.
+    pub server: ServerId,
+    /// The failure domain that server occupies.
+    pub domain: DomainId,
+}
+
+/// Why a domain-distinct placement could not be produced.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub enum PlacementError {
+    /// The topology offers fewer than `needed` distinct failure domains, so the
+    /// `n`-distinct invariant cannot be met — the caller must not place anyway
+    /// (durability is gate-zero, proposal 0005 §"Failure-domain-aware placement").
+    InsufficientDomains {
+        /// The number of distinct domains required (`n`).
+        needed: usize,
+        /// The number of distinct domains the topology actually offers.
+        found: usize,
+    },
+}
+
+impl fmt::Display for PlacementError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            PlacementError::InsufficientDomains { needed, found } => write!(
+                f,
+                "cannot place across {needed} distinct failure domains: topology offers only {found}"
+            ),
+        }
+    }
+}
+
+impl std::error::Error for PlacementError {}
+
+/// Select `n` placements across `n` **distinct** failure domains from
+/// `candidates`.
+///
+/// Returns exactly `n` placements, each in a distinct failure domain, when the
+/// candidate set spans `>= n` domains. When it spans fewer, returns
+/// [`PlacementError::InsufficientDomains`] rather than collapsing two fragments
+/// into one domain — the distinctness invariant is the durability guarantee, not
+/// a best-effort hint.
+///
+/// The algorithm (greedy first-fit by domain) is illustrative; the contract is
+/// the post-condition: the returned servers occupy `n` distinct domains.
+pub fn select_distinct_domains(
+    candidates: &[Candidate],
+    n: usize,
+) -> Result<Vec<Placement>, PlacementError> {
+    let mut chosen: Vec<Placement> = Vec::with_capacity(n);
+    let mut used: HashSet<&DomainId> = HashSet::new();
+    for candidate in candidates {
+        if chosen.len() == n {
+            break;
+        }
+        // First server seen in a not-yet-used domain wins the slot; subsequent
+        // servers in that domain are skipped, which is what enforces distinctness.
+        if used.insert(&candidate.domain) {
+            chosen.push(Placement {
+                server: candidate.server,
+                domain: candidate.domain.clone(),
+            });
+        }
+    }
+    if chosen.len() < n {
+        return Err(PlacementError::InsufficientDomains {
+            needed: n,
+            found: used.len(),
+        });
+    }
+    Ok(chosen)
+}
