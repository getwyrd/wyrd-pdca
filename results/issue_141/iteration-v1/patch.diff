@@ -0,0 +1,35 @@
+//! The reconciliation control-loop skeleton (proposal 0005 §"The four custodian
+//! loops", §"Declarative management hook").
+//!
+//! The custodian runs continuous reconciliation loops on the single active leader,
+//! reading authoritative state and converging reality toward the recorded intent.
+//! This slice (M3.3) stands up only the **scaffold**: a single fenced tick that
+//! the four loops' *behaviour* (GC, scrub, reconstruction, rebalance — proposal
+//! 0005 slices 4–7) will fill in. Each tick is gated by the leadership fence so a
+//! deposed custodian converges nothing.
+
+use wyrd_traits::{FencingToken, Result};
+
+use crate::leadership::{Custodian, LeadershipFence};
+
+/// The outcome of one reconciliation tick.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct TickReport {
+    /// The leadership term the tick ran under (proof it ran as the current leader).
+    pub term: FencingToken,
+}
+
+/// Run one reconciliation tick for `custodian`, gated by the zone's leadership
+/// `fence`. Returns the [`TickReport`] when the custodian still holds the current
+/// term; an error when it has been deposed (its token is stale).
+///
+/// The tick body is a no-op skeleton: the convergence work of each loop is slices
+/// 4–7 of proposal 0005. What is load-bearing here is the fence gate.
+pub fn reconcile_once(custodian: &Custodian, fence: &LeadershipFence) -> Result<TickReport> {
+    fence.guard(custodian.leadership())?;
+    // Skeleton: no loop behaviour runs yet (proposal 0005 slices 4–7). The tick
+    // simply reports the term it ran under, proving the gate let the leader act.
+    Ok(TickReport {
+        term: custodian.leadership().token,
+    })
+}
