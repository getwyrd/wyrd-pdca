+name: tier2-kill-reconstruct
+
+# **Tier-2 single-node kill-and-reconstruct campaign** (M3.8, proposal 0005 §13.2,
+# `0005:409-411`): stand up a cluster of real, networked gRPC D servers under
+# docker-compose, kill one of them, drive the **production** custodian reconstruction
+# path (`custodian::reconcile_step` → `reconstruction::reconcile`) against the live
+# cluster, and assert the durability outcome.
+#
+# Three campaign properties (`0005:381-403`):
+#   1. Reconstruct-to-full-redundancy — victim's chunk returns to N fragments in
+#      DISTINCT failure domains.
+#   2. Commit-point-atomic repair under crash — a crash before the version-conditional
+#      commit leaves the inode FULLY OLD, never a hybrid; placed-but-uncommitted
+#      fragment is collectable garbage (`0005:385-389`).
+#   3. Data integrity — erasure-decoding any K of the N post-repair fragments
+#      reconstructs the original bytes exactly.
+#
+# This job is the **deferred-posture** leg of the M3 campaign: the harness is compiled
+# and type-checked at Check by `cargo xtask ci`'s `cargo test --workspace` (which
+# compiles `#[ignore]`d bodies); this job provides the supplementary green evidence that
+# the harness runs correctly on a real node with a real Docker daemon.
+#
+# Modelled on `integration-nightly.yml` (M2.7, proposal 0004). Not a required status
+# check (it needs a privileged container runtime); its value is post-merge regression
+# visibility. Opted in via WYRD_TIER2=1.
+
+on:
+  schedule:
+    # 05:00 UTC daily (offset from integration-nightly.yml's 04:00 to avoid runner contention).
+    - cron: "0 5 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier2-kill-reconstruct-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  kill-reconstruct:
+    runs-on: ubuntu-latest
+    # Cold image build + 10-server cluster + three-phase scenario fit well under this.
+    # Matches integration-nightly.yml's bound (#150).
+    timeout-minutes: 45
+    env:
+      CI: "true"
+      WYRD_TIER2: "1"
+    steps:
+      - uses: actions/checkout@v7
+
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # ubuntu-latest ships Docker with the compose plugin; this confirms the daemon
+      # is reachable (same check integration-nightly.yml uses).
+      - name: Docker info
+        run: docker info
+
+      - name: cargo xtask kill-reconstruct
+        run: cargo xtask kill-reconstruct
+
+      # Surface container diagnostics captured by finalize_panic_safe before teardown
+      # (#150): `compose_logs` writes to target/tier2-logs/ on failure so the
+      # diagnostics survive compose_down.
+      - name: Upload container diagnostics
+        if: failure()
+        uses: actions/upload-artifact@v7
+        with:
+          name: tier2-kill-reconstruct-logs
+          path: target/tier2-logs/
+          if-no-files-found: ignore
+          retention-days: 14
