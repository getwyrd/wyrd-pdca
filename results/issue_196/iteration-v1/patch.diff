diff --git a/xtask/src/kill_reconstruct.rs b/xtask/src/kill_reconstruct.rs
new file mode 100644
index 0000000..57aca6e
--- /dev/null
+++ b/xtask/src/kill_reconstruct.rs
@@ -0,0 +1,258 @@
+//! Host-independent orchestration helpers for the Tier-2 kill-and-reconstruct
+//! harness (proposal 0005 §13.2, `0005:409-411`; the crate touch-point `0005:437-438`).
+//!
+//! Pure functions extracted from the orchestration flow so they are unit-testable
+//! inside `cargo xtask ci` without a container runtime or privileged environment —
+//! the "born-at-tier coverage" the verification posture requires (brief §"Verification
+//! posture"). The live orchestration that threads these through the compose/finalize
+//! plumbing lives in [`crate::faults::run_kill_reconstruct`].
+
+/// Number of D-server containers the Tier-2 kill-and-reconstruct cluster stands up:
+/// [`crate::DSERVER_COUNT`] (nine, for the RS(6,3) initial placement) plus **one spare**
+/// server that reconstruction re-places the rebuilt fragment onto after the victim is
+/// killed. The spare (index [`crate::DSERVER_COUNT`]) is in a distinct failure domain
+/// from every initial server so the post-reconstruction placement spans N distinct
+/// failure domains.
+pub(crate) const KR_DSERVER_COUNT: usize = crate::DSERVER_COUNT + 1;
+
+/// Select the kill-victim by 0-indexed server index. Deterministic: always selects
+/// server 0 (the first D server). Pure so unit tests can assert it without a container.
+///
+/// The simplest deterministic policy — "always the first" — is sufficient because the
+/// harness's invariant (full reconstruction over the surviving fleet) is server-index-
+/// agnostic; the Tier-0 DST already seeds-varies the kill index over all `N` servers
+/// (`crates/dst/tests/custodian.rs:529-530`). The Tier-2 harness proves the same
+/// invariant holds over **real gRPC D-server containers**.
+pub(crate) fn select_victim_index(_server_count: usize) -> usize {
+    0
+}
+
+/// Produce the Docker container name for the kill-victim. Docker Compose V2 names
+/// replicas `<project>-<service>-<1-indexed-replica>`, so 0-indexed victim index 0
+/// maps to replica 1 of the `dserver` service under [`crate::TIER2_PROJECT`].
+pub(crate) fn victim_container_name(victim_index: usize) -> String {
+    format!("{}-dserver-{}", crate::TIER2_PROJECT, victim_index + 1)
+}
+
+/// Assert the post-reconstruction placement outcome:
+/// - exactly `n` fragments are placed (full redundancy restored);
+/// - the killed server (`victim_id`) is no longer in the placement.
+///
+/// Returns `Ok(())` when both hold, `Err` describing the first violation otherwise.
+#[cfg(test)]
+pub(crate) fn assert_redundancy_outcome(
+    placement: &[u64],
+    victim_id: u64,
+    n: usize,
+) -> Result<(), String> {
+    if placement.len() != n {
+        return Err(format!(
+            "expected {n} fragments in placement after reconstruction, got {}; \
+             full redundancy not restored",
+            placement.len()
+        ));
+    }
+    if placement.contains(&victim_id) {
+        return Err(format!(
+            "killed server {victim_id} still appears in the post-reconstruction placement; \
+             reconstruction must not re-place onto the dead server"
+        ));
+    }
+    Ok(())
+}
+
+/// Assert that all fragments in `placement` are on **distinct** failure domains,
+/// using `domain_of(server_id)` to look up each server's domain label.
+///
+/// The distinct-domain invariant (`0005:241-242`, `0005:382-383`): each fragment of a
+/// replicated chunk must reside on a separate failure domain so a single-domain loss
+/// (e.g. a rack failure) cannot take more than `m` fragments. Reconstruction preserves
+/// this by selecting re-placement servers via `select_distinct_domains_excluding`.
+///
+/// Returns `Ok(())` when all domains are distinct, `Err` on the first violation.
+#[cfg(test)]
+pub(crate) fn assert_distinct_domains<'a, F>(placement: &[u64], domain_of: F) -> Result<(), String>
+where
+    F: Fn(u64) -> Option<&'a str>,
+{
+    use std::collections::HashSet;
+    let mut seen: HashSet<&str> = HashSet::new();
+    for &server in placement {
+        let domain = domain_of(server).ok_or_else(|| {
+            format!(
+                "server {server} has no failure-domain assignment in the topology; \
+                 all placed servers must be registered"
+            )
+        })?;
+        if !seen.insert(domain) {
+            return Err(format!(
+                "duplicate failure domain `{domain}` in placement: two fragments are on \
+                 the same domain (server {server}), violating the distinct-domain invariant"
+            ));
+        }
+    }
+    Ok(())
+}
+
+/// Assert the garbage-not-corruption invariant after a crash mid-repair
+/// (`0005:277`, `0005:385-389`):
+///
+/// - The placed-but-uncommitted rebuilt fragment **EXISTS** on the new server
+///   (`orphaned_fragment_exists`): the write-before-commit ordering in
+///   `reconstruction::repair_chunk` ensures a crash leaves a collectable orphan, not
+///   missing bytes.
+/// - The committed chunk map does **NOT** reference the victim
+///   (`committed_placement_has_victim == false`): the version-conditional commit never
+///   landed, so the inode is at its prior (fully-old) value — never a hybrid.
+///
+/// Returns `Ok(())` when both hold, `Err` describing the first violation otherwise.
+#[cfg(test)]
+pub(crate) fn assert_garbage_not_corruption(
+    orphaned_fragment_exists: bool,
+    committed_placement_has_victim: bool,
+) -> Result<(), String> {
+    if !orphaned_fragment_exists {
+        return Err(
+            "placed-but-uncommitted rebuilt fragment is absent after a crash mid-repair; \
+             reconstruction writes the fragment BEFORE its commit, so a crash must leave it \
+             as collectable garbage — its absence means the write-before-commit ordering \
+             was violated"
+                .to_string(),
+        );
+    }
+    if committed_placement_has_victim {
+        return Err(
+            "the committed chunk map still references the victim after a crash mid-repair; \
+             the version-conditional commit must NOT have landed — a crashed custodian \
+             must leave the inode fully old, never a torn/hybrid chunk"
+                .to_string(),
+        );
+    }
+    Ok(())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    // ---- select_victim_index ----
+
+    #[test]
+    fn victim_is_always_server_zero() {
+        // The policy is deterministic: always the first server (index 0).
+        assert_eq!(select_victim_index(4), 0);
+        assert_eq!(select_victim_index(9), 0);
+        assert_eq!(select_victim_index(10), 0);
+    }
+
+    // ---- victim_container_name ----
+
+    #[test]
+    fn container_name_is_one_indexed() {
+        // Docker Compose V2 names replicas starting at 1 (0-indexed victim 0 → replica 1).
+        assert_eq!(victim_container_name(0), "wyrd-tier2-dserver-1");
+        assert_eq!(victim_container_name(1), "wyrd-tier2-dserver-2");
+        assert_eq!(victim_container_name(2), "wyrd-tier2-dserver-3");
+    }
+
+    // ---- assert_redundancy_outcome ----
+
+    #[test]
+    fn redundancy_outcome_passes_when_victim_absent_and_n_fragments() {
+        // Victim = 0, N = 3. Placement [1, 2, 3]: victim absent, exactly 3 fragments.
+        assert!(
+            assert_redundancy_outcome(&[1, 2, 3], 0, 3).is_ok(),
+            "victim 0 absent, 3 fragments: must pass"
+        );
+    }
+
+    #[test]
+    fn redundancy_outcome_fails_when_victim_in_placement() {
+        let result = assert_redundancy_outcome(&[0, 1, 2], 0, 3);
+        assert!(result.is_err());
+        let err = result.unwrap_err();
+        assert!(
+            err.contains("still appears"),
+            "error must name the violation: {err}"
+        );
+    }
+
+    #[test]
+    fn redundancy_outcome_fails_when_wrong_fragment_count() {
+        // Only 2 fragments in placement, need 3.
+        let result = assert_redundancy_outcome(&[1, 2], 0, 3);
+        assert!(result.is_err());
+        let err = result.unwrap_err();
+        assert!(
+            err.contains('2'),
+            "error must cite the observed count: {err}"
+        );
+    }
+
+    // ---- assert_distinct_domains ----
+
+    #[test]
+    fn distinct_domains_passes_for_all_different() {
+        let domain_of =
+            |id: u64| -> Option<&'static str> { ["A", "B", "C", "D"].get(id as usize).copied() };
+        // [1, 2, 3] → domains B, C, D — all distinct.
+        assert!(
+            assert_distinct_domains(&[1, 2, 3], domain_of).is_ok(),
+            "all distinct domains: must pass"
+        );
+    }
+
+    #[test]
+    fn distinct_domains_fails_for_duplicate_domain() {
+        // Servers 1 and 3 share domain "B" in this test topology.
+        let domain_of = |id: u64| -> Option<&'static str> {
+            match id {
+                1 => Some("B"),
+                2 => Some("C"),
+                3 => Some("B"), // duplicate!
+                _ => None,
+            }
+        };
+        let result = assert_distinct_domains(&[1, 2, 3], domain_of);
+        assert!(result.is_err());
+        let err = result.unwrap_err();
+        assert!(
+            err.contains("duplicate"),
+            "error must name the violation: {err}"
+        );
+        assert!(
+            err.contains('B'),
+            "error must name the duplicated domain: {err}"
+        );
+    }
+
+    #[test]
+    fn distinct_domains_fails_for_unregistered_server() {
+        let domain_of = |_: u64| -> Option<&'static str> { None };
+        let result = assert_distinct_domains(&[0], domain_of);
+        assert!(result.is_err());
+        assert!(result.unwrap_err().contains("no failure-domain assignment"));
+    }
+
+    // ---- assert_garbage_not_corruption ----
+
+    #[test]
+    fn garbage_not_corruption_passes_when_orphan_exists_and_committed_unchanged() {
+        // orphaned fragment exists, victim NOT in committed placement.
+        assert!(assert_garbage_not_corruption(true, false).is_ok());
+    }
+
+    #[test]
+    fn garbage_not_corruption_fails_when_orphan_absent() {
+        let result = assert_garbage_not_corruption(false, false);
+        assert!(result.is_err());
+        assert!(result.unwrap_err().contains("absent"));
+    }
+
+    #[test]
+    fn garbage_not_corruption_fails_when_victim_in_committed_placement() {
+        let result = assert_garbage_not_corruption(true, true);
+        assert!(result.is_err());
+        assert!(result.unwrap_err().contains("hybrid"));
+    }
+}
