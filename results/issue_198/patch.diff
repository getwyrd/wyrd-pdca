diff --git a/crates/core/tests/read_repair.rs b/crates/core/tests/read_repair.rs
index b9a49c3..a5fca62 100644
--- a/crates/core/tests/read_repair.rs
+++ b/crates/core/tests/read_repair.rs
@@ -253,3 +253,134 @@ async fn unrecoverable_read_still_enqueues_the_corrupt_chunk() {
