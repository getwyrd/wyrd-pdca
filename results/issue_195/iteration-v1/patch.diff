+++ b/.github/workflows/tier1-disk-faults.yml
@@ -0,0 +1,69 @@
+name: tier1-disk-faults
+
+# Tier-1 disk-fault tier (Milestone 3, proposal 0005 §"DST and tests", 0005:405-408):
+# the privileged, off-Check leg of the M3 verification campaign. It stands up a real
+# device-mapper (`dm-flakey` / `dm-error`) faulted block device and drives the
+# production custodian repair path (scrub + reconstruction) over it via
+# `cargo xtask disk-faults`, asserting a faulted chunk returns to full redundancy with
+# no read errors during repair.
+#
+# It is deliberately **not** part of the unprivileged, container-free `cargo xtask ci`
+# gate (ADR-0016): it needs root + `dmsetup` + loop devices, which `ci` must never
+# require. It runs nightly (and on demand), not on every PR — its value is post-merge
+# regression visibility on real block-layer behaviour, modelled on integration-nightly.yml.
+# Opt-in is explicit (`WYRD_TIER1=1`), matching the runner's gating.
+
+on:
+  schedule:
+    # 05:00 UTC daily (an hour after the Tier-2 container nightly).
+    - cron: "0 5 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier1-disk-faults-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  tier1:
+    runs-on: ubuntu-latest
+    # Bound the job so a hung setup fails fast rather than drifting toward the 6h
+    # GitHub default. Device setup + the scenario fit well under this.
+    timeout-minutes: 30
+    env:
+      CI: "true"
+      # Opt in to the Tier-1 runner (the runner defers unless this is set).
+      WYRD_TIER1: "1"
+    steps:
+      - uses: actions/checkout@v7
+
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # ubuntu-latest ships device-mapper userspace; load the targets and confirm the
+      # tools the harness needs are present before the run.
+      - name: Enable device-mapper targets
+        run: |
+          sudo modprobe dm-mod
+          sudo modprobe dm-flakey || true
+          sudo dmsetup version
+
+      # The harness drives privileged loop / device-mapper / mount syscalls, so it runs
+      # under sudo. `--preserve-env` keeps WYRD_TIER1 (and the cargo/rustup env) so the
+      # runner sees the opt-in and the toolchain.
+      - name: cargo xtask disk-faults (dm-flakey / dm-error)
+        run: sudo --preserve-env env "PATH=$PATH" cargo xtask disk-faults
+
+      - name: Upload campaign report
+        if: always()
+        uses: actions/upload-artifact@v7
+        with:
+          name: tier1-campaign-report
+          path: target/tier1-disk-faults/campaign-report.txt
+          if-no-files-found: ignore
+          retention-days: 14
diff --git a/crates/custodian/tests/tier1_disk_faults.rs b/crates/custodian/tests/tier1_disk_faults.rs
new file mode 100644
index 0000000..b991cbe
--- /dev/null
+++ b/crates/custodian/tests/tier1_disk_faults.rs
@@ -0,0 +1,449 @@
+//! Tier-1 **disk-fault scenario** (M3.9, issue #195) — the real-block-layer complement
+//! to the Tier-0 DST custodian campaign (`crates/dst/tests/custodian.rs`). Born at
+//! Tier-1 per proposal 0005 §"DST and tests" → Tier-1 disk-fault injection
+//! (`0005:405-408`) and the `xtask` touch-point `0005:437`.
+//!
+//! Where Tier-0 *models* bit rot / fragment loss in memory under madsim, this scenario
+//! drives the **production** custodian repair path —
+//! [`reconcile_step`] → [`scrub::reconcile`] / [`reconstruction::reconcile`] — over
+//! **real** [`FsChunkStore`] D servers, one of which is rooted on a device-mapper
+//! (`dm-flakey` / `dm-error`) faulted block device. It asserts the Tier-1 success
+//! criterion (`0005:381-384`): a chunk whose fragment is lost to a real block-layer
+//! fault is driven **back to full redundancy** and the object **reads without error
+//! throughout the repair** (degraded reads succeed off the `k` survivors).
+//!
+//! It is **gated** exactly like the Tier-2 container scenario
+//! (`crates/chunkstore-grpc/tests/tier2_integration.rs`): `#[ignore]`d so the default
+//! `cargo test` (and the container-free `cargo xtask ci`) only **compiles and
+//! type-checks** it — proving the harness is real, API-bound Rust against the production
+//! `FsChunkStore` / `reconcile_step` / `scrub` / `reconstruction` surface, not an
+//! env-var shell string. Its body needs root + `dmsetup`, so it runs only under the
+//! privileged off-Check job `cargo xtask disk-faults`, which stands up the faulted
+//! device, exports the roots + the dm error-table below, and reads back the campaign
+//! report this writes.
+
+use std::path::{Path, PathBuf};
+use std::process::Command;
+use std::sync::Arc;
+
+use async_trait::async_trait;
+use bytes::Bytes;
+use wyrd_chunkstore_fs::FsChunkStore;
+use wyrd_coordination_mem::MemCoordination;
+use wyrd_core::metadata::{self, EcScheme, InodeId, InodeRecord};
+use wyrd_core::placement::Topology;
+use wyrd_core::read::read_object;
+use wyrd_core::repair;
+use wyrd_core::write::write_new_object_placed;
+use wyrd_custodian::{
+    reconcile_step, Custodian, FencedZone, Reconciled, ReconstructionContext, ScrubContext,
+};
+use wyrd_traits::{
+    ChunkId, ChunkStore, CommitOutcome, DServerId, FragmentId, Health, MetadataStore,
+    PlacementChunkStore, Result, WriteBatch,
+};
+
+// Env contract with `xtask disk-faults` (`crate::disk_faults::run_scenario`).
+const VICTIM_ROOT: &str = "WYRD_TIER1_VICTIM_ROOT";
+const HEALTHY_ROOT: &str = "WYRD_TIER1_HEALTHY_ROOT";
+const DM_NAME: &str = "WYRD_TIER1_DM_NAME";
+const DM_ERROR_TABLE: &str = "WYRD_TIER1_DM_ERROR_TABLE";
+const REPORT: &str = "WYRD_TIER1_REPORT";
+
+// RS(2,1): 2 data + 1 parity = 3 fragments on servers 0,1,2 across domains A,B,C; server
+// 3 (domain D) is the healthy spare a rebuild flips onto — the smallest genuinely
+// erasure-coded scheme that survives one loss, so a read is always satisfiable from the
+// `k=2` survivors throughout the single-server fault (mirrors the Tier-0 campaign).
+const K: u8 = 2;
+const M: u8 = 1;
+const N: usize = (K + M) as usize;
+const ROOT: InodeId = 0;
+const INODE: InodeId = 1;
+const CHUNK: ChunkId = 0xC0FFEE;
+/// Server 0 holds fragment index 0; its `FsChunkStore` is rooted on the faulted device.
+const VICTIM: DServerId = 0;
+/// The healthy spare a rebuilt fragment is re-placed onto (domain D).
+const SPARE: DServerId = 3;
+
+// ---- a placement-aware fleet of real `FsChunkStore` D servers ----
+
+/// A [`PlacementChunkStore`] over several real [`FsChunkStore`]s, routing each fragment
+/// to the D server its placement record names — the same shape the Tier-0 `Fleet` takes,
+/// but backed by on-disk stores so the read path and the repair traverse real files (one
+/// of them on the faulted device).
+struct FsFleet {
+    servers: Vec<(DServerId, Arc<FsChunkStore>)>,
+}
+
+impl FsFleet {
+    fn store(&self, dserver: DServerId) -> Option<&Arc<FsChunkStore>> {
+        self.servers
+            .iter()
+            .find(|(id, _)| *id == dserver)
+            .map(|(_, s)| s)
+    }
+}
+
+#[async_trait]
+impl ChunkStore for FsFleet {
+    async fn put_fragment(&self, id: FragmentId, fragment: Bytes) -> Result<()> {
+        // Fan-out placement: fragment index `i` lands on D server `i` (placement [0,1,2]).
+        if let Some(store) = self.store(DServerId::from(id.index)) {
+            store.put_fragment(id, fragment).await?;
+        }
+        Ok(())
+    }
+
+    async fn get_fragment(&self, id: FragmentId) -> Result<Option<Bytes>> {
+        for (_, store) in &self.servers {
+            if let Some(bytes) = store.get_fragment(id).await? {
+                return Ok(Some(bytes));
+            }
+        }
+        Ok(None)
+    }
+
+    async fn list_fragments(&self) -> Result<Vec<FragmentId>> {
+        let mut all = Vec::new();
+        for (_, store) in &self.servers {
+            all.extend(store.list_fragments().await?);
+        }
+        Ok(all)
+    }
+
+    async fn delete_fragment(&self, id: FragmentId) -> Result<()> {
+        for (_, store) in &self.servers {
+            store.delete_fragment(id).await?;
+        }
+        Ok(())
+    }
+
+    async fn health(&self) -> Result<Health> {
+        Ok(Health::Healthy)
+    }
+}
+
+#[async_trait]
+impl PlacementChunkStore for FsFleet {
+    async fn get_fragment_at(&self, dserver: DServerId, id: FragmentId) -> Result<Option<Bytes>> {
+        match self.store(dserver) {
+            Some(store) => store.get_fragment(id).await,
+            None => Ok(None),
+        }
+    }
+
+    async fn put_fragment_at(
+        &self,
+        dserver: DServerId,
+        id: FragmentId,
+        fragment: Bytes,
+    ) -> Result<()> {
+        if let Some(store) = self.store(dserver) {
+            store.put_fragment(id, fragment).await?;
+        }
+        Ok(())
+    }
+}
+
+// ---- in-memory metadata store (the loops are proven over the trait seam) ----
+
+#[derive(Default)]
+struct MemMeta {
+    kv: std::sync::Mutex<std::collections::HashMap<Vec<u8>, Bytes>>,
+}
+
+#[async_trait]
+impl MetadataStore for MemMeta {
+    async fn get(&self, key: &[u8]) -> Result<Option<Bytes>> {
+        Ok(self.kv.lock().unwrap().get(key).cloned())
+    }
+
+    async fn scan(&self, prefix: &[u8]) -> Result<Vec<(Vec<u8>, Bytes)>> {
+        Ok(self
+            .kv
+            .lock()
+            .unwrap()
+            .iter()
+            .filter(|(k, _)| k.starts_with(prefix))
+            .map(|(k, v)| (k.clone(), v.clone()))
+            .collect())
+    }
+
+    async fn commit(&self, batch: WriteBatch) -> Result<CommitOutcome> {
+        let mut kv = self.kv.lock().unwrap();
+        for pre in &batch.preconditions {
+            if kv.get(&pre.key).cloned() != pre.expected {
+                return Ok(CommitOutcome::Conflict);
+            }
+        }
+        for (k, v) in batch.puts {
+            kv.insert(k, v);
+        }
+        for k in batch.deletes {
+            kv.remove(&k);
+        }
+        Ok(CommitOutcome::Committed)
+    }
+}
+
+// ---- helpers ----
+
+fn four_domains() -> Topology {
+    let mut t = Topology::default();
+    t.register(0, "A")
+        .register(1, "B")
+        .register(2, "C")
+        .register(3, "D");
+    t
+}
+
+/// The healthy reconstruction view after the victim is faulted: every server except the
+/// victim, each under its domain — so the rebuilt fragment lands on the free domain D
+/// (the spare, server 3), distinct from the survivors (`0005:382-383`).
+fn healthy_view(
+    servers: &[(DServerId, Arc<FsChunkStore>)],
+) -> (Topology, Vec<(DServerId, &dyn ChunkStore)>) {
+    let mut topo = Topology::default();
+    let mut fleet: Vec<(DServerId, &dyn ChunkStore)> = Vec::new();
+    for (id, store) in servers {
+        if *id == VICTIM {
+            continue;
+        }
+        topo.register(*id, ["A", "B", "C", "D"][*id as usize]);
+        fleet.push((*id, store.as_ref() as &dyn ChunkStore));
+    }
+    (topo, fleet)
+}
+
+async fn read_inode(meta: &MemMeta) -> InodeRecord {
+    let bytes = meta
+        .get(&metadata::inode_key(INODE))
+        .await
+        .unwrap()
+        .expect("inode present");
+    metadata::decode(&bytes).unwrap()
+}
+
+/// Reload the dm device named by `DM_NAME` to the error/flakey table `xtask` exported —
+/// the live block-layer fault injection. The device was created with a healthy *linear*
+/// table so the fragments could be written; this flips it to a faulting target so the
+/// victim D server's reads now error at the block layer. `suspend` → `load` → `resume`
+/// is the dmsetup atomic table swap.
+fn inject_disk_fault() {
+    let name = std::env::var(DM_NAME).expect("WYRD_TIER1_DM_NAME set by xtask");
+    let table = std::env::var(DM_ERROR_TABLE).expect("WYRD_TIER1_DM_ERROR_TABLE set by xtask");
+    run_dmsetup(&["suspend", &name]);
+    run_dmsetup(&["load", &name, "--table", &table]);
+    run_dmsetup(&["resume", &name]);
+    // Drop the page cache so subsequent reads actually hit the now-faulted device rather
+    // than being served from cached pages (best-effort; the privileged job runs as root).
+    let _ = std::fs::write("/proc/sys/vm/drop_caches", b"3");
+}
+
+fn run_dmsetup(args: &[&str]) {
+    let status = Command::new("dmsetup")
+        .args(args)
+        .status()
+        .unwrap_or_else(|e| panic!("failed to spawn dmsetup {args:?}: {e}"));
+    assert!(status.success(), "dmsetup {args:?} failed with {status}");
+}
+
+/// Open a fresh `FsChunkStore` rooted at `base/<subdir>`, so each D server owns a
+/// distinct directory (the victim's under the faulted mount).
+fn open_store(base: &Path, subdir: &str) -> Arc<FsChunkStore> {
+    let root = base.join(subdir);
+    Arc::new(FsChunkStore::open(root).expect("open FsChunkStore"))
+}
+
+fn write_report(total: u64, full: u64, read_errors: u64) {
+    if let Ok(path) = std::env::var(REPORT) {
+        let body = format!(
+            "chunks_total={total}\nchunks_full_redundancy={full}\nread_errors_during_repair={read_errors}\n"
+        );
+        std::fs::write(PathBuf::from(path), body).expect("write campaign report");
+    }
+}
+
+/// Read the object, counting it as a read error if the read fails (the "no read errors
+/// during repair" assertion is built on this count).
+async fn read_or_count_error(
+    meta: &MemMeta,
+    fleet: &FsFleet,
+    read_errors: &mut u64,
+) -> Option<Vec<u8>> {
+    match read_object(meta, fleet, INODE).await {
+        Ok(bytes) => bytes,
+        Err(_) => {
+            *read_errors += 1;
+            None
+        }
+    }
+}
+
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+#[ignore = "Tier-1: needs root + device-mapper — run via cargo xtask disk-faults"]
+async fn faulted_chunk_repairs_to_full_redundancy_without_read_errors() {
+    let (Ok(victim_root), Ok(healthy_root)) =
+        (std::env::var(VICTIM_ROOT), std::env::var(HEALTHY_ROOT))
+    else {
+        eprintln!(
+            "tier1_disk_faults: {VICTIM_ROOT}/{HEALTHY_ROOT} unset — skipping. \
+             Run `cargo xtask disk-faults` (root + device-mapper) to drive it."
+        );
+        return;
+    };
+    let victim_base = PathBuf::from(victim_root);
+    let healthy_base = PathBuf::from(healthy_root);
+
+    // D server 0 (the victim) is rooted on the faulted mount; the rest — including the
+    // spare a rebuild flips onto — are on the healthy scratch.
+    let servers: Vec<(DServerId, Arc<FsChunkStore>)> = vec![
+        (0, open_store(&victim_base, "d0")),
+        (1, open_store(&healthy_base, "d1")),
+        (2, open_store(&healthy_base, "d2")),
+        (SPARE, open_store(&healthy_base, "d3")),
+    ];
+    let fleet = FsFleet {
+        servers: servers.clone(),
+    };
+    let meta = MemMeta::default();
+
+    // WRITE an RS(2,1) object across distinct domains (servers 0,1,2) over the real
+    // on-disk stores while the victim's device is still healthy (linear).
+    let data = b"reconstruct this erasure-coded chunk over a real faulted disk".to_vec();
+    let topo = four_domains();
+    let outcome = write_new_object_placed(
+        &meta,
+        &fleet,
+        ROOT,
+        "obj",
+        INODE,
+        &data,
+        data.len(),
+        EcScheme::ReedSolomon { k: K, m: M },
+        &topo,
+        0,
+        1_000,
+        || CHUNK,
+    )
+    .await
+    .expect("write the object");
+    assert_eq!(outcome, CommitOutcome::Committed);
+    assert_eq!(
+        read_inode(&meta).await.chunk_map[0].placement,
+        vec![0, 1, 2],
+        "RS(2,1) placed across distinct domains A,B,C (servers 0,1,2)"
+    );
+
+    let mut read_errors = 0u64;
+
+    // INJECT the real block-layer fault: the victim's device starts erroring all I/O.
+    inject_disk_fault();
+
+    // A health/loss finding enqueues the chunk on the shared repair queue.
+    repair::enqueue_repair(&meta, CHUNK, "health")
+        .await
+        .unwrap();
+
+    // READ during repair: the victim's fragment now errors at the block layer, but the
+    // read path reads around it off the k=2 survivors — it must NOT error.
+    assert_eq!(
+        read_or_count_error(&meta, &fleet, &mut read_errors).await,
+        Some(data.clone()),
+        "object reads correctly while a real disk fault makes the victim fragment unreadable"
+    );
+
+    // RECONSTRUCT through the real fenced control point over the healthy fleet view: the
+    // unreadable fragment is rebuilt from the survivors and re-placed onto the spare.
+    let (recon_topo, healthy) = healthy_view(&servers);
+    let recon_ctx = ReconstructionContext {
+        meta: &meta,
+        fleet: &healthy,
+        topology: &recon_topo,
+    };
+    let coord = MemCoordination::new();
+    let leader = Custodian::elect(&coord, "zone-tier1").await.unwrap();
+    let mut zone = FencedZone::new();
+    zone.install(leader.leadership());
+
+    // SCRUB over the healthy view too (its referenced fragments verify clean) — the same
+    // production loop the Tier-0 campaign drives, exercised here over real on-disk stores.
+    let scrub_ctx = ScrubContext {
+        meta: &meta,
+        fleet: &healthy,
+    };
+    reconcile_step(&zone, &leader, None, Some(&scrub_ctx), None, None, 100)
+        .await
+        .expect("scrub pass over the healthy survivors");
+
+    let repaired = reconcile_step(&zone, &leader, None, None, Some(&recon_ctx), None, 200)
+        .await
+        .expect("reconstruction pass");
+    assert_eq!(
+        repaired,
+        Reconciled::Changed,
+        "the faulted chunk was reconstructed"
+    );
+
+    // The obligation is drained, exactly one version-conditional commit landed, and the
+    // chunk no longer references the faulted victim server.
+    assert!(
+        repair::queued_repairs(&meta).await.unwrap().is_empty(),
+        "the repair obligation is drained by the reconstruction commit"
+    );
+    let record = read_inode(&meta).await;
+    assert_eq!(record.version, 2, "exactly one version-conditional commit");
+    assert!(
+        !record.chunk_map[0].placement.contains(&VICTIM),
+        "the faulted server no longer holds a referenced fragment"
+    );
+
+    // FULL REDUNDANCY: every placed fragment is present, verifies its checksum, and the N
+    // fragments occupy N distinct failure domains — read from the healthy stores.
+    let placement = &record.chunk_map[0].placement;
+    assert_eq!(placement.len(), N, "n fragments placed");
+    let mut domains = std::collections::HashSet::new();
+    let mut full_redundancy = true;
+    for (index, &server) in placement.iter().enumerate() {
+        let store = servers.iter().find(|(id, _)| *id == server).map(|(_, s)| s);
+        let intact = match store {
+            Some(store) => match store
+                .get_fragment(FragmentId {
+                    chunk: CHUNK,
+                    index: index as u16,
+                })
+                .await
+            {
+                Ok(Some(bytes)) => repair::fragment_intact(&bytes, CHUNK),
+                _ => false,
+            },
+            None => false,
+        };
+        full_redundancy &= intact;
+        domains.insert(["A", "B", "C", "D"][server as usize]);
+    }
+    assert!(
+        full_redundancy,
+        "every placed fragment verifies after repair"
+    );
+    assert_eq!(
+        domains.len(),
+        N,
+        "n fragments on n distinct failure domains"
+    );
+
+    // The object still reads byte-identical after repair, off the now-full-redundancy set.
+    assert_eq!(
+        read_or_count_error(&meta, &fleet, &mut read_errors).await,
+        Some(data),
+        "object reads byte-identical after repair (full redundancy, atomic flip)"
+    );
+
+    assert_eq!(
+        read_errors, 0,
+        "no object read errored during the repair window"
+    );
+
+    // Report the campaign outcome for `xtask disk-faults`'s verdict.
+    write_report(1, u64::from(full_redundancy), read_errors);
+}
diff --git a/xtask/src/disk_faults.rs b/xtask/src/disk_faults.rs
new file mode 100644
index 0000000..46c75c4
--- /dev/null
+++ b/xtask/src/disk_faults.rs
@@ -0,0 +1,572 @@
+//! **Tier-1 disk-fault harness** — the in-repo orchestration for the M3 verification
+//! campaign's Tier-1 disk-fault leg (proposal 0005 §"DST and tests", `0005:405-408`;
+//! the `xtask` touch-point `0005:437`). This is the real harness #146 deferred: it
+//! replaces `faults.rs`'s old `WYRD_TIER1_DISK_CMD` external-command shell-out — an
+//! env var that pointed at a command defined nowhere in the repo — with code that
+//! actually stands up a device-mapper (`dm-flakey` / `dm-error`) faulted block device
+//! and drives the **production** custodian repair path
+//! (`crates/custodian/tests/tier1_disk_faults.rs`, the `#[ignore]`d scenario) over it.
+//!
+//! Posture (ADR-0016, INTEGRATION §3): the *privileged* run ([`run`]) needs root +
+//! `dmsetup`, so it is **never** part of the unprivileged container-free `cargo xtask
+//! ci` and runs only in the dedicated off-Check Tier-1 CI job (opt in `WYRD_TIER1=1`).
+//! What IS exercised at Check is this module's **host-independent** logic — the
+//! device-mapper table planning ([`DmTablePlan`]), the fault-scenario step plan
+//! ([`setup_steps`] / [`teardown_steps`]), and the post-repair redundancy /
+//! no-read-error verdict ([`CampaignReport`] / [`assert_campaign_passed`]) — which is
+//! unit-tested below (and so runs inside `cargo xtask ci`'s `cargo test`). That
+//! coverage is the born-at-tier guard: stub any of these helpers out and the unit
+//! tests go red, so the harness can never silently rot back into inert dispatch.
+
+use std::process::Command;
+
+/// The size of the backing block device the harness stands up, in 512-byte sectors —
+/// 64 MiB, comfortably enough for an ext4 filesystem plus the scenario's fragments.
+pub(crate) const DEVICE_SECTORS: u64 = 64 * 1024 * 1024 / 512;
+
+/// dm-flakey alternates between a healthy ("up") and an erroring ("down") window. The
+/// harness writes during setup over a *linear* table, then reloads to the fault table,
+/// so for the flakey variant we want it erroring as soon as it is loaded: a zero-length
+/// up window with a non-zero down window (`0005:405-407`).
+const FLAKEY_UP_SECS: u32 = 0;
+const FLAKEY_DOWN_SECS: u32 = 60;
+
+/// Which block-layer fault to inject after the data is written. Both are real
+/// device-mapper targets (`0005:405-408`): `dm-error` fails *all* I/O to the mapped
+/// range (a dead disk / dead sector), `dm-flakey` makes the device flap between healthy
+/// and erroring (transient block-layer misbehaviour).
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub(crate) enum DiskFaultKind {
+    /// `dm-error`: every read/write to the device fails.
+    Error,
+    /// `dm-flakey`: the device alternates up/down, erroring during the down window.
+    Flakey,
+}
+
+impl DiskFaultKind {
+    /// Resolve the fault kind from the raw `WYRD_TIER1_FAULT` value. `"flakey"` selects
+    /// [`DiskFaultKind::Flakey`]; **any** other value — unset, `"error"`, or
+    /// unrecognised — is [`DiskFaultKind::Error`], the stricter (always-erroring)
+    /// default, so a typo never silently weakens the injected fault. Pure (input ->
+    /// output) so it is unit-tested without an environment.
+    pub(crate) fn from_env(raw: Option<&str>) -> Self {
+        match raw.map(str::trim) {
+            Some("flakey") => DiskFaultKind::Flakey,
+            _ => DiskFaultKind::Error,
+        }
+    }
+}
+
+/// A device-mapper target — the part of a dm table line after `<start> <length>`.
+#[derive(Debug, Clone, PartialEq, Eq)]
+enum DmTarget {
+    /// `linear <backing> <offset>` — pass-through to the backing device (healthy).
+    Linear { backing: String, offset: u64 },
+    /// `error` — fail all I/O.
+    Error,
+    /// `flakey <backing> <offset> <up> <down>` — flap healthy/erroring.
+    Flakey {
+        backing: String,
+        offset: u64,
+        up_interval: u32,
+        down_interval: u32,
+    },
+}
+
+/// A planned device-mapper table over a backing device: the single-line table string
+/// `dmsetup create` / `dmsetup load` consumes (`man dmsetup`, kernel
+/// `Documentation/admin-guide/device-mapper/`). Pure (inputs -> table string) so the
+/// table construction — the load-bearing detail of the harness's dm setup — is
+/// unit-tested without `dmsetup` or root.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub(crate) struct DmTablePlan {
+    sectors: u64,
+    target: DmTarget,
+}
+
+impl DmTablePlan {
+    /// A healthy linear mapping of `sectors` sectors onto `backing` at offset 0 — what
+    /// the device is created with so the scenario can write its fragments before the
+    /// fault is injected.
+    pub(crate) fn linear(backing: &str, sectors: u64) -> Self {
+        Self {
+            sectors,
+            target: DmTarget::Linear {
+                backing: backing.to_string(),
+                offset: 0,
+            },
+        }
+    }
+
+    /// The fault mapping the device is *reloaded* to after the write, per `kind`. For
+    /// [`DiskFaultKind::Error`] the backing device is irrelevant (all I/O fails); for
+    /// [`DiskFaultKind::Flakey`] it flaps the backing mapping up/down.
+    pub(crate) fn fault(kind: DiskFaultKind, backing: &str, sectors: u64) -> Self {
+        let target = match kind {
+            DiskFaultKind::Error => DmTarget::Error,
+            DiskFaultKind::Flakey => DmTarget::Flakey {
+                backing: backing.to_string(),
+                offset: 0,
+                up_interval: FLAKEY_UP_SECS,
+                down_interval: FLAKEY_DOWN_SECS,
+            },
+        };
+        Self { sectors, target }
+    }
+
+    /// Render the dm table line. The logical device always starts at sector 0 and spans
+    /// the whole device.
+    pub(crate) fn table(&self) -> String {
+        match &self.target {
+            DmTarget::Linear { backing, offset } => {
+                format!("0 {} linear {} {}", self.sectors, backing, offset)
+            }
+            DmTarget::Error => format!("0 {} error", self.sectors),
+            DmTarget::Flakey {
+                backing,
+                offset,
+                up_interval,
+                down_interval,
+            } => format!(
+                "0 {} flakey {} {} {} {}",
+                self.sectors, backing, offset, up_interval, down_interval
+            ),
+        }
+    }
+}
+
+/// One step of the host-side fault-scenario orchestration: a program plus its args.
+/// Kept as data (not a side effect) so the planned command sequence is unit-testable
+/// without spawning `dmsetup` / `mkfs` / `mount`.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub(crate) struct HarnessStep {
+    pub(crate) program: String,
+    pub(crate) args: Vec<String>,
+}
+
+impl HarnessStep {
+    fn new(program: &str, args: &[&str]) -> Self {
+        Self {
+            program: program.to_string(),
+            args: args.iter().map(|a| a.to_string()).collect(),
+        }
+    }
+}
+
+/// The full mapper-device path for a dm device named `dm_name`.
+fn mapper_path(dm_name: &str) -> String {
+    format!("/dev/mapper/{dm_name}")
+}
+
+/// Plan the steps that bring the faulted device up over an already-attached loop
+/// device: create the dm device with the healthy `linear_table`, lay an ext4
+/// filesystem on it, and mount it at `mount_dir`. Pure so the sequence is asserted in
+/// a unit test; [`run`] executes it. (Loop attach is done first by [`run`] because the
+/// loop path is only known at runtime.)
+pub(crate) fn setup_steps(dm_name: &str, mount_dir: &str, linear_table: &str) -> Vec<HarnessStep> {
+    let mapper = mapper_path(dm_name);
+    vec![
+        HarnessStep::new("dmsetup", &["create", dm_name, "--table", linear_table]),
+        HarnessStep::new("mkfs.ext4", &["-q", "-F", &mapper]),
+        HarnessStep::new("mount", &[&mapper, mount_dir]),
+    ]
+}
+
+/// Plan the teardown steps, in reverse dependency order: unmount, remove the dm device,
+/// detach the loop device. Run best-effort so a half-built run still cleans up.
+pub(crate) fn teardown_steps(dm_name: &str, loop_dev: &str, mount_dir: &str) -> Vec<HarnessStep> {
+    vec![
+        HarnessStep::new("umount", &[mount_dir]),
+        HarnessStep::new("dmsetup", &["remove", dm_name]),
+        HarnessStep::new("losetup", &["-d", loop_dev]),
+    ]
+}
+
+/// The campaign outcome the `#[ignore]`d scenario reports back after driving the
+/// production custodian path over the faulted device — the numbers the privileged run's
+/// verdict is computed from.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub(crate) struct CampaignReport {
+    /// Faulted chunks the scenario exercised.
+    pub(crate) chunks_total: u64,
+    /// Of those, chunks the production repair drove back to full redundancy.
+    pub(crate) chunks_full_redundancy: u64,
+    /// Object reads that errored *during* the repair window (must be zero — the Tier-1
+    /// success criterion is repair without a read fault, `0005:381-384`).
+    pub(crate) read_errors_during_repair: u64,
+}
+
+impl CampaignReport {
+    /// Parse the scenario's `key=value` report (one per line). Every field is required;
+    /// a missing or unparsable field is an error so a truncated / malformed report is
+    /// never read as a pass. Pure so the parse is unit-tested.
+    pub(crate) fn parse(text: &str) -> Result<Self, String> {
+        let mut chunks_total = None;
+        let mut chunks_full_redundancy = None;
+        let mut read_errors_during_repair = None;
+        for line in text.lines() {
+            let line = line.trim();
+            if line.is_empty() {
+                continue;
+            }
+            let (key, value) = line
+                .split_once('=')
+                .ok_or_else(|| format!("malformed report line (no `=`): {line:?}"))?;
+            let parsed = || -> Result<u64, String> {
+                value
+                    .trim()
+                    .parse::<u64>()
+                    .map_err(|e| format!("non-integer value for `{}`: {e}", key.trim()))
+            };
+            match key.trim() {
+                "chunks_total" => chunks_total = Some(parsed()?),
+                "chunks_full_redundancy" => chunks_full_redundancy = Some(parsed()?),
+                "read_errors_during_repair" => read_errors_during_repair = Some(parsed()?),
+                _ => {} // tolerate forward-compatible extra keys
+            }
+        }
+        Ok(Self {
+            chunks_total: chunks_total.ok_or("report missing `chunks_total`")?,
+            chunks_full_redundancy: chunks_full_redundancy
+                .ok_or("report missing `chunks_full_redundancy`")?,
+            read_errors_during_repair: read_errors_during_repair
+                .ok_or("report missing `read_errors_during_repair`")?,
+        })
+    }
+}
+
+/// The Tier-1 success criterion as a verdict over the scenario's report (`0005:381-384`,
+/// proposal 0005 §13.2): the campaign passes **iff** it exercised at least one faulted
+/// chunk, drove **every** faulted chunk back to full redundancy, and saw **no** read
+/// error during repair. Returns `Err(reason)` on any shortfall. Pure so the verdict is
+/// unit-tested — and so a stubbed-out verdict (always `Ok`) flips the unit tests red.
+pub(crate) fn assert_campaign_passed(report: &CampaignReport) -> Result<(), String> {
+    if report.chunks_total == 0 {
+        return Err("Tier-1 campaign exercised no faulted chunks — the harness did nothing".into());
+    }
+    if report.chunks_full_redundancy != report.chunks_total {
+        return Err(format!(
+            "Tier-1 campaign left {} of {} faulted chunks below full redundancy",
+            report.chunks_total - report.chunks_full_redundancy,
+            report.chunks_total
+        ));
+    }
+    if report.read_errors_during_repair != 0 {
+        return Err(format!(
+            "Tier-1 campaign saw {} read error(s) during repair (must be zero)",
+            report.read_errors_during_repair
+        ));
+    }
+    Ok(())
+}
+
+/// Run a planned [`HarnessStep`] sequence from the workspace root, echoing each. On the
+/// first failure returns an error naming the step.
+fn execute_steps(steps: &[HarnessStep]) -> Result<(), String> {
+    for step in steps {
+        let mut display = vec![step.program.as_str()];
+        display.extend(step.args.iter().map(String::as_str));
+        crate::print_step(&display);
+        let status = Command::new(&step.program)
+            .args(&step.args)
+            .current_dir(crate::workspace_root())
+            .status()
+            .map_err(|e| format!("failed to spawn `{}`: {e}", step.program))?;
+        if !status.success() {
+            return Err(format!("`{}` failed with {status}", display.join(" ")));
+        }
+    }
+    Ok(())
+}
+
+/// Run the teardown steps best-effort (each failure only warns) so a run never leaks a
+/// loop / dm device or a mount, even if one teardown step fails.
+fn teardown_best_effort(steps: &[HarnessStep]) {
+    for step in steps {
+        let mut display = vec![step.program.as_str()];
+        display.extend(step.args.iter().map(String::as_str));
+        crate::print_step(&display);
+        match Command::new(&step.program)
+            .args(&step.args)
+            .current_dir(crate::workspace_root())
+            .status()
+        {
+            Ok(status) if status.success() => {}
+            Ok(status) => eprintln!("warning: `{}` failed with {status}", display.join(" ")),
+            Err(e) => eprintln!("warning: failed to spawn `{}`: {e}", step.program),
+        }
+    }
+}
+
+/// Attach a loop device over `backing` and return its path (`losetup --find --show`).
+fn losetup_attach(backing: &str) -> Result<String, String> {
+    crate::print_step(&["losetup", "--find", "--show", backing]);
+    let out = Command::new("losetup")
+        .args(["--find", "--show", backing])
+        .current_dir(crate::workspace_root())
+        .output()
+        .map_err(|e| format!("failed to spawn losetup: {e}"))?;
+    if !out.status.success() {
+        return Err(format!(
+            "losetup --find --show failed: {}",
+            String::from_utf8_lossy(&out.stderr).trim()
+        ));
+    }
+    let dev = String::from_utf8_lossy(&out.stdout).trim().to_string();
+    if dev.is_empty() {
+        return Err("losetup --find --show returned no device path".into());
+    }
+    Ok(dev)
+}
+
+/// Run the (otherwise `#[ignore]`d) Tier-1 disk-fault scenario against the faulted
+/// device, then read back and assert its campaign report.
+fn run_scenario(
+    victim_root: &str,
+    healthy_root: &str,
+    dm_name: &str,
+    fault_table: &str,
+    report_path: &str,
+    sectors: u64,
+) -> Result<(), String> {
+    crate::print_step(&[
+        "cargo",
+        "test",
+        "-p",
+        "wyrd-custodian",
+        "--test",
+        "tier1_disk_faults",
+        "--",
+        "--ignored",
+    ]);
+    let status = Command::new("cargo")
+        .args([
+            "test",
+            "-p",
+            "wyrd-custodian",
+            "--test",
+            "tier1_disk_faults",
+            "--",
+            "--ignored",
+            "--nocapture",
+        ])
+        .current_dir(crate::workspace_root())
+        .env("WYRD_TIER1_VICTIM_ROOT", victim_root)
+        .env("WYRD_TIER1_HEALTHY_ROOT", healthy_root)
+        .env("WYRD_TIER1_DM_NAME", dm_name)
+        .env("WYRD_TIER1_DM_ERROR_TABLE", fault_table)
+        .env("WYRD_TIER1_DM_SECTORS", sectors.to_string())
+        .env("WYRD_TIER1_REPORT", report_path)
+        .status()
+        .map_err(|e| format!("failed to spawn cargo: {e}"))?;
+    if !status.success() {
+        return Err(format!("Tier-1 disk-fault scenario failed with {status}"));
+    }
+
+    let text = std::fs::read_to_string(report_path).map_err(|e| {
+        format!("Tier-1 scenario produced no campaign report at {report_path}: {e}")
+    })?;
+    let report = CampaignReport::parse(&text)?;
+    assert_campaign_passed(&report)?;
+    println!(
+        "\nxtask disk-faults: Tier-1 campaign passed \
+         ({} chunk(s) repaired to full redundancy, {} read errors during repair)",
+        report.chunks_full_redundancy, report.read_errors_during_repair
+    );
+    Ok(())
+}
+
+/// The privileged Tier-1 disk-fault run: stand up a loop-backed, device-mapper-faulted
+/// block device, drive the production custodian repair path over it via the
+/// `#[ignore]`d scenario, assert the campaign outcome, and tear the device down
+/// unconditionally. Called only from [`crate::faults::run_disk_faults`] once gating has
+/// confirmed the opt-in (`WYRD_TIER1=1`) and `dmsetup` are present; it is **never** part
+/// of `cargo xtask ci` (ADR-0016).
+pub(crate) fn run() -> Result<(), String> {
+    let scratch = crate::workspace_root()
+        .join("target")
+        .join("tier1-disk-faults");
+    let backing = scratch.join("backing.img");
+    let mount_dir = scratch.join("victim");
+    let healthy_dir = scratch.join("healthy");
+    let report_path = scratch.join("campaign-report.txt");
+    let dm_name = "wyrd-tier1";
+
+    std::fs::create_dir_all(&mount_dir).map_err(|e| format!("{}: {e}", mount_dir.display()))?;
+    std::fs::create_dir_all(&healthy_dir).map_err(|e| format!("{}: {e}", healthy_dir.display()))?;
+    let _ = std::fs::remove_file(&report_path);
+
+    // A sparse backing file sized to the device.
+    let file =
+        std::fs::File::create(&backing).map_err(|e| format!("{}: {e}", backing.display()))?;
+    file.set_len(DEVICE_SECTORS * 512)
+        .map_err(|e| format!("sizing {}: {e}", backing.display()))?;
+    drop(file);
+
+    let backing_str = backing.to_string_lossy().to_string();
+    let loop_dev = losetup_attach(&backing_str)?;
+
+    let mount_str = mount_dir.to_string_lossy().to_string();
+    let healthy_str = healthy_dir.to_string_lossy().to_string();
+    let report_str = report_path.to_string_lossy().to_string();
+
+    let linear = DmTablePlan::linear(&loop_dev, DEVICE_SECTORS).table();
+    let kind = DiskFaultKind::from_env(std::env::var("WYRD_TIER1_FAULT").ok().as_deref());
+    let fault_table = DmTablePlan::fault(kind, &loop_dev, DEVICE_SECTORS).table();
+
+    if let Err(e) = execute_steps(&setup_steps(dm_name, &mount_str, &linear)) {
+        teardown_best_effort(&teardown_steps(dm_name, &loop_dev, &mount_str));
+        return Err(e);
+    }
+
+    // Run the scenario, then ALWAYS tear the device down — even on a panic, so a loop /
+    // dm device is never leaked (mirrors `run_integration`'s panic-safe finalize).
+    crate::finalize_panic_safe(
+        || {
+            run_scenario(
+                &mount_str,
+                &healthy_str,
+                dm_name,
+                &fault_table,
+                &report_str,
+                DEVICE_SECTORS,
+            )
+        },
+        |result| {
+            teardown_best_effort(&teardown_steps(dm_name, &loop_dev, &mount_str));
+            result
+        },
+    )
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    // ---- dm-table planning (the load-bearing dm setup detail) ----
+
+    #[test]
+    fn linear_table_maps_the_whole_device_to_the_backing() {
+        let table = DmTablePlan::linear("/dev/loop7", DEVICE_SECTORS).table();
+        assert_eq!(table, format!("0 {DEVICE_SECTORS} linear /dev/loop7 0"));
+    }
+
+    #[test]
+    fn error_fault_table_fails_all_io() {
+        let table = DmTablePlan::fault(DiskFaultKind::Error, "/dev/loop7", DEVICE_SECTORS).table();
+        // dm-error needs no backing device — it fails every I/O to the range.
+        assert_eq!(table, format!("0 {DEVICE_SECTORS} error"));
+    }
+
+    #[test]
+    fn flakey_fault_table_flaps_the_backing_device() {
+        let table = DmTablePlan::fault(DiskFaultKind::Flakey, "/dev/loop7", DEVICE_SECTORS).table();
+        assert_eq!(
+            table,
+            format!("0 {DEVICE_SECTORS} flakey /dev/loop7 0 {FLAKEY_UP_SECS} {FLAKEY_DOWN_SECS}")
+        );
+    }
+
+    #[test]
+    fn fault_kind_defaults_to_error_and_recognises_flakey() {
+        assert_eq!(DiskFaultKind::from_env(None), DiskFaultKind::Error);
+        assert_eq!(DiskFaultKind::from_env(Some("error")), DiskFaultKind::Error);
+        assert_eq!(
+            DiskFaultKind::from_env(Some(" flakey ")),
+            DiskFaultKind::Flakey
+        );
+        // An unrecognised value never silently weakens the fault — it stays Error.
+        assert_eq!(
+            DiskFaultKind::from_env(Some("garbage")),
+            DiskFaultKind::Error
+        );
+    }
+
+    // ---- the fault-scenario step plan ----
+
+    #[test]
+    fn setup_steps_create_then_format_then_mount() {
+        let steps = setup_steps("wyrd-tier1", "/mnt/v", "0 100 linear /dev/loop7 0");
+        let programs: Vec<&str> = steps.iter().map(|s| s.program.as_str()).collect();
+        assert_eq!(programs, vec!["dmsetup", "mkfs.ext4", "mount"]);
+        // The dm device is created with the supplied healthy table...
+        assert_eq!(
+            steps[0].args,
+            vec![
+                "create",
+                "wyrd-tier1",
+                "--table",
+                "0 100 linear /dev/loop7 0"
+            ]
+        );
+        // ...the filesystem and the mount both target the mapper device.
+        assert!(steps[1].args.iter().any(|a| a == "/dev/mapper/wyrd-tier1"));
+        assert_eq!(steps[2].args, vec!["/dev/mapper/wyrd-tier1", "/mnt/v"]);
+    }
+
+    #[test]
+    fn teardown_steps_unmount_remove_detach_in_reverse_order() {
+        let steps = teardown_steps("wyrd-tier1", "/dev/loop7", "/mnt/v");
+        let programs: Vec<&str> = steps.iter().map(|s| s.program.as_str()).collect();
+        // Reverse of setup: unmount before removing the dm device before detaching loop.
+        assert_eq!(programs, vec!["umount", "dmsetup", "losetup"]);
+        assert_eq!(steps[0].args, vec!["/mnt/v"]);
+        assert_eq!(steps[1].args, vec!["remove", "wyrd-tier1"]);
+        assert_eq!(steps[2].args, vec!["-d", "/dev/loop7"]);
+    }
+
+    // ---- the post-repair redundancy / no-read-error verdict ----
+
+    fn report(total: u64, full: u64, read_errors: u64) -> CampaignReport {
+        CampaignReport {
+            chunks_total: total,
+            chunks_full_redundancy: full,
+            read_errors_during_repair: read_errors,
+        }
+    }
+
+    #[test]
+    fn campaign_passes_only_at_full_redundancy_with_no_read_errors() {
+        assert!(assert_campaign_passed(&report(3, 3, 0)).is_ok());
+    }
+
+    #[test]
+    fn campaign_fails_when_a_chunk_is_left_under_replicated() {
+        let err = assert_campaign_passed(&report(3, 2, 0)).unwrap_err();
+        assert!(err.contains("below full redundancy"), "{err}");
+    }
+
+    #[test]
+    fn campaign_fails_on_any_read_error_during_repair() {
+        let err = assert_campaign_passed(&report(3, 3, 1)).unwrap_err();
+        assert!(err.contains("read error"), "{err}");
+    }
+
+    #[test]
+    fn campaign_fails_when_nothing_was_exercised() {
+        // A harness that did nothing (0 chunks) must not be mistaken for a pass — this
+        // is the guard against the harness rotting back into inert dispatch.
+        let err = assert_campaign_passed(&report(0, 0, 0)).unwrap_err();
+        assert!(err.contains("no faulted chunks"), "{err}");
+    }
+
+    #[test]
+    fn report_parse_round_trips_a_well_formed_report() {
+        let text = "chunks_total=2\nchunks_full_redundancy=2\nread_errors_during_repair=0\n";
+        assert_eq!(CampaignReport::parse(text).unwrap(), report(2, 2, 0));
+    }
+
+    #[test]
+    fn report_parse_rejects_a_missing_field() {
+        let text = "chunks_total=2\nread_errors_during_repair=0\n";
+        let err = CampaignReport::parse(text).unwrap_err();
+        assert!(err.contains("chunks_full_redundancy"), "{err}");
+    }
+
+    #[test]
+    fn report_parse_rejects_a_non_integer_value() {
+        let text = "chunks_total=lots\nchunks_full_redundancy=2\nread_errors_during_repair=0\n";
+        let err = CampaignReport::parse(text).unwrap_err();
+        assert!(err.contains("non-integer"), "{err}");
+    }
+}
