+//! Unit tests for the Tier-1 Jepsen consistency harness orchestration helpers
+//! (`xtask::jepsen` — the Check-time flippable coverage, born at M3, issue #250,
+//! proposal 0005 §13.2, `0005:408`).
+//!
+//! **Why these tests exist.** The Tier-1 Jepsen harness is a "deferred" tier
+//! (ADR-0016): its real Clojure/Jepsen scenario (`jepsen/src/wyrd/jepsen.clj`)
+//! requires `lein` + a containerized Wyrd cluster and runs only in the privileged
+//! `tier1-jepsen.yml` CI job. "Deferred" means the *green run* is off-Check; it
+//! does NOT mean the harness is unbuilt. The deliverable must be **compiled and
+//! test-exercised at Check** — that is this file.
+//!
+//! These tests exercise the **host-independent** orchestration logic:
+//!
+//! - [`jepsen_harness_dir`] — the in-repo harness directory path, a pure function
+//!   of the workspace root, requiring no `lein` or live cluster.
+//!
+//! They run inside `cargo xtask ci`'s `cargo test --workspace` and go **RED** when
+//! the helper is removed or returns a wrong value — proving the seam is load-bearing,
+//! not resting red on non-existence (the "demonstrated red" the brief requires).
+//!
+//! **C4-verify note.** `run-verify.sh` classifies this file as an added test
+//! (`xtask/tests/*.rs` matches `*/tests/*.rs`) and targets it in the RED check:
+//! removing `xtask/src/lib.rs`'s `pub mod jepsen` + `xtask/src/jepsen.rs` makes
+//! this file fail to compile (`use xtask::jepsen::jepsen_harness_dir` has no lib
+//! to resolve against), so the RED check observes a non-zero exit and declares RED ✓.
+
+use xtask::jepsen::jepsen_harness_dir;
+
+// ─── Harness-dir path helper ──────────────────────────────────────────────────
+
+#[test]
+fn jepsen_harness_dir_lives_under_workspace_root() {
+    // The in-repo harness is at <workspace>/jepsen — not an env-var command path.
+    let root = std::path::Path::new("/workspace");
+    let dir = jepsen_harness_dir(root);
+    assert_eq!(
+        dir,
+        root.join("jepsen"),
+        "jepsen_harness_dir must return <workspace>/jepsen"
+    );
+}
+
+#[test]
+fn jepsen_harness_dir_uses_provided_workspace_root() {
+    // Different workspace roots → different paths, always ending with `jepsen`.
+    let cases = [
+        ("/home/ci/wyrd", "/home/ci/wyrd/jepsen"),
+        ("/opt/workspace", "/opt/workspace/jepsen"),
+        ("/", "/jepsen"),
+    ];
+    for (root, expected) in cases {
+        let dir = jepsen_harness_dir(std::path::Path::new(root));
+        assert_eq!(
+            dir,
+            std::path::PathBuf::from(expected),
+            "jepsen_harness_dir({root:?}) must be {expected:?}"
+        );
+    }
+}
+
+#[test]
+fn jepsen_harness_dir_never_consults_env_var() {
+    // Ensure WYRD_TIER1_JEPSEN_CMD is NOT used — the harness is in-repo, not env-supplied.
+    // Set the old env var to a sentinel value; the result must still be <root>/jepsen.
+    std::env::set_var(
+        "WYRD_TIER1_JEPSEN_CMD",
+        "/usr/local/bin/some-external-jepsen",
+    );
+    let dir = jepsen_harness_dir(std::path::Path::new("/workspace"));
+    // Must NOT be the env-var value.
+    assert_ne!(
+        dir,
+        std::path::PathBuf::from("/usr/local/bin/some-external-jepsen"),
+        "jepsen_harness_dir must NOT read WYRD_TIER1_JEPSEN_CMD; \
+         the harness is in-repo at <workspace>/jepsen"
+    );
+    // Must still be <workspace>/jepsen.
+    assert_eq!(
+        dir,
+        std::path::PathBuf::from("/workspace/jepsen"),
+        "jepsen_harness_dir must return <workspace>/jepsen regardless of env"
+    );
+    std::env::remove_var("WYRD_TIER1_JEPSEN_CMD");
+}
