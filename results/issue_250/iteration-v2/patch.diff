+++ b/jepsen/project.clj
@@ -0,0 +1,41 @@
+;; Tier-1 Jepsen consistency harness for Wyrd (proposal 0005 §13.2, issue #250).
+;;
+;; Drives the production custodian repair/reconstruction path against a
+;; containerized Wyrd cluster under partitions and crashes, asserting no stale
+;; or torn reads (ADR-0015) and that repair is commit-point-atomic (`0005:277`,
+;; `0005:385-389`).
+;;
+;; Prerequisites: JVM 11+, Leiningen (https://leiningen.org/).
+;;
+;; Run the Elle checker self-test only (no cluster required):
+;;   lein test
+;;
+;; Run the full Jepsen consistency test (requires a live Wyrd cluster):
+;;   export WYRD_JEPSEN_ENDPOINTS="http://127.0.0.1:<P1>,http://127.0.0.1:<P2>,..."
+;;   export WYRD_BIN=/path/to/wyrd          # default: "wyrd" on PATH
+;;   export WYRD_JEPSEN_META_DIR=/tmp/wyrd-jepsen-meta  # default
+;;   cargo xtask jepsen                     # via `cargo xtask jepsen` (WYRD_TIER1=1)
+;;   # or directly: lein run test
+
+(defproject wyrd-jepsen "0.1.0-SNAPSHOT"
+  :description "Tier-1 Jepsen consistency harness for Wyrd custodian repair path (issue #250)"
+  :url "https://github.com/getwyrd/wyrd"
+  :license {:name "Apache-2.0"
+            :url  "https://www.apache.org/licenses/LICENSE-2.0"}
