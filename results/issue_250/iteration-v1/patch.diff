@@ -0,0 +1,165 @@
+name: tier1-jepsen
+
+# Tier-1 Jepsen consistency harness (issue #250, proposal 0005 §13.2,
+# `0005:408`).  Drives the production custodian repair/reconstruction path
+# against a containerized Wyrd cluster under partitions and crashes, asserting
+# no stale or torn reads (ADR-0015) and that repair is commit-point-atomic
+# (`0005:277`, `0005:385-389`).
+#
+# Two-phase execution:
+#   1. Checker self-test (`lein test`) — verifies the Elle dependency is wired
+#      and catches a planted version-cycle anomaly; no live cluster needed.
+#   2. Full Jepsen consistency run (`cargo xtask jepsen` → `lein run test`) —
+#      drives the production repair path against a live D-server cluster,
+#      applies partition + crash nemeses, and asserts strict serializability.
+#
+# Toolchain footprint (pre-declared at plan, INTEGRATION §4 / brief §"Planning
+# artifact"):  JVM + Clojure + Leiningen are non-Cargo dependencies and are not
+# gated by `deny.toml`.  This is the accepted Option-A tradeoff (a genuine
+# Jepsen / Elle artifact over a Check-verifiable in-repo Rust check).
+#
+# Gating policy (ADR-0016):  NOT a required merge-gate status check.  Runs
+# nightly at 06:00 UTC (a non-colliding slot — 03:00/04:00/05:00 UTC are taken
+# by the existing staggered nightly jobs to avoid runner contention) and on
+# demand.  `cargo xtask ci` stays unprivileged and container-free; this job
+# runs after merge to catch regressions in the Tier-1 Jepsen path.
+#
+# Opt-in: `WYRD_TIER1=1` instructs `cargo xtask jepsen` to invoke the in-repo
+# harness (`lein run test` in `jepsen/`).  Without it the xtask exits cleanly
+# (deferred tier).
+
+on:
+  schedule:
+    # 06:00 UTC daily (non-colliding: 03:00=tier1-disk-faults, 04:00=integration-nightly
+    # and mutants, 05:00=tier2-kill-reconstruct).
+    - cron: "0 6 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier1-jepsen-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  tier1-jepsen:
+    runs-on: ubuntu-latest
+    # Cluster bring-up + warm-up (30 s) + fault phase (120 s) + quiesce (30 s)
+    # + lein dep download on first run.  Generous bound; a hung run fails fast
+    # rather than drifting toward the 6 h GitHub default.
+    timeout-minutes: 60
+    env:
+      CI: "true"
+      # Opt in to the Tier-1 Jepsen harness.
+      WYRD_TIER1: "1"
+      # Endpoint list for the Jepsen client (matches the compose scale below).
+      WYRD_JEPSEN_ENDPOINTS: >-
+        http://127.0.0.1:50051,
+        http://127.0.0.1:50052,
+        http://127.0.0.1:50053,
+        http://127.0.0.1:50054,
+        http://127.0.0.1:50055
+
+    steps:
+      - uses: actions/checkout@v7
+
+      # ── Rust toolchain ────────────────────────────────────────────────────────
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # Build the `wyrd` binary so the Jepsen client can invoke `wyrd put`/`wyrd ls`.
+      - name: Build wyrd binary
+        run: cargo build --release --locked --bin wyrd
+
+      - name: Export wyrd binary path
+        run: echo "WYRD_BIN=${{ github.workspace }}/target/release/wyrd" >> "$GITHUB_ENV"
+
+      # ── Java + Leiningen ──────────────────────────────────────────────────────
+      - name: Set up Java 21 (Temurin)
+        uses: actions/setup-java@v4
+        with:
+          distribution: temurin
+          java-version: "21"
+
+      - name: Install Leiningen
+        run: |
+          curl -sLo /usr/local/bin/lein \
+            https://raw.githubusercontent.com/technomancy/leiningen/stable/bin/lein
+          chmod +x /usr/local/bin/lein
+          lein version
+
+      - name: Cache Leiningen dependencies
+        uses: actions/cache@v4
+        with:
+          path: ~/.m2/repository
+          key: lein-${{ hashFiles('jepsen/project.clj') }}
+          restore-keys: lein-
+
+      # ── Elle checker self-test (no cluster needed) ────────────────────────────
+      # Runs first: a fast smoke-check that the Elle dependency is wired and the
+      # checker catches the planted version-cycle anomaly.  Fails fast without
+      # standing up a cluster if the harness code is broken.
+      - name: Elle checker self-test (lein test)
+        run: lein test
+        working-directory: jepsen
+
+      # ── Live Wyrd cluster (D servers) ─────────────────────────────────────────
+      - name: Docker info
+        run: docker info
+
+      - name: Start Wyrd D-server cluster (5 nodes, fixed ports)
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f crates/chunkstore-grpc/tests/docker-compose.yml \
+            up -d --build --scale dserver=5
+
+      - name: Wait for D servers to be ready
+        run: |
+          for port in 50051 50052 50053 50054 50055; do
+            for i in $(seq 1 30); do
+              nc -z 127.0.0.1 "$port" 2>/dev/null && echo "port $port ready" && break
+              sleep 2
+            done
+          done
+
+      # ── Full Jepsen consistency run ───────────────────────────────────────────
+      # cargo xtask jepsen (WYRD_TIER1=1) → faults::run_jepsen() → run_jepsen_harness()
+      # → `lein run test` in jepsen/ — the full Jepsen consistency run with
+      # partition + crash nemeses and Elle strict-serializability checker.
+      - name: cargo xtask jepsen (full Jepsen run)
+        run: cargo xtask jepsen
+
+      # ── Diagnostics on failure ────────────────────────────────────────────────
+      - name: Capture cluster logs
+        if: failure()
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f crates/chunkstore-grpc/tests/docker-compose.yml \
+            logs --no-color --timestamps \
+            > target/jepsen-cluster.log 2>&1 || true
+
+      - name: Upload Jepsen results
+        if: always()
+        uses: actions/upload-artifact@v7
+        with:
+          name: tier1-jepsen-results
+          path: |
+            jepsen/store/
+            target/jepsen-cluster.log
+          if-no-files-found: ignore
+          retention-days: 14
+
+      # ── Teardown ──────────────────────────────────────────────────────────────
+      - name: Tear down cluster
+        if: always()
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f crates/chunkstore-grpc/tests/docker-compose.yml \
+            down -v --remove-orphans || true
