+(ns wyrd.checker-test
+  "Elle checker self-test (proposal 0005 §13.2, issue #250).
+
+   Feeds Elle's list-append checker a **known-anomalous** history and asserts it
+   is flagged.  This test:
+   - runs via `lein test` with NO live cluster (no Wyrd binary, no D servers)
+   - proves the Elle dependency is wired and the checker is callable
+   - demonstrates a concrete anomaly class (version cycle) that Wyrd's custodian
+     repair path must not produce (ADR-0015)
+
+   The planted anomaly mirrors a torn/stale read after repair: two processes
+   observe the same chunk slot with shard-ids in mutually exclusive orders,
+   which is impossible in any consistent execution."
+  (:require
+   [clojure.test :refer :all]
+   [elle.list-append :as la]))
+
+;; ─── Anomalous history (planted) ─────────────────────────────────────────────
+
+(def ^:private anomalous-history
+  "Two processes observe chunk slot :s with shard-id lists in contradictory orders.
+   Process 0 sees  [1 2]  →  shard 1 was placed before shard 2.
+   Process 1 sees  [2 1]  →  shard 2 was placed before shard 1.
+   These orders are mutually exclusive: 1→2 AND 2→1 is a version cycle.
+   A correct repair path cannot produce both — Elle must flag the anomaly."
+  [{:index 0 :type :invoke :process 0 :f :txn :value [[:r :s nil]]}
+   {:index 1 :type :ok     :process 0 :f :txn :value [[:r :s [1 2]]]}
+   {:index 2 :type :invoke :process 1 :f :txn :value [[:r :s nil]]}
+   {:index 3 :type :ok     :process 1 :f :txn :value [[:r :s [2 1]]]}])
+
+;; ─── Consistent history (control) ────────────────────────────────────────────
+
+(def ^:private consistent-history
+  "A correct repair sequence: shard 1 is placed, then shard 2, then a read
+   confirms the full placement.  No anomaly — Elle must report :valid."
+  [{:index 0 :type :invoke :process 0 :f :txn :value [[:append :s 1]]}
+   {:index 1 :type :ok     :process 0 :f :txn :value [[:append :s 1]]}
+   {:index 2 :type :invoke :process 1 :f :txn :value [[:append :s 2]]}
+   {:index 3 :type :ok     :process 1 :f :txn :value [[:append :s 2]]}
+   {:index 4 :type :invoke :process 2 :f :txn :value [[:r :s nil]]}
+   {:index 5 :type :ok     :process 2 :f :txn :value [[:r :s [1 2]]]}])
+
+;; ─── Tests ───────────────────────────────────────────────────────────────────
+
+(deftest elle-flags-version-cycle
+  (testing "Elle detects a version cycle (mutually exclusive read orders) in the repair history"
+    (let [result (la/check {:consistency-models [:strict-serializable]} anomalous-history)]
+      (is (map? result)
+          "la/check must return a result map")
+      (is (not= :valid (:valid? result))
+          (str "Elle must flag the contradictory read orders [1 2] vs [2 1] as an anomaly. "
+               "Got: " (pr-str result))))))
+
+(deftest elle-passes-consistent-repair
+  (testing "Elle accepts a strictly-serializable repair history"
+    (let [result (la/check {:consistency-models [:strict-serializable]} consistent-history)]
+      (is (map? result)
+          "la/check must return a result map")
+      (is (= :valid (:valid? result))
+          (str "A correct repair history (1 placed before 2, read confirms [1 2]) "
+               "must pass Elle. Got: " (pr-str result))))))
