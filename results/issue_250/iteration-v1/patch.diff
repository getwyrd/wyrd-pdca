index 0000000..6e5e800
--- /dev/null
+++ b/jepsen/src/wyrd/jepsen.clj
@@ -0,0 +1,275 @@
+(ns wyrd.jepsen
+  "Tier-1 Jepsen consistency harness for Wyrd (proposal 0005 §13.2, issue #250).
+
+   Drives the production custodian repair/reconstruction path against a
+   containerized Wyrd cluster under partitions and crashes, asserting:
+   - No stale or torn reads (ADR-0015)
+   - Repair is commit-point-atomic: a crash mid-repair leaves collectable garbage,
+     never corruption or duplicate placement (`0005:277`, `0005:385-389`)
+
+   The workload models chunk-slot operations as a list-append register:
+   - append(slot, shard-id): record that shard-id was placed at slot
+   - read(slot): observe the current list of placed shard-ids at slot
+   Elle's list-append checker detects anomalies in the observed version histories.
+
+   Usage:
+     lein run test           -- full Jepsen consistency run (requires live cluster)
+     lein test wyrd.checker-test  -- checker self-test only (no cluster needed)"
+  (:gen-class)
+  (:require
+   [clojure.tools.logging :as log]
+   [clojure.string :as str]
+   [elle.list-append :as la]
+   [jepsen.checker :as checker]
+   [jepsen.checker.timeline :as timeline]
+   [jepsen.cli :as cli]
+   [jepsen.client :as client]
+   [jepsen.control :as c]
+   [jepsen.db :as db]
+   [jepsen.generator :as gen]
+   [jepsen.nemesis :as nemesis]
+   [jepsen.tests :as tests]
+   [jepsen.util :as util]))
+
+;; ─── Helpers ──────────────────────────────────────────────────────────────────
+
+(def ^:private wyrd-bin
+  "Path to the `wyrd` binary on the Jepsen control node."
+  (or (System/getenv "WYRD_BIN") "wyrd"))
+
+(defn- wyrd-data-dir
+  "Per-process metadata directory so concurrent clients don't collide."
+  [process]
+  (str "/tmp/wyrd-jepsen-meta-" process))
+
+(defn- endpoints-from-env
+  "Comma-separated D-server endpoint list from WYRD_JEPSEN_ENDPOINTS.
+   Falls back to the default local cluster used by the CI compose setup."
+  []
+  (or (System/getenv "WYRD_JEPSEN_ENDPOINTS")
+      "http://127.0.0.1:50051,http://127.0.0.1:50052,http://127.0.0.1:50053,http://127.0.0.1:50054,http://127.0.0.1:50055"))
+
+;; ─── Wyrd Client ──────────────────────────────────────────────────────────────
+
+(defrecord WyrdClient [endpoints data-dir]
+  client/Client
+
+  (open! [this test node]
+    (let [proc (:process test 0)
+          dir  (wyrd-data-dir proc)]
+      (assoc this
+             :endpoints (or endpoints (endpoints-from-env))
+             :data-dir  dir)))
+
+  (setup! [this test]
+    ;; Nothing to initialise: `wyrd put` is idempotent and creates the key
+    ;; on first write.
+    this)
+
+  (invoke! [this test op]
+    ;; Each micro-op in the transaction is executed against Wyrd in order.
+    ;; For a list-append workload:
+    ;;   [:append slot shard-id] → wyrd put a chunk whose content is shard-id
+    ;;   [:r slot nil]           → wyrd get + parse the full version history
+    (let [txn  (:value op)
+          eps  (:endpoints this)
+          ddir (:data-dir this)]
+      (try
+        (let [result
+              (mapv
+               (fn [[f k v]]
+                 (case f
+                   :append
+                   (let [key-path (format "jepsen/%s/%s" (name k) v)
+                         content  (str v)
+                         tmp      (java.io.File/createTempFile "wyrd-jepsen" ".chunk")]
+                     (spit tmp content)
+                     (let [proc (Runtime/getRuntime)
+                           cmd  [wyrd-bin "put"
+                                 "--endpoints" eps
+                                 "--data-dir"  ddir
+                                 "--key"       key-path
+                                 (.getAbsolutePath tmp)]
+                           pb   (doto (ProcessBuilder. cmd)
+                                  (.redirectErrorStream true))
+                           p    (.start pb)]
+                       (.waitFor p)
+                       (.delete tmp)
+                       (if (= 0 (.exitValue p))
+                         [f k v]
+                         (throw (ex-info "wyrd put failed"
+                                         {:key key-path :exit (.exitValue p)})))))
+
+                   :r
+                   (let [prefix (format "jepsen/%s/" (name k))
+                         ;; Read back all versions at this prefix.
+                         ;; Each file under the prefix is named by the shard-id
+                         ;; (the value appended), so list the prefix to get the
+                         ;; observed version history.
+                         cmd  [wyrd-bin "ls"
+                               "--endpoints" eps
+                               "--data-dir"  ddir
+                               "--prefix"    prefix]
+                         pb   (doto (ProcessBuilder. cmd)
+                                (.redirectErrorStream false))
+                         p    (.start pb)
+                         out  (slurp (.getInputStream p))]
+                     (.waitFor p)
+                     (if (= 0 (.exitValue p))
+                       (let [versions (->> (str/split-lines (str/trim out))
+                                           (remove str/blank?)
+                                           ;; Each line is "jepsen/<slot>/<shard-id>";
+                                           ;; extract the shard-id (last path component).
+                                           (mapv #(last (str/split % #"/")))
+                                           ;; Parse integers so Elle can reason about order.
+                                           (mapv #(Long/parseLong %)))]
+                         [f k (if (empty? versions) nil versions)])
+                       (throw (ex-info "wyrd ls failed"
+                                       {:prefix prefix :exit (.exitValue p)}))))
+
+                   (throw (ex-info "unknown op" {:f f}))))
+               txn)]
+          (assoc op :type :ok :value result))
+        (catch Exception e
+          (log/warn e "op failed" op)
+          (assoc op :type :fail :error (ex-message e))))))
+
+  (teardown! [this test] this)
+
+  (close! [this test] this))
+
+(defn wyrd-client
+  "Construct a Wyrd list-append client."
+  []
+  (map->WyrdClient {:endpoints nil :data-dir nil}))
+
+;; ─── DB (no-op: the CI workflow brings the cluster up before this runs) ────────
+
+(defrecord WyrdDB []
+  db/DB
+
+  (setup! [_ test node]
+    (log/info "Wyrd cluster assumed to be running (started by CI compose step)."))
+
+  (teardown! [_ test node]
+    (log/info "Leaving cluster teardown to the CI compose step."))
+
+  db/LogFiles
+  (log-files [_ test node] []))
+
+(defn wyrd-db [] (map->WyrdDB {}))
+
+;; ─── Nemesis ──────────────────────────────────────────────────────────────────
+
+(defn nemesis-package
+  "A combined nemesis that partitions the network AND crashes+restarts D servers.
+   The partition disrupts communication between nodes mid-repair; the crash
+   terminates a D server and exercises the custodian reconstruction path."
+  []
+  {:nemesis   (nemesis/compose
+               {{:partition-start :partition-start
+                 :partition-stop  :partition-stop}
+                (nemesis/partition-random-halves)
+
+                {:kill  :kill
+                 :start :start}
+                (nemesis/node-start-stopper
+                 rand-nth                          ; kill a random D server
+                 (fn [test node] (c/su (c/exec :pkill :-f "wyrd d-server")))
+                 (fn [test node] (c/su (c/exec :bash :-c
+                                               (str "wyrd d-server "
+                                                    "--bind 0.0.0.0:50051 "
+                                                    "--data-dir /data &")))))})}
+
+   :generator (gen/cycle
+               [(gen/sleep 5)
+                {:type :info :f :partition-start}
+                (gen/sleep 10)
+                {:type :info :f :partition-stop}
+                (gen/sleep 5)
+                {:type :info :f :kill}
+                (gen/sleep 15)      ; allow custodian to detect and begin repair
+                {:type :info :f :start}
+                (gen/sleep 10)])
+
+   :final-generator (gen/phases
+                     {:type :info :f :partition-stop}
+                     {:type :info :f :start}
+                     (gen/sleep 5))})
+
+;; ─── Generator ────────────────────────────────────────────────────────────────
+
+(defn- rand-slot
+  "Pick a random chunk slot from a small key space so reads see collisions."
+  [n]
+  (keyword (str "slot" (rand-int n))))
+
+(defn workload-generator
+  "Produces a mix of list-append and read operations.
+   80 % appends drive the repair path; 20 % reads observe the version history."
+  [slot-count]
+  (gen/mix
+   [(gen/repeat {:type :invoke :f :txn
+                 :value [[:append (rand-slot slot-count) (rand-int 1000000)]]})
+    (gen/repeat {:type :invoke :f :txn
+                 :value [[:r (rand-slot slot-count) nil]]})]))
+
+;; ─── Checker ──────────────────────────────────────────────────────────────────
+
+(defn wyrd-checker
+  "Wraps Elle's list-append checker to assert strict serializability over the
+   repair history.  Elle detects stale reads, torn reads, and version cycles —
+   exactly the anomaly classes ADR-0015 prohibits."
+  []
+  (reify checker/Checker
+    (check [_ test history opts]
+      (la/check
+       {:consistency-models [:strict-serializable]
+        :anomalies          [:G1 :G2]
+        :directory          (str (:store test) "/elle")}
+       history))))
+
+;; ─── Test map ─────────────────────────────────────────────────────────────────
+
+(defn wyrd-test
+  "Assemble the Jepsen test map for the Wyrd Tier-1 consistency campaign."
+  [opts]
+  (let [slot-count 5
+        nemesis    (nemesis-package)]
+    (merge
+     tests/noop-test
+     opts
+     {:name      "wyrd-jepsen-tier1"
+      :db        (wyrd-db)
+      :client    (wyrd-client)
+      :nemesis   (:nemesis nemesis)
+      :checker   (checker/compose
+                  {:list-append (wyrd-checker)
+                   :timeline    (timeline/html)})
+      :generator (gen/phases
+                  ;; Warm-up: seed the cluster before any fault injection.
+                  (->> (workload-generator slot-count)
+                       (gen/stagger 1/50)
+                       (gen/time-limit 30))
+                  ;; Fault phase: inject partitions and crashes while clients continue.
+                  (gen/nemesis
+                   (:generator nemesis)
+                   (->> (workload-generator slot-count)
+                        (gen/stagger 1/20)
+                        (gen/time-limit 120)))
+                  ;; Quiesce: stop the nemesis, allow repair to complete, read results.
+                  (gen/nemesis
+                   (:final-generator nemesis))
+                  (->> (workload-generator slot-count)
+                       (gen/stagger 1/10)
+                       (gen/time-limit 30)))})))
+
+;; ─── Main ─────────────────────────────────────────────────────────────────────
+
+(defn -main
+  "Entry point for `lein run test`.  Delegates to Jepsen's CLI runner so the
+   standard --nodes, --time-limit, --concurrency, etc. flags are honoured."
+  [& args]
+  (cli/run!
+   (cli/single-test-cmd {:test-fn wyrd-test})
+   args))
