@@ -0,0 +1,183 @@
+name: tier1-jepsen
+
+# Tier-1 Jepsen consistency harness (issue #250, proposal 0005 §13.2, `0005:408`).
+# Drives the production custodian repair/reconstruction path against a containerized
+# Wyrd cluster under partitions and crashes, asserting no stale or torn reads
+# (ADR-0015) and that repair is commit-point-atomic (`0005:277`, `0005:385-389`).
+#
+# Two-phase execution:
+#   1. Checker self-test (`lein test`) — verifies the Elle dependency is wired and
+#      catches the planted version-cycle anomaly; no live cluster needed. Runs first
+#      as a fast smoke-check before standing up the cluster.
+#   2. Full Jepsen consistency run (`cargo xtask jepsen`) — drives the production
+#      repair path against a live D-server cluster (RS(3,2), 5 nodes), injects
+#      crash nemeses (kill+restart with tmpfs data loss) AND network-partition
+#      nemeses (docker network disconnect/connect), and asserts strict
+#      serializability via Elle.
+#
+# Toolchain footprint (pre-declared at plan, INTEGRATION §4 / brief §"Planning
+# artifact"): JVM + Clojure + Leiningen are non-Cargo dependencies and are not
+# gated by `deny.toml`. This is the accepted Option-A tradeoff (a genuine Jepsen /
+# Elle artifact over a Check-verifiable in-repo Rust check).
+#
+# Gating policy (ADR-0016): NOT a required merge-gate status check. Runs nightly
+# at 02:00 UTC (non-colliding — 03:00=tier1-disk-faults, 04:00=integration-nightly
+# and mutants, 05:00=tier2-kill-reconstruct) and on demand. `cargo xtask ci` stays
+# unprivileged and container-free; this job runs after merge.
+#
+# Opt-in: `WYRD_TIER1=1` instructs `cargo xtask jepsen` to invoke the in-repo
+# harness (`lein run test` in `jepsen/`). Without it the xtask exits cleanly.
+
+on:
+  schedule:
+    # 02:00 UTC daily (non-colliding: 03:00=tier1-disk-faults,
+    # 04:00=integration-nightly and mutants, 05:00=tier2-kill-reconstruct).
+    - cron: "0 2 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier1-jepsen-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  tier1-jepsen:
+    runs-on: ubuntu-latest
+    # Cluster bring-up + image build + warm-up (30 s) + fault phase (120 s) +
+    # quiesce (30 s) + lein dep download on first run. Generous to avoid flaky
+    # timeout failures on slow runners.
+    timeout-minutes: 60
+    env:
+      CI: "true"
+      # Opt in to the Tier-1 Jepsen harness.
+      WYRD_TIER1: "1"
+      # Number of D-server containers for the Jepsen cluster.
+      WYRD_JEPSEN_DSERVER_COUNT: "5"
+
+    steps:
+      - uses: actions/checkout@v4
+
+      # ── Rust toolchain ────────────────────────────────────────────────────────
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # Build the `wyrd` client binary (used by the Jepsen harness for put/get).
+      - name: Build wyrd binary
+        run: cargo build --release --locked --bin wyrd
+
+      - name: Export wyrd binary path
+        run: echo "WYRD_BIN=${{ github.workspace }}/target/release/wyrd" >> "$GITHUB_ENV"
+
+      # ── Java + Leiningen ──────────────────────────────────────────────────────
+      - name: Set up Java 21 (Temurin)
+        uses: actions/setup-java@v4
+        with:
+          distribution: temurin
+          java-version: "21"
+
+      - name: Install Leiningen
+        run: |
+          curl -sLo /usr/local/bin/lein \
+            https://raw.githubusercontent.com/technomancy/leiningen/stable/bin/lein
+          chmod +x /usr/local/bin/lein
+          lein version
+
+      - name: Cache Leiningen dependencies
+        uses: actions/cache@v4
+        with:
+          path: ~/.m2/repository
+          key: lein-${{ hashFiles('jepsen/project.clj') }}
+          restore-keys: lein-
+
+      # ── Elle checker self-test (no cluster needed) ────────────────────────────
+      # Fast smoke-check: verifies Elle is wired and catches the planted anomaly.
+      # Fails fast before standing up the cluster if the harness code is broken.
+      - name: Elle checker self-test (lein test)
+        working-directory: jepsen
+        run: lein test
+
+      # ── Live Wyrd cluster (D servers) ─────────────────────────────────────────
+      - name: Docker info
+        run: docker info
+
+      - name: Start Wyrd D-server cluster (5 nodes, tmpfs data dirs)
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f jepsen/docker-compose.yml \
+            up -d --build \
+            --scale dserver=5
+
+      - name: Resolve ephemeral D-server ports and export WYRD_JEPSEN_ENDPOINTS
+        # Fix from iteration-1 issue #2: resolve ephemeral ports dynamically via
+        # `docker compose port --index N dserver 50051`, not hardcoded 50051-50055.
+        run: |
+          ENDPOINTS=""
+          for n in $(seq 1 5); do
+            HOST_PORT=$(docker compose \
+              -p wyrd-jepsen \
+              -f jepsen/docker-compose.yml \
+              port --index "$n" dserver 50051 | cut -d: -f2)
+            ENDPOINTS="${ENDPOINTS}http://127.0.0.1:${HOST_PORT},"
+          done
+          # Remove trailing comma.
+          ENDPOINTS="${ENDPOINTS%,}"
+          echo "WYRD_JEPSEN_ENDPOINTS=$ENDPOINTS" >> "$GITHUB_ENV"
+          echo "Resolved endpoints: $ENDPOINTS"
+
+      - name: Export container name prefix
+        run: echo "WYRD_JEPSEN_CONTAINER_PREFIX=wyrd-jepsen-dserver-" >> "$GITHUB_ENV"
+
+      - name: Wait for all D servers to be ready
+        run: |
+          for ep in $(echo "$WYRD_JEPSEN_ENDPOINTS" | tr ',' ' '); do
+            host=$(echo "$ep" | sed 's|http://||' | cut -d: -f1)
+            port=$(echo "$ep" | sed 's|http://||' | cut -d: -f2)
+            for i in $(seq 1 30); do
+              nc -z "$host" "$port" 2>/dev/null && echo "  ready: $ep" && break
+              [ "$i" -eq 30 ] && echo "WARN: $ep not ready after 60 s" || true
+              sleep 2
+            done
+          done
+
+      # ── Full Jepsen consistency run ───────────────────────────────────────────
+      # cargo xtask jepsen (WYRD_TIER1=1) → faults::run_jepsen() → run_jepsen_harness()
+      # → `lein run test` in jepsen/ — full Jepsen run with crash + partition nemeses
+      # and Elle consistency checking.
+      - name: cargo xtask jepsen (full Jepsen consistency run)
+        run: cargo xtask jepsen
+
+      # ── Diagnostics on failure ────────────────────────────────────────────────
+      - name: Capture cluster logs
+        if: failure()
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f jepsen/docker-compose.yml \
+            logs --no-color --timestamps \
+            > target/jepsen-cluster.log 2>&1 || true
+
+      - name: Upload Jepsen results and cluster logs
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: tier1-jepsen-results
+          path: |
+            jepsen/store/
+            target/jepsen-cluster.log
+          if-no-files-found: ignore
+          retention-days: 14
+
+      # ── Teardown ──────────────────────────────────────────────────────────────
+      - name: Tear down cluster
+        if: always()
+        run: |
+          docker compose \
+            -p wyrd-jepsen \
+            -f jepsen/docker-compose.yml \
+            down -v --remove-orphans || true
