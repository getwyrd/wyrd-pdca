@@ -0,0 +1,371 @@
+//! **Tier-1 Jepsen custodian reconstruction step** (issue #250, proposal 0005 §13.2).
+//!
+//! What this test does: drives the **production custodian repair/reconstruction path**
+//! (`custodian::reconcile_step` → `reconstruction::reconcile`) against the live Jepsen
+//! D-server cluster, processing repair obligations for fragments missing on a
+//! killed-and-restarted server.
+//!
+//! ## How it integrates with the Jepsen harness
+//!
+//! The Clojure Jepsen harness (`jepsen/src/wyrd/jepsen.clj`) invokes this test after
+//! the nemesis recovery (`:heal`) phase:
+//!
+//! ```text
+//! (sh "cargo" "test" "-p" "wyrd-chunkstore-grpc" "--test" "jepsen_custodian_step"
+//!     "--" "--ignored" "--nocapture"
+//!     :env {"WYRD_JEPSEN_META_DIR" meta-dir "WYRD_DSERVER_ENDPOINTS" endpoints})
+//! ```
+//!
+//! ## Production path exercised
+//!
+//! The Jepsen crash nemesis kills a D-server container and restarts it with empty
+//! `/data` (tmpfs). After restart, the server holds NO fragment data — all chunks
+//! previously placed on it are now missing on that server. This test:
+//!
+//! 1. Opens the persisted client-side `RedbMetadataStore` (written by `wyrd put`/`wyrd get`).
+//! 2. Connects to all live D-server endpoints (including the restarted server).
+//! 3. **Detects missing fragments** (`detect_and_enqueue_missing`): scans all committed
+//!    inodes, checks each placed server for each fragment via `get_fragment`, and calls
+//!    `repair::enqueue_repair` for any chunk with a missing fragment (`Ok(None)`).
+//!    This is the "detect" phase the production read path does not perform for
+//!    simply-absent (as opposed to present-but-corrupt) fragments.
+//! 4. **Asserts the repair queue is non-empty** — at least one missing fragment must
+//!    have been detected, proving the crash nemesis created real data loss.
+//! 5. Runs `reconcile_step` with a `ReconstructionContext`: detects missing fragments
+//!    from the repair queue, rebuilds them from the k surviving erasure fragments, and
+//!    places the rebuilt fragment on the restarted server (its domain is now free).
+//! 6. **Asserts `Reconciled::Changed`** — reconstruction must have actually fired,
+//!    not returned `Satisfied` (no-work-done). This proves the production reconstruction
+//!    path was exercised, not bypassed by an empty repair queue.
+//!
+//! ## Fixes from iteration-2 carry-forward (issue #250)
+//!
+//! - **Issue #2 (advisory: jepsen_custodian_step.rs:229, v2)**: The previous version
+//!   treated any successful `reconcile_step` as a pass, including `Reconciled::Satisfied`
+//!   (no work done). Combined with the production read path only enqueuing repair for
+//!   present-but-corrupt fragments (not for missing/`Ok(None)` ones), the step could
+//!   run against an empty repair queue and never exercise reconstruction.
+//!
+//!   Fix: `detect_and_enqueue_missing` explicitly scans all committed chunks for
+//!   missing fragments and enqueues them. `reconcile_step` then has actual work to do
+//!   and returns `Reconciled::Changed`. Both are asserted.
+//!
+//! ## Gating
+//!
+//! The `#[ignore]` attribute keeps this body out of `cargo xtask ci` (unprivileged,
+//! container-free, ADR-0016). `cargo test --workspace` **compiles and type-checks** this
+//! file (proving the custodian step is real API-bound Rust, not an env-var shell string).
+//!
+//! ## Born-at-tier coverage
+//!
+//! [`jepsen_topology`] is a regular function with its own non-`#[ignore]`d unit tests.
+//! Removing or stubbing it fails both those unit tests AND the compile-time type-check of
+//! the scenario body — the born-at-tier seam is load-bearing.
+
+use std::collections::HashMap;
+use std::time::Duration;
+
+use wyrd_chunkstore_grpc::GrpcChunkStore;
+use wyrd_coordination_mem::MemCoordination;
+use wyrd_core::metadata::{self, InodeRecord, InodeState};
+use wyrd_core::repair;
+use wyrd_custodian::{reconcile_step, Custodian, FencedZone, ReconstructionContext, Topology};
+use wyrd_metadata_redb::RedbMetadataStore;
+use wyrd_traits::{ChunkStore, DServerId, FragmentId, MetadataStore};
+
+// ── Born-at-tier topology helper ──────────────────────────────────────────────
+
+/// Build a simple topology for an N-server Jepsen cluster: server 0 → domain "A",
+/// server 1 → domain "B", …, server N-1 → domain chr('A' + (N-1) % 26).
+///
+/// With RS(3,2) and 5 servers (domains A–E), killing server 0 and restarting it with
+/// empty `/data` leaves servers 1–4 (domains B–E) holding the 4 surviving fragments.
+/// Domain A is "free" (no surviving fragment there), so reconstruction re-places the
+/// rebuilt fragment back onto server 0 (domain A) — the production distinct-domain
+/// selector picks the free domain, and the restarted server receives the rebuilt shard.
+#[must_use]
+pub(crate) fn jepsen_topology(n: usize) -> Topology {
+    let mut t = Topology::new(vec![]);
+    for i in 0..n {
+        let domain = format!("{}", (b'A' + (i % 26) as u8) as char);
+        t.register(i as DServerId, domain);
+    }
+    t
+}
+
+// ── Born-at-tier unit tests ────────────────────────────────────────────────────
+
+#[test]
+fn jepsen_topology_assigns_distinct_domains_for_five_server_cluster() {
+    let t = jepsen_topology(5);
+    // Domains must be assigned to all 5 servers and be distinct.
+    let domains: Vec<_> = (0u64..5)
+        .map(|i| t.domain_of(i).expect("server must be registered").clone())
+        .collect();
+    assert_eq!(domains.len(), 5, "topology must have 5 entries");
+    let mut sorted = domains.clone();
+    sorted.sort();
+    sorted.dedup();
+    assert_eq!(
+        sorted.len(),
+        5,
+        "all 5 domains must be distinct; got {domains:?}"
+    );
+    // Spot-check domain names (FailureDomain(pub String) — access inner string via .0).
+    assert_eq!(t.domain_of(0).unwrap().0, "A");
+    assert_eq!(t.domain_of(4).unwrap().0, "E");
+}
+
+#[test]
+fn jepsen_topology_distinct_domain_count_matches_server_count() {
+    for n in 1..=10_usize {
+        let t = jepsen_topology(n);
+        assert_eq!(
+            t.distinct_domains(),
+            n,
+            "jepsen_topology({n}): distinct_domains() must equal n"
+        );
+    }
+}
+
+// ── Detect-and-enqueue missing fragments ──────────────────────────────────────
+
+/// Scan all committed inodes in `meta`, check each placed fragment on the fleet,
+/// and enqueue repair for any chunk that has at least one missing fragment
+/// (`get_fragment` returns `Ok(None)`).
+///
+/// Returns the number of chunks enqueued for repair.
+///
+/// ## Why this step is needed
+///
+/// The production read path (`crates/core/src/read.rs`) only enqueues repair when a
+/// fragment is **present but corrupt** (checksum fails or header names a different
+/// chunk). A **missing** fragment — `get_fragment` returns `Ok(None)` because the
+/// server restarted with empty `/data` — is treated as a transient absence and is
+/// NOT enqueued. This means after the crash nemesis heals, the repair queue is empty
+/// and `reconcile_step` returns `Reconciled::Satisfied` without exercising
+/// reconstruction.
+///
+/// This function closes that gap for the Jepsen scenario: it explicitly checks each
+/// placed server for each committed chunk's fragments and enqueues repair for any chunk
+/// with a missing fragment. `reconcile_step` then has actual work to do.
+///
+/// This is analogous to a "placement integrity check" — detecting ABSENT fragments,
+/// not just verifying PRESENT ones (which is what scrub does).
+async fn detect_and_enqueue_missing(
+    meta: &dyn MetadataStore,
+    fleet: &[(DServerId, &dyn ChunkStore)],
+) -> u32 {
+    let stores: HashMap<DServerId, &dyn ChunkStore> = fleet.iter().copied().collect();
+
+    let entries = meta
+        .scan(b"inode:")
+        .await
+        .expect("jepsen_custodian_step: failed to scan inode: metadata");
+
+    let mut enqueued = 0u32;
+    for (_key, value) in entries {
+        let record: InodeRecord = match metadata::decode(&value) {
+            Ok(r) => r,
+            Err(_) => continue, // skip malformed records
+        };
+        if record.state != InodeState::Committed {
+            continue;
+        }
+        'chunk: for chunk in &record.chunk_map {
+            // Check each placed server for the expected fragment.
+            for (index, &dserver) in chunk.placement.iter().enumerate() {
+                let frag = FragmentId {
+                    chunk: chunk.id,
+                    index: index as u16,
+                };
+                let missing = match stores.get(&dserver) {
+                    Some(store) => match store.get_fragment(frag).await {
+                        Ok(None) => true,     // fragment definitely absent → enqueue repair
+                        Ok(Some(_)) => false, // fragment present → skip
+                        Err(_) => false,      // transient error → skip (not a confirmed loss)
+                    },
+                    None => false, // server not in fleet → skip
+                };
+                if missing {
+                    // Enqueue this chunk for reconstruction once (idempotent).
+                    repair::enqueue_repair(meta, chunk.id, "jepsen-detect")
+                        .await
+                        .expect("jepsen_custodian_step: failed to enqueue repair");
+                    enqueued += 1;
+                    continue 'chunk; // one enqueue per chunk is sufficient
+                }
+            }
+        }
+    }
+    enqueued
+}
+
+// ── Scenario helpers ───────────────────────────────────────────────────────────
+
+/// Dial a D-server, retrying briefly while it finishes binding its listener after a
+/// container restart. Mirrors `connect` in `tier2_kill_reconstruct.rs`.
+async fn connect_with_retry(endpoint: &str) -> GrpcChunkStore {
+    let mut last_err = None;
+    for _ in 0..30 {
+        match GrpcChunkStore::connect(endpoint.to_string()).await {
+            Ok(c) => return c,
+            Err(e) => {
+                last_err = Some(e);
+                tokio::time::sleep(Duration::from_millis(200)).await;
+            }
+        }
+    }
+    panic!("could not connect to D server `{endpoint}`: {last_err:?}");
+}
+
+// ── Scenario test ──────────────────────────────────────────────────────────────
+
+/// **Jepsen custodian reconstruction step** — detects missing fragments on the
+/// restarted server, enqueues repair obligations, and drives `reconcile_step`
+/// → `reconstruction::reconcile` against the live Jepsen cluster.
+///
+/// Invoked by `jepsen/src/wyrd/jepsen.clj` after crash nemesis recovery:
+/// ```text
+/// (sh "cargo" "test" "-p" "wyrd-chunkstore-grpc"
+///     "--test" "jepsen_custodian_step"
+///     "--" "--ignored" "--nocapture"
+///     :env {"WYRD_JEPSEN_META_DIR" meta-dir "WYRD_DSERVER_ENDPOINTS" eps})
+/// ```
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+#[ignore = "Tier-1 Jepsen: needs live cluster — invoked by `jepsen/src/wyrd/jepsen.clj` after crash nemesis recovery"]
+async fn jepsen_custodian_reconstruction_step() {
+    let meta_dir = match std::env::var("WYRD_JEPSEN_META_DIR") {
+        Ok(v) if !v.trim().is_empty() => v,
+        _ => {
+            eprintln!(
+                "jepsen_custodian_step: WYRD_JEPSEN_META_DIR not set — skipping. \
+                 This test is invoked by the Jepsen harness after crash nemesis recovery."
+            );
+            return;
+        }
+    };
+    let raw_endpoints = match std::env::var("WYRD_DSERVER_ENDPOINTS") {
+        Ok(v) if !v.trim().is_empty() => v,
+        _ => {
+            eprintln!("jepsen_custodian_step: WYRD_DSERVER_ENDPOINTS not set — skipping.");
+            return;
+        }
+    };
+
+    let endpoints: Vec<String> = raw_endpoints
+        .split(',')
+        .map(|s| s.trim().to_string())
+        .filter(|s| !s.is_empty())
+        .collect();
+
+    eprintln!("jepsen_custodian_step: meta_dir={meta_dir:?} endpoints={endpoints:?}");
+
+    // Open the persisted client-side metadata store (written by `wyrd put`/`wyrd get`).
+    // Path mirrors `cli.rs::open_cluster_meta`: `{data_dir}/meta.redb`.
+    let meta_path = std::path::Path::new(&meta_dir).join("meta.redb");
+    let meta = RedbMetadataStore::open(&meta_path).unwrap_or_else(|e| {
+        panic!("jepsen_custodian_step: failed to open RedbMetadataStore at {meta_path:?}: {e}")
+    });
+
+    // Connect to all D-server endpoints (including the restarted server with empty /data).
+    let mut clients: Vec<GrpcChunkStore> = Vec::with_capacity(endpoints.len());
+    for ep in &endpoints {
+        clients.push(connect_with_retry(ep).await);
+    }
+
+    // Fleet: all servers (server i is at index i).
+    let fleet: Vec<(DServerId, &dyn ChunkStore)> = clients
+        .iter()
+        .enumerate()
+        .map(|(i, c)| (i as DServerId, c as &dyn ChunkStore))
+        .collect();
+
+    // Topology: one distinct failure domain per server (A, B, C, D, E for 5 servers).
+    // The restarted server (killed+restarted with empty /data) is still in the
+    // topology — its domain is free (no surviving fragment there), so reconstruction
+    // can re-place the rebuilt fragment onto it.
+    let topology = jepsen_topology(endpoints.len());
+
+    // ── Step 1: Detect and enqueue missing fragments ───────────────────────────
+    //
+    // The production read path only enqueues repair for present-but-corrupt fragments.
+    // After the crash nemesis, the restarted server has empty /data — all its placed
+    // fragments return `Ok(None)` — but these are not enqueued by the read path.
+    // We detect them here and enqueue repair obligations so reconcile_step has work.
+    //
+    // Fix from iteration-2 advisory issue #2: assert reconstruction actually fires.
+    eprintln!("jepsen_custodian_step: detecting missing fragments and enqueuing repair");
+    let enqueued = detect_and_enqueue_missing(&meta, &fleet).await;
+    eprintln!("jepsen_custodian_step: enqueued {enqueued} chunks for repair");
+
+    assert!(
+        enqueued > 0,
+        "jepsen_custodian_step: no missing fragments detected after crash nemesis heal. \
+         The repair queue is empty — reconstruction cannot fire. \
+         Expected: the crash nemesis killed+restarted a server with empty /data (tmpfs), \
+         leaving at least one chunk without its placed fragment on that server."
+    );
+
+    // ── Step 2: Elect custodian and run reconcile_step ─────────────────────────
+    //
+    // In-process coordination (no live etcd needed for the custodian step).
+    let coord = MemCoordination::new();
+    let custodian = Custodian::elect(&coord, "jepsen-custodian-zone")
+        .await
+        .expect("Custodian::elect");
+    let mut zone = FencedZone::new();
+    zone.install(custodian.leadership());
+
+    eprintln!("jepsen_custodian_step: running reconcile_step (reconstruction)");
+
+    // Drive the production custodian reconstruction path:
+    // - Reads queued repair obligations (enqueued above by detect_and_enqueue_missing).
+    // - For each obligation, checks which fragments are missing on the fleet.
+    // - Rebuilds missing fragments from the surviving k erasure fragments.
+    // - Places the rebuilt fragment in the free failure domain (the restarted server's).
+    // - Updates the metadata (version-conditional commit).
+    let result = reconcile_step(
+        &zone,
+        &custodian,
+        None, // no GC
+        None, // no scrub
+        Some(&ReconstructionContext {
+            meta: &meta,
+            fleet: &fleet,
+            topology: &topology,
+        }),
+        None, // no rebalance
+        0,    // now_millis (deterministic; lease-check irrelevant here)
+    )
+    .await;
+
+    // ── Step 3: Assert reconstruction actually fired ───────────────────────────
+    //
+    // Fix from iteration-2 advisory issue #2: assert Reconciled::Changed, not just Ok.
+    // Reconciled::Satisfied means no work was done (queue was empty or all obligations
+    // were stale/satisfied) — that would indicate reconstruction did NOT exercise the
+    // production repair path.
+    match result {
+        Ok(wyrd_custodian::Reconciled::Changed) => {
+            eprintln!(
+                "jepsen_custodian_step: reconstruction fired — \
+                 reconcile_step returned Reconciled::Changed. OK."
+            );
+        }
+        Ok(wyrd_custodian::Reconciled::Satisfied) => {
+            panic!(
+                "jepsen_custodian_step: reconcile_step returned Reconciled::Satisfied \
+                 (no work done) even though {enqueued} chunks were enqueued for repair. \
+                 This means the reconstruction loop found no repairable chunks in the queue \
+                 — the harness did not exercise the production repair/reconstruction path. \
+                 Check that: (1) the repair queue entries were committed before reconcile_step \
+                 was called, (2) the fleet includes the restarted server, and (3) at least \
+                 k surviving fragments exist on the other servers."
+            );
+        }
+        Err(e) => {
+            panic!("jepsen_custodian_step: reconcile_step failed: {e:?}");
+        }
+    }
+}
