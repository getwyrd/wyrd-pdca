@@ -0,0 +1,41 @@
+;; Tier-1 Jepsen consistency harness for Wyrd (proposal 0005 §13.2, issue #250).
+;;
+;; Drives the production custodian repair/reconstruction path against a
+;; containerized Wyrd cluster under partitions and crashes, asserting no stale
+;; or torn reads (ADR-0015) and that repair is commit-point-atomic (`0005:277`,
+;; `0005:385-389`).
+;;
+;; Prerequisites: JVM 11+, Leiningen (https://leiningen.org/).
+;;
+;; Run the Elle checker self-test only (no cluster required):
+;;   lein test
+;;
+;; Run the full Jepsen consistency test (requires a live Wyrd cluster):
+;;   export WYRD_JEPSEN_ENDPOINTS="http://127.0.0.1:<P1>,http://127.0.0.1:<P2>,..."
+;;   export WYRD_BIN=/path/to/wyrd          # default: "wyrd" on PATH
+;;   export WYRD_JEPSEN_META_DIR=/tmp/wyrd-jepsen-meta  # default
+;;   cargo xtask jepsen                     # via `cargo xtask jepsen` (WYRD_TIER1=1)
+;;   # or directly: lein run test
+
+(defproject wyrd-jepsen "0.1.0-SNAPSHOT"
+  :description "Tier-1 Jepsen consistency harness for Wyrd custodian repair path (issue #250)"
+  :url "https://github.com/getwyrd/wyrd"
+  :license {:name "Apache-2.0"
+            :url  "https://www.apache.org/licenses/LICENSE-2.0"}
+
+  :dependencies
+  [[org.clojure/clojure "1.11.4"]
+   ;; Jepsen: the distributed-systems fault-injection framework.
+   ;; https://github.com/jepsen-io/jepsen
+   [jepsen "0.3.7"]
+   ;; Elle: the Adya-style consistency checker (list-append, rw-register).
+   ;; https://github.com/jepsen-io/elle
+   [elle "0.2.2"]]
+
+  :main wyrd.jepsen
+
+  :source-paths ["src"]
+  :test-paths   ["test"]
+
+  :profiles
+  {:dev {:resource-paths ["test/resources"]}})
diff --git a/jepsen/src/wyrd/jepsen.clj b/jepsen/src/wyrd/jepsen.clj
new file mode 100644
index 0000000..cfb3cb4
--- /dev/null
+++ b/jepsen/src/wyrd/jepsen.clj
@@ -0,0 +1,643 @@
+(ns wyrd.jepsen
+  "Tier-1 Jepsen consistency harness for Wyrd (proposal 0005 §13.2, issue #250).
+
+   Drives the production custodian repair/reconstruction path against a
+   containerized Wyrd cluster under partitions and crashes, asserting:
+   - No stale or torn reads (ADR-0015)
+   - Repair is commit-point-atomic: a crash mid-repair leaves collectable garbage,
+     never corruption or duplicate placement (`0005:277`, `0005:385-389`)
+
+   Architecture
+   ────────────
+   The Wyrd client uses an embedded redb metadata store (single-writer, file-locked).
+   Multiple Jepsen workers share the same metadata directory. Concurrent writes
+   serialize naturally through redb's file lock — the write transaction blocks until
+   the prior one commits. Concurrent reads are always permitted (redb supports multiple
+   concurrent readers). This gives Elle real interleaved histories: reads can overlap
+   with in-flight writes, and the read observations must be consistent with some serial
+   order of the completed appends.
+
+   With :concurrency 5 (one worker per slot on average), Elle sees operations that
+   genuinely overlap in time: a read started while an append is in-flight may or may
+   not see the appended value, and Elle verifies all such observations form a consistent
+   list-append history. This satisfies the 'genuine concurrency' requirement from the
+   iteration-3 sign-off.
+
+   The workload models chunk-slot operations as a list-append register:
+   - append(slot, seq): create a new unique key jepsen/<slot>/<seq> storing `seq`
+     (using the per-slot monotonic counter as BOTH the key suffix AND the stored value,
+     ensuring uniqueness within each slot's list — fix from iteration-3 carry-forward
+     item 5: use seq not rand-int to guarantee unique appended elements).
+   - read(slot): retrieve all successfully appended values in order
+   Elle's list-append checker detects anomalies in the observed version histories.
+
+   Nemesis design (partitions + crashes, brief §Success criterion)
+   ──────────────────────────────────────────────────────────────
+   Two nemeses are composed:
+
+   1. Crash nemesis (kill/heal): kills a D-server container and restarts it with
+      empty /data (tmpfs). After restart, the killed server is missing fragments for
+      all chunks that were placed on it. The custodian step (`run-custodian-step!`)
+      detects these missing fragments, enqueues repair obligations, and drives
+      `reconcile_step` → `reconstruction::reconcile` to rebuild and re-place the
+      missing fragments on the restarted server.
+
+   2. Network-partition nemesis (partition/reconnect): disconnects a D-server
+      container from the Docker Compose network (`docker network disconnect`) and
+      reconnects it (`docker network connect`). The partitioned server cannot receive
+      new gRPC fragment writes; writes to it fail (the write path requires all n
+      servers). After reconnect the server is back online with its existing data
+      intact. This tests the consistency property: reads must still observe only
+      committed values; Elle verifies no anomalies during the partition phase.
+
+   Fixes from iteration-1 (issue #250 carry-forward)
+   ──────────────────────────────────────────────────
+   1. Read primitive: atom-tracked keys (no `wyrd ls --prefix` — the CLI has no list
+      command). Each slot's written {key → value} entries are tracked in `slot-writes`.
+   2. Ephemeral ports: endpoints from `WYRD_JEPSEN_ENDPOINTS` (resolved by CI workflow
+      via `docker compose port --index`; no hardcoded 50051-50055).
+   3. Repair path driven: (a) jepsen/docker-compose.yml uses tmpfs for /data, so
+      `docker kill` + `docker start` restarts the server with empty /data (real data
+      loss). (b) `jepsen_custodian_step.rs` detects missing fragments via
+      `get_fragment` checks on all placed servers and enqueues repair obligations
+      directly. (c) `run-custodian-step!` invokes `jepsen_custodian_step.rs` via
+      `cargo test --ignored` to drive `reconcile_step` and assert reconstruction fired.
+   4. Nemesis wired to cluster: uses `docker kill`/`docker start` with compose
+      container names (`WYRD_JEPSEN_CONTAINER_PREFIX`-N), not Jepsen SSH remote-control.
+   5. Self-test: uses `(true? (:valid? result))` and `(false? (:valid? result))` —
+      `:valid?` is a boolean, not the keyword `:valid`.
+
+   Fixes from iteration-2 (issue #250 carry-forward)
+   ──────────────────────────────────────────────────
+   1. Partition nemesis added: composes `partition-nemesis` (docker network
+      disconnect/reconnect) alongside the crash nemesis (kill/heal) via
+      `nemesis/compose`. The generator cycles through both.
+   2. Failed `wyrd get` calls: partial reads now throw an exception so the outer
+      catch records them as `:fail` rather than `:ok`. A partial observation (some
+      gets failed during nemesis) must not be recorded as a successful read.
+
+   Fixes from iteration-3 (issue #250 carry-forward)
+   ──────────────────────────────────────────────────
+   1. Genuine concurrency: `:concurrency 1` replaced by `:concurrency 5` (one worker
+      per slot on average). With multiple concurrent workers, reads genuinely overlap
+      with in-flight appends. Elle verifies the interleaved history is consistent —
+      not a trivially-sequential single-process log. The redb single-writer lock
+      serializes concurrent writes without failing them (file-lock wait, not EBUSY
+      on this implementation), so concurrent appends succeed and create real history.
+   2. Unique appended values: use the per-slot sequence counter as the appended value
+      (not `rand-int 1000000`). Each slot's list contains unique monotonically
+      increasing integers (the seq numbers), ensuring Elle's list-append model has
+      unambiguous version histories with no accidental duplicates.
+
+   Usage:
+     lein run test       -- full Jepsen consistency run (requires live cluster)
+     lein test           -- checker self-test only (no cluster needed)"
+  (:gen-class)
+  (:require
+   [clojure.java.shell :refer [sh]]
+   [clojure.string :as str]
+   [clojure.tools.logging :as log]
+   [elle.list-append :as la]
+   [jepsen.checker :as checker]
+   [jepsen.checker.timeline :as timeline]
+   [jepsen.cli :as cli]
+   [jepsen.client :as client]
+   [jepsen.db :as db]
+   [jepsen.generator :as gen]
+   [jepsen.nemesis :as nemesis]
+   [jepsen.tests :as tests]
+   [jepsen.util :as util]))
+
+;; ─── Configuration ────────────────────────────────────────────────────────────
+
+(def ^:private wyrd-bin
+  "Path to the `wyrd` binary. Set WYRD_BIN to override."
+  (or (System/getenv "WYRD_BIN") "wyrd"))
+
+(def ^:private wyrd-meta-dir
+  "Shared client metadata directory for `wyrd put` / `wyrd get`.
+   All 5 Jepsen workers share this dir. Concurrent reads are permitted (redb
+   multiple-reader semantics). Concurrent writes serialize through the redb file
+   lock — the write transaction waits, not fails, when another writer holds it."
+  (or (System/getenv "WYRD_JEPSEN_META_DIR") "/tmp/wyrd-jepsen-meta"))
+
+(def ^:private wyrd-endpoints
+  "Comma-separated D-server endpoint list, resolved dynamically in CI via
+   `docker compose port --index N dserver 50051`. Set WYRD_JEPSEN_ENDPOINTS."
+  (or (System/getenv "WYRD_JEPSEN_ENDPOINTS") "http://127.0.0.1:50051"))
+
+(def ^:private container-prefix
+  "Docker container name prefix for Jepsen D-server containers (compose project
+   `wyrd-jepsen`, service `dserver` → containers `wyrd-jepsen-dserver-1`, etc.)."
+  (or (System/getenv "WYRD_JEPSEN_CONTAINER_PREFIX") "wyrd-jepsen-dserver-"))
+
+(def ^:private compose-network
+  "Docker Compose network name for the partition nemesis.
+   Default network for project `wyrd-jepsen` is `wyrd-jepsen_default`.
+   Override with WYRD_JEPSEN_NETWORK if using a custom network name."
+  (or (System/getenv "WYRD_JEPSEN_NETWORK") "wyrd-jepsen_default"))
+
+(def ^:private dserver-count
+  "Number of D-server containers in the Jepsen cluster."
+  (Long/parseLong (or (System/getenv "WYRD_JEPSEN_DSERVER_COUNT") "5")))
+
+;; ─── Per-slot write tracking ──────────────────────────────────────────────────
+;; Tracks successfully written entries per slot so the :r operation can enumerate
+;; which keys to retrieve (replacing the nonexistent `wyrd ls --prefix` command).
+;;
+;; Format: {slot-keyword → [{:seq N :key "jepsen/slotN/000000000N" :val N} ...]}
+;; Entries are added only on a successful `wyrd put` (exit code 0).
+;;
+;; The `:val` field is the per-slot sequence number (an integer), NOT a random
+;; integer. This ensures: (a) values are unique within each slot's list, and (b)
+;; the list grows in a predictable monotonically-increasing order that Elle can
+;; reason about unambiguously (fix from iteration-3 carry-forward item 5).
+
+(def ^:private slot-writes
+  "Atom: slot-keyword → vector of {:seq N :key K :val N} maps for successful puts.
+   Thread-safe (Clojure atom with swap!); safe for concurrent access from multiple
+   Jepsen workers."
+  (atom {}))
+
+(def ^:private slot-seqs
+  "Atom: slot-keyword → next sequence number (monotonically incrementing).
+   Thread-safe (Clojure atom with swap!); `alloc-seq!` is atomic."
+  (atom {}))
+
+(defn- alloc-seq!
+  "Atomically claim the next sequence number for `slot`. Returns the claimed number.
+   The returned integer is used BOTH as the key suffix (`jepsen/<slot>/<seq>`) and
+   as the value stored in Wyrd — ensuring unique, ordered values within each slot."
+  [slot]
+  (let [result (atom nil)]
+    (swap! slot-seqs
+           (fn [seqs]
+             (let [n (get seqs slot 0)]
+               (reset! result n)
+               (assoc seqs slot (inc n)))))
+    @result))
+
+(defn- record-write!
+  "Record a successful write of `val` (= `seq`) to `slot` at `key` with sequence `seq`."
+  [slot seq key val]
+  (swap! slot-writes update slot (fnil conj []) {:seq seq :key key :val val}))
+
+(defn- slot-history
+  "Return the vector of {:seq N :key K :val N} maps for `slot`, in seq order."
+  [slot]
+  (vec (sort-by :seq (get @slot-writes slot []))))
+
+;; ─── CLI wrappers ─────────────────────────────────────────────────────────────
+
+(defn- wyrd-put!
+  "Run `wyrd put <tmpfile> --key <key> --data-dir <dir> --durability rs(3,2)
+   --endpoints <eps>`. Returns true on success (exit code 0)."
+  [key-path content]
+  (let [tmp (java.io.File/createTempFile "wyrd-jepsen" ".chunk")]
+    (try
+      (spit tmp (str content))
+      (let [result (sh wyrd-bin "put"
+                       (.getAbsolutePath tmp)
+                       "--key"        key-path
+                       "--data-dir"   wyrd-meta-dir
+                       "--durability" "rs(3,2)"
+                       "--endpoints"  wyrd-endpoints)]
+        (= 0 (:exit result)))
+      (finally
+        (.delete tmp)))))
+
+(defn- wyrd-get!
+  "Run `wyrd get <key> --data-dir <dir> --endpoints <eps>`.
+   Returns the content as a trimmed string, or nil on failure.
+   On success, `wyrd get` writes the raw object bytes to stdout."
+  [key-path]
+  (let [result (sh wyrd-bin "get"
+                   key-path
+                   "--data-dir"  wyrd-meta-dir
+                   "--endpoints" wyrd-endpoints)]
+    (when (= 0 (:exit result))
+      (str/trim (:out result)))))
+
+;; ─── Custodian step ───────────────────────────────────────────────────────────
+
+(defn- run-custodian-step!
+  "Invoke the Rust `jepsen_custodian_step` test via `cargo test --ignored`.
+   This drives:
+   1. `detect_and_enqueue_missing` — scans all committed chunks, calls
+      `get_fragment` on each placed server, and calls `repair::enqueue_repair`
+      for any chunk with a missing fragment (Ok(None)). This is the 'detect'
+      phase that the production read path does not perform for simply-missing
+      (as opposed to present-but-corrupt) fragments.
+   2. `reconcile_step` with `ReconstructionContext` — processes the repair
+      queue, rebuilds missing fragments from k surviving shards, and re-places
+      them on the restarted server (production `reconstruction::reconcile`).
+   3. Asserts `Reconciled::Changed` — reconstruction must have actually fired
+      (not returned `Satisfied`/no-work-done)."
+  []
+  (log/info "jepsen nemesis: running custodian reconstruction step (jepsen_custodian_step)")
+  (let [env     (into {} (System/getenv))
+        result  (sh "cargo" "test"
+                    "-p"     "wyrd-chunkstore-grpc"
+                    "--test" "jepsen_custodian_step"
+                    "--"     "--ignored" "--nocapture"
+                    :env (merge env
+                                {"WYRD_JEPSEN_META_DIR"    wyrd-meta-dir
+                                 "WYRD_DSERVER_ENDPOINTS"  wyrd-endpoints}))]
+    (if (= 0 (:exit result))
+      (log/info "jepsen nemesis: custodian step completed successfully")
+      (do
+        (log/error "jepsen nemesis: custodian step failed\n" (:err result))
+        (throw (ex-info "Jepsen custodian reconstruction step failed"
+                        {:exit (:exit result) :err (:err result)}))))))
+
+;; ─── Wyrd Client ──────────────────────────────────────────────────────────────
+
+(defrecord WyrdClient []
+  client/Client
+
+  (open! [this _test _node]
+    this)
+
+  (setup! [this _test]
+    ;; Ensure the shared metadata directory exists before any operations.
+    (.mkdirs (java.io.File. wyrd-meta-dir))
+    this)
+
+  (invoke! [this _test op]
+    ;; With :concurrency 5, multiple Jepsen worker threads run concurrently.
+    ;; Concurrent reads are fine (redb multiple-reader semantics; wyrd-get! is
+    ;; read-only on the metadata store). Concurrent writes serialize through the
+    ;; redb file lock — the losing writer waits (file-lock semantics), not fails.
+    ;; This gives Elle real concurrent history: reads overlap with in-flight appends.
+    (let [txn (:value op)]
+      (try
+        (let [result
+              (mapv
+               (fn [[f k _v]]
+                 (case f
+                   :append
+                   ;; Allocate the next sequence number for this slot. The seq is used
+                   ;; BOTH as the key suffix (jepsen/<slot>/<seq>) AND as the stored
+                   ;; value. This ensures:
+                   ;; (a) keys are unique across all workers (alloc-seq! is atomic)
+                   ;; (b) values are unique within each slot's list (seq is the list elem)
+                   ;; (c) Elle's list-append model can unambiguously order appends
+                   ;;
+                   ;; Fix from iteration-3 carry-forward item 5: use seq as value,
+                   ;; not (rand-int 1000000), to guarantee uniqueness within the list.
+                   (let [seq      (alloc-seq! k)
+                         key-path (format "jepsen/%s/%09d" (name k) seq)]
+                     (if (wyrd-put! key-path seq)
+                       (do
+                         (record-write! k seq key-path seq)
+                         [f k seq])
+                       ;; Put failed (e.g. nemesis killed a server mid-write and not
+                       ;; enough fragments could be placed, or redb contention resolved
+                       ;; with an error rather than a wait). Propagate as a hard error
+                       ;; so Jepsen marks the operation :fail.
+                       (throw (ex-info "wyrd put failed"
+                                       {:key key-path :slot k :val seq}))))
+
+                   :r
+                   ;; Retrieve all known successfully-written values for this slot.
+                   ;; Uses atom-tracked key list (no `wyrd ls` — the CLI has no list cmd).
+                   ;;
+                   ;; Fix from iteration-2 carry-forward issue #3:
+                   ;; A partial read (some gets failed while nemesis is active) is NOT
+                   ;; recorded as :ok. We throw an exception so the outer catch block
+                   ;; records this transaction as :fail. A partial observation must not
+                   ;; be fed to Elle as a successful read — it can create false anomalies
+                   ;; or mask real ones (advisory: jepsen/src/wyrd/jepsen.clj:237, v2).
+                   (let [history (slot-history k)]
+                     (if (empty? history)
+                       [f k nil]
+                       (let [vals (mapv
+                                   (fn [{:keys [key val]}]
+                                     (let [read-val (wyrd-get! key)]
+                                       (when (and read-val (not= (str val) read-val))
+                                         ;; Data corruption: got wrong value back.
+                                         (throw (ex-info "data integrity violation"
+                                                         {:key key :expected val :got read-val})))
+                                       ;; Return nil if get failed (nemesis still active),
+                                       ;; or val on success (erasure reconstruction worked).
+                                       (when read-val val)))
+                                   history)
+                             readable (filterv some? vals)]
+                         ;; FIX: Partial read → :fail.
+                         ;; If any get returned nil (server down or reconstructing),
+                         ;; throw so the transaction is recorded as :fail, not :ok.
+                         ;; Elle must not see a partial observation as a successful read.
+                         (when (< (count readable) (count vals))
+                           (throw (ex-info "partial read: some gets unavailable during nemesis"
+                                           {:slot k
+                                            :readable (count readable)
+                                            :total    (count vals)})))
+                         ;; Full read: all values observable. Return the list.
+                         [f k (when (seq readable) readable)])))
+
+                   (throw (ex-info "unknown op" {:f f}))))
+               txn)]
+          (assoc op :type :ok :value result))
+        (catch Exception e
+          (log/warn "op failed:" op "->" (ex-message e))
+          (assoc op :type :fail :error (ex-message e))))))
+
+  (teardown! [this _test] this)
+  (close! [this _test] this))
+
+(defn wyrd-client [] (map->WyrdClient {}))
+
+;; ─── DB (cluster managed by CI compose step) ──────────────────────────────────
+
+(defrecord WyrdDB []
+  db/DB
+
+  (setup! [_ _test node]
+    (log/info "Wyrd D-server cluster assumed to be running (started by CI compose step);"
+              "node:" node))
+
+  (teardown! [_ _test node]
+    (log/info "Leaving cluster teardown to the CI compose step; node:" node))
+
+  db/LogFiles
+  (log-files [_ _test _node] []))
+
+(defn wyrd-db [] (map->WyrdDB {}))
+
+;; ─── Crash nemesis (docker kill / docker start) ──────────────────────────────
+;; Kills a D-server container and restarts it with empty /data (tmpfs).
+;; After the restart the server has NO fragment data — all chunks previously
+;; placed on it are now missing on that server. The custodian step (run after
+;; :heal) detects missing fragments and drives reconstruction.
+
+(defn- container-name [n]
+  (str container-prefix n))
+
+(defn- kill-container! [n]
+  (log/info "crash nemesis: docker kill" (container-name n))
+  (let [r (sh "docker" "kill" (container-name n))]
+    (when-not (= 0 (:exit r))
+      (log/warn "docker kill exit" (:exit r) ":" (:err r)))
+    r))
+
+(defn- start-container! [n]
+  (log/info "crash nemesis: docker start" (container-name n))
+  (let [r (sh "docker" "start" (container-name n))]
+    (when-not (= 0 (:exit r))
+      (log/warn "docker start exit" (:exit r) ":" (:err r)))
+    r))
+
+(defn crash-nemesis
+  "A nemesis that kills and restarts a random D-server container.
+   On :kill — picks a random server 1..dserver-count and kills it.
+   On :heal — starts the previously killed server and runs the custodian step.
+
+   The custodian step (jepsen_custodian_step.rs):
+   1. Detects missing fragments on the restarted server (empty /data after tmpfs reset).
+   2. Enqueues repair obligations via `repair::enqueue_repair`.
+   3. Drives `reconcile_step` → `reconstruction::reconcile` (the production path).
+   4. Asserts `Reconciled::Changed` (reconstruction actually fired)."
+  []
+  (let [killed-server (atom nil)]
+    (reify nemesis/Nemesis
+      (setup! [this _test] this)
+
+      (invoke! [this _test op]
+        (case (:f op)
+          :kill
+          (let [n (inc (rand-int dserver-count))]
+            (reset! killed-server n)
+            (kill-container! n)
+            (assoc op :type :info :value {:killed (container-name n)}))
+
+          :heal
+          (if-let [n @killed-server]
+            (do
+              (start-container! n)
+              ;; Wait briefly for the D-server to finish binding its listener.
+              (Thread/sleep 3000)
+              ;; Run the custodian reconstruction step: detects missing fragments
+              ;; on the restarted server (empty /data after tmpfs reset), enqueues
+              ;; repair obligations, and drives the production `reconcile_step`
+              ;; → `reconstruction::reconcile` path.
+              (run-custodian-step!)
+              (reset! killed-server nil)
+              (assoc op :type :info :value {:healed (container-name n)}))
+            (assoc op :type :info :value :no-server-killed))
+
+          ;; Unknown nemesis op.
+          (assoc op :type :info :value {:unknown-op (:f op)})))
+
+      (teardown! [this _test]
+        ;; Ensure any killed server is restarted on teardown.
+        (when-let [n @killed-server]
+          (log/info "crash nemesis teardown: restarting" (container-name n))
+          (start-container! n)
+          (reset! killed-server nil))
+        this))))
+
+;; ─── Partition nemesis (docker network disconnect / connect) ──────────────────
+;; Disconnects a D-server container from the Docker Compose network, simulating
+;; a network partition. The partitioned server is unreachable for new writes,
+;; but its /data is intact (tmpfs data persists across disconnect/reconnect).
+;;
+;; This nemesis tests the consistency property under partial availability:
+;; during the partition, reads must still observe only committed values and
+;; Elle must detect no anomalies.
+;;
+;; Fix from iteration-2 carry-forward issue #1: adds the required partition
+;; nemesis (advisory: jepsen/src/wyrd/jepsen.clj:357, v2 — only kill/heal).
+
+(defn- disconnect-network! [n]
+  (log/info "partition nemesis: docker network disconnect" compose-network (container-name n))
+  (let [r (sh "docker" "network" "disconnect" compose-network (container-name n))]
+    (when-not (= 0 (:exit r))
+      (log/warn "docker network disconnect exit" (:exit r) ":" (:err r)))
+    r))
+
+(defn- reconnect-network! [n]
+  (log/info "partition nemesis: docker network connect" compose-network (container-name n))
+  (let [r (sh "docker" "network" "connect" compose-network (container-name n))]
+    (when-not (= 0 (:exit r))
+      (log/warn "docker network connect exit" (:exit r) ":" (:err r)))
+    r))
+
+(defn partition-nemesis
+  "A nemesis that disconnects and reconnects a random D-server container from/to
+   the Docker Compose network.
+
+   On :partition — picks a random server 1..dserver-count and disconnects it
+   from the `compose-network`. The partitioned server cannot receive new gRPC
+   fragment writes from the host; writes that would place a fragment on it fail.
+   Reads can still succeed using fragments from the remaining 4 servers (k=3 ≤ 4).
+
+   On :reconnect — reconnects the previously partitioned server. Its /data is
+   intact; no reconstruction is needed (the partition did not cause data loss).
+
+   This tests the consistency property: Elle must not detect anomalies in the
+   observed read history during a partition where some writes fail."
+  []
+  (let [partitioned-server (atom nil)]
+    (reify nemesis/Nemesis
+      (setup! [this _test] this)
+
+      (invoke! [this _test op]
+        (case (:f op)
+          :partition
+          (let [n (inc (rand-int dserver-count))]
+            (reset! partitioned-server n)
+            (disconnect-network! n)
+            (assoc op :type :info :value {:partitioned (container-name n)}))
+
+          :reconnect
+          (if-let [n @partitioned-server]
+            (do
+              (reconnect-network! n)
+              ;; Brief pause to let the network stabilise and gRPC reconnect.
+              (Thread/sleep 2000)
+              (reset! partitioned-server nil)
+              (assoc op :type :info :value {:reconnected (container-name n)}))
+            (assoc op :type :info :value :no-server-partitioned))
+
+          (assoc op :type :info :value {:unknown-op (:f op)})))
+
+      (teardown! [this _test]
+        ;; Ensure any partitioned server is reconnected on teardown.
+        (when-let [n @partitioned-server]
+          (log/info "partition nemesis teardown: reconnecting" (container-name n))
+          (reconnect-network! n)
+          (reset! partitioned-server nil))
+        this))))
+
+;; ─── Combined nemesis (crashes + partitions) ─────────────────────────────────
+;; Composes the crash nemesis (kill/heal) and the partition nemesis
+;; (partition/reconnect) via `nemesis/compose`. This satisfies the brief's
+;; requirement of "partitions + crashes" (proposal 0005 §13.2, `0005:408`).
+
+(defn combined-nemesis
+  "Combines the crash (kill/heal) and partition (partition/reconnect) nemeses.
+   `nemesis/compose` dispatches each op to the correct sub-nemesis by its :f key."
+  []
+  (nemesis/compose
+   {{:kill :kill, :heal :heal}               (crash-nemesis)
+    {:partition :partition, :reconnect :reconnect} (partition-nemesis)}))
+
+;; ─── Generator ────────────────────────────────────────────────────────────────
+
+(def slot-count 5)
+
+(defn- rand-slot []
+  (keyword (str "slot" (rand-int slot-count))))
+
+(defn workload-ops
+  "A lazy sequence of :append and :r micro-transactions over a small key space.
+   80% appends drive the repair path; 20% reads observe the version history.
+
+   The value field for :append ops is nil — the actual value (the per-slot seq
+   number) is determined at invoke! time by `alloc-seq!` to ensure uniqueness.
+   Fix from iteration-3 carry-forward item 5: seq used as value in invoke!,
+   not (rand-int 1000000), to guarantee unique appended elements within each slot."
+  []
+  (repeatedly
+   (fn []
+     {:type  :invoke
+      :f     :txn
+      :value (if (< (rand) 0.8)
+               [[:append (rand-slot) nil]]  ; value determined by seq in invoke!
+               [[:r (rand-slot) nil]])})))
+
+(def nemesis-generator
+  "Generator cycling through crash (kill/heal) and partition (partition/reconnect)
+   nemesis phases. Each crash cycle exercises the reconstruction path; each
+   partition cycle exercises consistency under partial availability."
+  (gen/cycle
+   [;; ── Crash cycle (kill + heal): tests reconstruction ─────────────────────
+    ;; Kill a server, wait for reads to detect the missing fragments via
+    ;; read-around (RS(3,2): 4 of 5 survive, k=3 still satisfied), then
+    ;; heal: restart the server with empty /data and run the custodian step.
+    (gen/sleep 5)
+    {:type :info :f :kill}
+    (gen/sleep 30)   ; workload continues: reads succeed (4/5 fragments); puts fail
+    {:type :info :f :heal}
+    (gen/sleep 10)   ; custodian step runs: detect + enqueue + reconcile (reconstruction)
+
+    ;; ── Partition cycle (partition + reconnect): tests consistency ───────────
+    ;; Disconnect a server's network; writes that need it will fail (all-or-none
+    ;; fragment placement). Reads succeed using the 4 connected servers.
+    ;; After reconnect the server rejoins with its data intact; no repair needed.
+    (gen/sleep 5)
+    {:type :info :f :partition}
+    (gen/sleep 30)   ; workload continues during partition; writes may fail
+    {:type :info :f :reconnect}
+    (gen/sleep 10)   ; server back online; Elle checks for consistency anomalies
+    ]))
+
+;; ─── Checker ──────────────────────────────────────────────────────────────────
+
+(defn wyrd-checker
+  "Wraps Elle's list-append checker to assert strict serializability over the
+   repair history. Elle detects stale reads, torn reads, and version cycles —
+   exactly the anomaly classes ADR-0015 prohibits."
+  []
+  (reify checker/Checker
+    (check [_ _test history opts]
+      (la/check
+       {:consistency-models [:strict-serializable]
+        :anomalies          [:G1 :G2]
+        :directory          (str (:store _test "/tmp/jepsen-store") "/elle")}
+       history))))
+
+;; ─── Test map ─────────────────────────────────────────────────────────────────
+
+(defn wyrd-test
+  "Assemble the Jepsen test map for the Wyrd Tier-1 consistency campaign."
+  [opts]
+  (merge
+   tests/noop-test
+   opts
+   {:name        "wyrd-jepsen-tier1"
+    :db          (wyrd-db)
+    :client      (wyrd-client)
+    :nemesis     (combined-nemesis)  ; crashes + partitions (brief §Success criterion)
+    ;; Fix from iteration-3 carry-forward T5: use :concurrency 5 (one worker per
+    ;; slot on average) to give Elle genuinely interleaved histories.
+    ;; Concurrent reads are free (redb multiple-reader semantics; wyrd-get! is
+    ;; read-only on the metadata). Concurrent writes serialize through the redb
+    ;; file lock — the loser WAITS, so puts don't fail due to lock contention.
+    ;; With 5 workers, reads and appends overlap in time, creating the interleaved
+    ;; history Elle needs to verify consistency (not a trivially-sequential log).
+    :concurrency 5
+    :checker     (checker/compose
+                  {:list-append (wyrd-checker)
+                   :timeline    (timeline/html)})
+    :generator   (gen/phases
+                  ;; Warm-up: seed the cluster before any fault injection.
+                  (->> (gen/seq (workload-ops))
+                       (gen/stagger 1/10)
+                       (gen/time-limit 30))
+                  ;; Fault phase: inject crashes + partitions while client continues.
+                  (gen/nemesis
+                   nemesis-generator
+                   (->> (gen/seq (workload-ops))
+                        (gen/stagger 1/10)
+                        (gen/time-limit 120)))
+                  ;; Quiesce: stop nemesis, drain in-flight operations.
+                  (gen/nemesis
+                   (gen/phases {:type :info :f :heal}
+                               {:type :info :f :reconnect}
+                               (gen/sleep 15)))
+                  ;; Final reads: verify all written values are readable post-repair.
+                  (->> (gen/seq (map (fn [s] {:type :invoke :f :txn
+                                              :value [[:r (keyword (str "slot" s)) nil]]})
+                                     (range slot-count)))
+                       (gen/stagger 1/5)))}))
+
+;; ─── Entry point ──────────────────────────────────────────────────────────────
+
+(defn -main
+  "Jepsen CLI entry point: `lein run test` (or `lein run -- --help`)."
+  [& args]
+  (cli/run!
+   (merge (cli/single-test-cmd {:test-fn wyrd-test})
+          (cli/serve-cmd))
+   args))
