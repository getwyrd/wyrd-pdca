index 0000000..235197d
--- /dev/null
+++ b/jepsen/test/wyrd/checker_test.clj
@@ -0,0 +1,77 @@
+(ns wyrd.checker-test
+  "Elle checker self-test for the Wyrd Jepsen harness (issue #250).
+
+   Verifies that the Elle list-append checker correctly:
+   1. ACCEPTS a clean history (no anomalies → :valid? = true)
+   2. REJECTS a history with a planted version-cycle anomaly (G2 → :valid? = false)
+
+   No live cluster or `lein run` needed — runs via `lein test` in CI.
+
+   Fix from iteration-1 carry-forward issue #5:
+   `:valid?` is a BOOLEAN (true/false), not the keyword `:valid`.
+   Use `(true? (:valid? result))` and `(false? (:valid? result))` for correct
+   comparisons."
+  (:require
+   [clojure.test :refer [deftest is testing]]
+   [elle.list-append :as la]))
+
+;; ─── Clean history (Elle must accept) ────────────────────────────────────────
+;;
+;; Two appends to slot :x followed by a read that sees both values in order.
+;; This is a trivially consistent history; Elle must return :valid? = true.
+
+(def clean-history
+  [{:type :invoke :process 0 :f :txn :value [[:append :x 1]]}
+   {:type :ok     :process 0 :f :txn :value [[:append :x 1]]}
+   {:type :invoke :process 0 :f :txn :value [[:append :x 2]]}
+   {:type :ok     :process 0 :f :txn :value [[:append :x 2]]}
+   {:type :invoke :process 0 :f :txn :value [[:r :x nil]]}
+   {:type :ok     :process 0 :f :txn :value [[:r :x [1 2]]]}])
+
+(deftest clean-history-passes-elle
+  (testing "Elle accepts a clean, consistent list-append history"
+    (let [result (la/check
+                  {:consistency-models [:strict-serializable]
+                   :anomalies          [:G1 :G2]}
+                  clean-history)]
+      ;; Fix from iteration-1 issue #5: `:valid?` is a boolean, not the keyword
+      ;; `:valid`. Use `(true? ...)` — NOT `(= :valid (:valid? result))`.
+      (is (true? (:valid? result))
+          (str "Elle must accept a clean history; result: " (pr-str result))))))
+
+;; ─── Anomalous history (Elle must reject) ────────────────────────────────────
+;;
+;; A planted version-cycle anomaly: process 0 reads slot :x as [1], then
+;; process 1 reads slot :x as [2, 1]. The second read claims 2 was appended
+;; BEFORE 1 (because [2, 1] implies 2 ≺ 1 in the list), but the first read
+;; saw only [1] (implying 1 was the only value at that point). These two reads
+;; are inconsistent: no single linearizable append order can explain both
+;; [1] and [2, 1] being observed versions of the same slot at the same time.
+;; Elle must detect this as a G-nonadjacent or G2 anomaly → :valid? = false.
+
+(def anomalous-history
+  [{:type :invoke :process 0 :f :txn :value [[:append :x 1]]}
+   {:type :ok     :process 0 :f :txn :value [[:append :x 1]]}
+   {:type :invoke :process 1 :f :txn :value [[:append :x 2]]}
+   {:type :ok     :process 1 :f :txn :value [[:append :x 2]]}
+   ;; Process 0 reads [1] — does not see 2 yet (consistent with append order 1→2).
+   {:type :invoke :process 0 :f :txn :value [[:r :x nil]]}
+   {:type :ok     :process 0 :f :txn :value [[:r :x [1]]]}
+   ;; Process 1 reads [2 1] — implies 2 was appended BEFORE 1 (2 ≺ 1 in list order).
+   ;; This contradicts the above: 1 must be before 2 (process 0 saw only 1), but
+   ;; here the list claims 2 is before 1. A version cycle: 1 ≺ 2 (from first read)
+   ;; AND 2 ≺ 1 (from second read). Elle must flag this as an anomaly.
+   {:type :invoke :process 1 :f :txn :value [[:r :x nil]]}
+   {:type :ok     :process 1 :f :txn :value [[:r :x [2 1]]]}])
+
+(deftest anomalous-history-fails-elle
+  (testing "Elle rejects a history with a planted version-cycle anomaly"
+    (let [result (la/check
+                  {:consistency-models [:strict-serializable]
+                   :anomalies          [:G1 :G2]}
+                  anomalous-history)]
+      ;; Fix from iteration-1 issue #5: `:valid?` is a boolean.
+      ;; Use `(false? ...)` — NOT `(not= :valid (:valid? result))`.
+      (is (false? (:valid? result))
+          (str "Elle must reject a history with a version-cycle anomaly; "
+               "result: " (pr-str result))))))
