+# Tier-1 Jepsen consistency harness cluster (issue #250, proposal 0005 §13.2).
+#
+# 5 D-server containers for the Jepsen consistency test with RS(3,2) erasure coding.
+# Each container uses tmpfs for /data so that a `docker kill` + `docker start` gives
+# a fresh data directory — enabling the crash nemesis to simulate real data loss
+# while reusing the same container and host-port binding.
+#
+# For the network-partition nemesis, containers are disconnected from / reconnected
+# to the Docker Compose default network (wyrd-jepsen_default) via
+# `docker network disconnect/connect`.
+#
+# Container names (project wyrd-jepsen, service dserver):
+#   wyrd-jepsen-dserver-1 ... wyrd-jepsen-dserver-5
+#
+# Usage (from the workspace root):
+#   docker compose -p wyrd-jepsen -f jepsen/docker-compose.yml up -d --build --scale dserver=5
+#
+# Resolve ephemeral host ports after start:
+#   for n in $(seq 1 5); do
+#     PORT=$(docker compose -p wyrd-jepsen -f jepsen/docker-compose.yml \
+#              port --index $n dserver 50051 | cut -d: -f2)
+#     ENDPOINTS="${ENDPOINTS}http://127.0.0.1:${PORT},"
+#   done
+#   ENDPOINTS="${ENDPOINTS%,}"
+services:
+  dserver:
+    build:
+      # Build context is the workspace root so the whole crate graph is available.
+      # Reuses the same multi-stage Dockerfile as the Tier-2 kill-reconstruct test.
+      context: ..
+      dockerfile: crates/chunkstore-grpc/tests/dserver/Dockerfile
+    image: wyrd-dserver:jepsen
+    command: ["d-server", "--bind", "0.0.0.0:50051", "--data-dir", "/data"]
+    # tmpfs for /data: the data is ephemeral — a `docker kill` + `docker start`
+    # restarts the container with an empty /data, simulating a node that lost all
+    # its fragment data (the crash nemesis' data-loss scenario for the repair-path
+    # test). The network-partition nemesis leaves /data intact (only disconnects
+    # the container from the compose network).
+    tmpfs:
+      - /data:size=512m
+    # Target-only port: Docker assigns a free host port per replica (no clashes
+    # under --scale), which the CI workflow reads back with `docker compose port`.
+    ports:
+      - "50051"
