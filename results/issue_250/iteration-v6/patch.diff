+name: tier1-jepsen
+
+# **Tier-1 consistency-over-repair campaign** (M3, issue #250, proposal 0005 §13.2,
+# `0005:408`): drive the production custodian reconstruction path
+# (`custodian::reconcile_step` → `reconstruction::reconcile`) against a real
+# containerized RS(6,3) D-server cluster, inject a crash (commit-intercept via
+# `CrashMeta`) and kill server 0, then assert the ADR-0015 consistency contract
+# over the repair path.
+#
+# ADR-0015 contract properties verified:
+#   1. No torn reads — committed placement is always fully old or fully new, never a
+#      hybrid (`0005:277`, `0005:385-389`).
+#   2. Read-after-commit — after `Reconciled::Changed`, committed metadata immediately
+#      reflects the new placement (no stale reads).
+#   3. Commit-point-atomic repair — crash/partition before commit leaves the inode
+#      fully old and a collectable orphan on the spare, never corruption.
+#
+# This job is the **deferred-posture** leg of the M3 consistency campaign: the harness
+# is compiled and type-checked at Check by `cargo xtask ci`'s `cargo test --workspace`
+# (which compiles `#[ignore]`d bodies); this job provides the supplementary green
+# evidence that the harness runs correctly on a real node with a real Docker daemon.
+#
+# Modelled on `tier2-kill-reconstruct.yml` (#196). Not a required status check (it
+# needs a privileged container runtime); its value is post-merge regression visibility.
+# Opted in via WYRD_TIER1=1.
+#
+# Cron slot: 02:00 UTC — earlier than the existing staggered nightly jobs (disk-faults
+# at 03:00, integration-nightly at 04:00, kill-reconstruct at 05:00) to avoid runner
+# contention.
+
+on:
+  schedule:
+    # 02:00 UTC daily — offset from the other nightly jobs (03:00/04:00/05:00 UTC)
+    # to avoid runner contention.
+    - cron: "0 2 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier1-jepsen-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  jepsen:
+    runs-on: ubuntu-latest
+    # Cold image build + 10-server cluster + three-phase scenario fit well under this.
+    # Matches tier2-kill-reconstruct.yml's bound (#196).
+    timeout-minutes: 45
+    env:
+      CI: "true"
+      # Opt in to the Tier-1 consistency-over-repair scenario.
+      WYRD_TIER1: "1"
+    steps:
+      - uses: actions/checkout@v7
+
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # ubuntu-latest ships Docker with the compose plugin; this confirms the daemon
+      # is reachable (same check integration-nightly.yml and tier2-kill-reconstruct.yml
+      # use).
+      - name: Docker info
+        run: docker info
+
+      - name: cargo xtask jepsen
+        run: cargo xtask jepsen
+
+      # Surface container diagnostics captured by finalize_panic_safe before teardown
+      # (#150): `compose_logs` writes to target/tier2-logs/ on failure so the
+      # diagnostics survive compose_down.
+      - name: Upload container diagnostics
+        if: failure()
+        uses: actions/upload-artifact@v7
+        with:
+          name: tier1-jepsen-logs
+          path: target/tier2-logs/
+          if-no-files-found: ignore
+          retention-days: 14
