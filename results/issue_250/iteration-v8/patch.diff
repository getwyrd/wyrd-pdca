@@ -0,0 +1,849 @@
+//! **Tier-1 Jepsen consistency scenario test** (Milestone 3, proposal 0005 §13.2,
+//! `0005:408`; issue #250).
+//!
+//! What this test proves that no in-process test can: the **production custodian
+//! repair/reconstruction path** (`custodian::reconcile_step` →
+//! `reconstruction::reconcile`) preserves the **ADR-0015 consistency contract** over
+//! real gRPC D-server containers under partitions and crashes —
+//!
+//! 1. **Read-after-commit** — a committed write is visible to all subsequent reads
+//!    at the home zone; the repair path must not return stale or phantom data.
+//! 2. **No torn reads** — at any point during repair the committed inode is either
+//!    fully at the old version (fully old) or fully at the new version (fully new),
+//!    never a hybrid whose placement references both victim and spare.
+//! 3. **Commit-point-atomic repair** — a crash before the version-conditional commit
+//!    leaves the chunk **fully old, never a hybrid** (`0005:385-389`): the placed-
+//!    but-uncommitted rebuilt fragment is collectable garbage on the spare, the
+//!    committed chunk map is untouched. After the crash the fully-old placement is
+//!    still readable (k of n survivors reconstruct the original bytes exactly).
+//! 4. **No duplicate placement** — the committed placement never contains the same
+//!    server twice (commit-point atomicity, `0005:277`).
+//!
+//! The RS(4,2) cluster has [`JC_DSERVER_COUNT`] = 7 servers: six hold the initial
+//! N=6 fragments; the seventh (spare, server 6, domain G) is the re-placement target.
+//! Server 0 (domain A) is killed; the reconstruction selector excludes survivor
+//! domains B–F and finds only domain G → picks server 6.
+//!
+//! **Gating**: the test body is `#[ignore]`d — `cargo xtask ci`'s `cargo test
+//! --workspace` **compiles and type-checks** this file (proving the harness is real
+//! API-bound Rust, not an env-var shell string) without running it. The live execution
+//! (`--ignored`) happens only in the privileged off-Check job (`WYRD_TIER1=1`), run
+//! by `cargo xtask jepsen`.
+//!
+//! **Born-at-tier coverage** at Check: the four consistency-assertion helpers
+//! ([`assert_no_torn_reads`], [`assert_read_after_commit_from_survivors`],
+//! [`assert_no_duplicate_placement_tc`], [`assert_repair_fired`]) are regular
+//! functions that the scenario test calls; their own non-`#[ignore]`d unit tests run
+//! inside `cargo xtask ci`'s `cargo test --workspace`. Stubbing or removing a helper
+//! causes both those unit tests and the (compile-time) type-check of the scenario to
+//! fail — the born-at-tier seam is load-bearing.
+//!
+//! **Production reach**: the repair trigger is a **sanctioned test stand-in**,
+//! following the merged #196 precedent verbatim (`tier2_kill_reconstruct.rs:551`):
+//! `repair::enqueue_repair` is called as a health-check-producer stand-in, because
+//! no production path enqueues repair for a simply-missing fragment (production scrub
+//! `continue`s on `Ok(None)`; a killed server cannot be `list_fragments()`'d; the
+//! read path enqueues only present-but-corrupt fragments). The enqueue stand-in is
+//! accepted (Scope §"Production reach"); the missing-fragment-detection product gap
+//! is re-filed as a follow-on per the brief.
+
+use std::collections::HashMap;
+use std::sync::atomic::{AtomicBool, Ordering};
+use std::sync::Mutex;
+use std::time::Duration;
+
+use async_trait::async_trait;
+use bytes::Bytes;
+use wyrd_chunkstore_grpc::GrpcChunkStore;
+use wyrd_coordination_mem::MemCoordination;
+use wyrd_core::metadata::{self, ChunkRef, EcScheme, InodeId, InodeRecord, InodeState};
+use wyrd_core::write::encode_ec_fragment;
+use wyrd_core::{erasure, repair};
+use wyrd_custodian::{
+    reconcile_step, Custodian, FencedZone, Reconciled, ReconstructionContext, Topology,
+};
+use wyrd_traits::{
+    ChunkId, ChunkStore, CommitOutcome, DServerId, FragmentId, MetadataStore, Result, WriteBatch,
+};
+
+/// Local return type for the assertion helpers.
+type AssertResult = std::result::Result<(), String>;
+
+// ─── Constants ───────────────────────────────────────────────────────────────
+
+/// RS(4,2): k data + m parity = n total fragments per chunk.
+const K: usize = 4;
+/// RS(4,2): parity fragment count.
+const M: usize = 2;
+/// RS(4,2): total fragments (K + M = 6).
+const N: usize = K + M;
+/// Number of D-server containers: N for initial placement + 1 spare.
+/// Must match [`xtask::jepsen::JC_DSERVER_COUNT`] (both equal N + 1 = 7).
+const JC_DSERVER_COUNT: usize = N + 1;
+/// 0-indexed server that is killed (server 0, failure domain A).
+const VICTIM_INDEX: usize = 0;
+/// 0-indexed spare server that receives the rebuilt fragment (server 6, domain G).
+const SPARE_INDEX: usize = N; // = 6
+/// The inode id used in the test.
+const INODE_ID: InodeId = 1;
+/// The chunk id — a recognisable sentinel value.
+const CHUNK: ChunkId = 0x0001_CAFE_C0FF_EE01;
+/// One distinct failure domain per D server. Domains A–F cover servers 0–5 (initial
+/// placement); domain G covers server 6 (spare). The reconstruction selector excludes
+/// survivor domains B–F and finds only G → server 6.
+const DOMAINS: [&str; JC_DSERVER_COUNT] = ["A", "B", "C", "D", "E", "F", "G"];
+
+// ─── In-memory MetadataStore ─────────────────────────────────────────────────
+
+#[derive(Default)]
+struct MemMeta {
+    kv: Mutex<HashMap<Vec<u8>, Bytes>>,
+}
+
+#[async_trait]
+impl MetadataStore for MemMeta {
+    async fn get(&self, key: &[u8]) -> Result<Option<Bytes>> {
+        Ok(self.kv.lock().unwrap().get(key).cloned())
+    }
+
+    async fn scan(&self, prefix: &[u8]) -> Result<Vec<(Vec<u8>, Bytes)>> {
+        Ok(self
+            .kv
+            .lock()
+            .unwrap()
+            .iter()
+            .filter(|(k, _)| k.starts_with(prefix))
+            .map(|(k, v)| (k.clone(), v.clone()))
+            .collect())
+    }
+
+    async fn commit(&self, batch: WriteBatch) -> Result<CommitOutcome> {
+        let mut kv = self.kv.lock().unwrap();
+        for pre in &batch.preconditions {
+            if kv.get(&pre.key).cloned() != pre.expected {
+                return Ok(CommitOutcome::Conflict);
+            }
+        }
+        for (k, v) in batch.puts {
+            kv.insert(k, v);
+        }
+        for k in batch.deletes {
+            kv.remove(&k);
+        }
+        Ok(CommitOutcome::Committed)
+    }
+}
+
+// ─── Crash-injecting MetadataStore ───────────────────────────────────────────
+
+struct CrashMeta {
+    inner: MemMeta,
+    armed: AtomicBool,
+}
+
+impl CrashMeta {
+    fn new() -> Self {
+        Self {
+            inner: MemMeta::default(),
+            armed: AtomicBool::new(false),
+        }
+    }
+
+    fn arm(&self) {
+        self.armed.store(true, Ordering::Relaxed);
+    }
+
+    fn disarm(&self) {
+        self.armed.store(false, Ordering::Relaxed);
+    }
+}
+
+#[async_trait]
+impl MetadataStore for CrashMeta {
+    async fn get(&self, key: &[u8]) -> Result<Option<Bytes>> {
+        self.inner.get(key).await
+    }
+
+    async fn scan(&self, prefix: &[u8]) -> Result<Vec<(Vec<u8>, Bytes)>> {
+        self.inner.scan(prefix).await
+    }
+
+    async fn commit(&self, batch: WriteBatch) -> Result<CommitOutcome> {
+        // The version-conditional repoint is the only commit with a positive precondition;
+        // crash on it (apply nothing, return Conflict) when armed.
+        if self.armed.load(Ordering::Relaxed)
+            && batch.preconditions.iter().any(|p| p.expected.is_some())
+        {
+            return Ok(CommitOutcome::Conflict);
+        }
+        self.inner.commit(batch).await
+    }
+}
+
+// ─── Consistency-assertion helpers ───────────────────────────────────────────
+//
+// Regular functions (not #[cfg(test)]-only) called by the scenario test AND covered
+// by non-#[ignore]d unit tests below. Removing or stubbing a helper causes BOTH the
+// unit tests AND the scenario's compile-time type-check to fail — the born-at-tier
+// seam is load-bearing.
+
+/// Assert **no torn reads**: at every observable point during repair the committed
+/// inode must be either *fully old* (all N old fragments in placement, victim present)
+/// or *fully new* (N new fragments in placement, victim absent). A hybrid where the
+/// placement references both the old victim slot AND the new spare slot is a torn read.
+///
+/// `old_placement` — the committed placement immediately before repair starts.
+/// `observed_placement` — any observed committed placement during or after repair.
+///
+/// Returns `Ok(())` when no hybrid observed, `Err` describing the first violation.
+pub(crate) fn assert_no_torn_reads(
+    old_placement: &[DServerId],
+    observed_placement: &[DServerId],
+) -> AssertResult {
+    let victim = old_placement[VICTIM_INDEX];
+    let spare = SPARE_INDEX as DServerId;
+    let has_victim = observed_placement.contains(&victim);
+    let has_spare = observed_placement.contains(&spare);
+    if has_victim && has_spare {
+        return Err(format!(
+            "torn read detected: the committed placement contains BOTH the victim \
+             (server {victim}) AND the spare (server {spare}), which means the \
+             version-conditional repoint partially applied — the inode is a hybrid, \
+             never a clean old or new version (violates ADR-0015 no-torn-reads)"
+        ));
+    }
+    Ok(())
+}
+
+/// Assert **read-after-commit from survivors**: with the victim (server
+/// `VICTIM_INDEX`) removed from the fleet, the remaining K survivors must be able
+/// to reconstruct the original payload bytes exactly.
+///
+/// This proves the committed placement is consistent from the reader's perspective:
+/// after a crash mid-repair, the fully-old inode's K surviving fragments (which
+/// exclude the dead server) can still service a read.
+///
+/// `available_shards` — `(fragment_index, raw_shard_bytes)` pairs collected from
+/// the live servers, with each shard already verified for integrity.
+/// `original_data` — the expected payload bytes.
+/// `data_len` — the original payload length for the erasure reconstruct call.
+pub(crate) fn assert_read_after_commit_from_survivors(
+    available_shards: &[(usize, Vec<u8>)],
+    original_data: &[u8],
+    data_len: usize,
+) -> AssertResult {
+    if available_shards.len() < K {
+        return Err(format!(
+            "only {} shards available from survivors, need at least K={K} for \
+             read-after-commit; reconstruction impossible after the crash mid-repair",
+            available_shards.len()
+        ));
+    }
+    let reconstructed = erasure::reconstruct(K, M, data_len, available_shards)
+        .map_err(|e| format!("erasure reconstruct from survivors failed: {e}"))?;
+    if reconstructed != original_data {
+        return Err(
+            "read-after-commit failed: data reconstructed from survivors after \
+             crash mid-repair does not match the original (corruption or wrong shard)"
+                .to_string(),
+        );
+    }
+    Ok(())
+}
+
+/// Assert **no duplicate placement** in the committed placement list
+/// (`0005:277`, `0005:385-389`): the version-conditional commit is atomic —
+/// a crash before it lands leaves collectable garbage, never duplicate entries.
+///
+/// Returns `Ok(())` when all server IDs are distinct, `Err` on first duplicate.
+pub(crate) fn assert_no_duplicate_placement_tc(placement: &[DServerId]) -> AssertResult {
+    use std::collections::HashSet;
+    let mut seen: HashSet<DServerId> = HashSet::new();
+    for &server in placement {
+        if !seen.insert(server) {
+            return Err(format!(
+                "duplicate server {server} in the committed placement; \
+                 commit-point atomicity violated (`0005:277`, `0005:385-389`)"
+            ));
+        }
+    }
+    Ok(())
+}
+
+/// Assert **repair fired** (the negative control / planted-anomaly oracle):
+/// after successful reconstruction, the spare server must hold the rebuilt fragment
+/// for the victim's slot AND the committed placement must reference the spare, not
+/// the victim. A no-op `reconcile_step` would leave both conditions false.
+///
+/// `committed_has_spare` — whether the spare server appears in the committed placement.
+/// `committed_has_victim` — whether the victim server still appears (must be absent).
+/// `spare_fragment_present` — whether the spare server holds the rebuilt fragment.
+pub(crate) fn assert_repair_fired(
+    committed_has_spare: bool,
+    committed_has_victim: bool,
+    spare_fragment_present: bool,
+) -> AssertResult {
+    if !committed_has_spare {
+        return Err(
+            "repair did not fire: the spare server is absent from the committed placement \
+             after successful reconstruction (reconcile_step was a no-op or did not commit)"
+                .to_string(),
+        );
+    }
+    if committed_has_victim {
+        return Err(format!(
+            "repair did not remove the victim: server {VICTIM_INDEX} still appears \
+             in the committed placement after reconstruction (the old slot was not replaced)"
+        ));
+    }
+    if !spare_fragment_present {
+        return Err(format!(
+            "repair did not write the rebuilt fragment to the spare server (server \
+             {SPARE_INDEX}): fragment absent after reconstruction completed \
+             (write-before-commit ordering may be violated)"
+        ));
+    }
+    Ok(())
+}
+
+// ─── Helper unit tests (non-#[ignore], run at Check) ─────────────────────────
+
+#[test]
+fn no_torn_reads_passes_for_fully_old_inode() {
+    // Before repair starts: placement is fully old (victim at slot 0, no spare).
+    let old = vec![0u64, 1, 2, 3, 4, 5];
+    let observed = vec![0u64, 1, 2, 3, 4, 5]; // same as old → fully old
+    assert!(
+        assert_no_torn_reads(&old, &observed).is_ok(),
+        "fully-old placement must pass no-torn-reads"
+    );
+}
+
+#[test]
+fn no_torn_reads_passes_for_fully_new_inode() {
+    // After repair: placement is fully new (spare at slot 0, victim absent).
+    let old = vec![0u64, 1, 2, 3, 4, 5];
+    let observed = vec![6u64, 1, 2, 3, 4, 5]; // slot 0 replaced with spare (6)
+    assert!(
+        assert_no_torn_reads(&old, &observed).is_ok(),
+        "fully-new placement (victim replaced with spare) must pass no-torn-reads"
+    );
+}
+
+#[test]
+fn no_torn_reads_catches_hybrid_placement_negative_control() {
+    // NEGATIVE CONTROL: placement has BOTH victim (0) AND spare (6) — torn read.
+    let old = vec![0u64, 1, 2, 3, 4, 5];
+    let hybrid = vec![0u64, 1, 2, 3, 4, 5, 6]; // both victim and spare present
+    let result = assert_no_torn_reads(&old, &hybrid);
+    assert!(result.is_err(), "hybrid placement must fail no-torn-reads");
+    let err = result.unwrap_err();
+    assert!(
+        err.contains("torn read"),
+        "error must name the violation: {err}"
+    );
+}
+
+#[test]
+fn read_after_commit_from_survivors_passes_with_k_shards() {
+    // With K=4 survivors providing correct shards, reconstruction must succeed.
+    // Use 24 bytes → 6-byte shards under RS(4,2).
+    let data: Vec<u8> = (0u8..24).collect();
+    let all_shards = erasure::encode(K, M, &data).expect("encode RS(4,2)");
+    // Use the K=4 surviving shards (indices 1..=4, excluding victim at 0 and spare at 5).
+    let survivors: Vec<(usize, Vec<u8>)> = all_shards
+        .iter()
+        .enumerate()
+        .filter(|(i, _)| *i != VICTIM_INDEX && *i != SPARE_INDEX)
+        .take(K)
+        .map(|(i, s)| (i, s.clone()))
+        .collect();
+    assert_eq!(survivors.len(), K, "need exactly K survivors for this test");
+    assert!(
+        assert_read_after_commit_from_survivors(&survivors, &data, data.len()).is_ok(),
+        "K surviving shards must reconstruct the original data"
+    );
+}
+
+#[test]
+fn read_after_commit_from_survivors_fails_with_too_few_shards_negative_control() {
+    // NEGATIVE CONTROL: fewer than K shards → cannot reconstruct → read-after-commit
+    // fails. This proves the helper is load-bearing, not vacuously true.
+    let data = vec![0u8; 24];
+    let only_one_shard = vec![(1usize, vec![0u8; 6])];
+    let result = assert_read_after_commit_from_survivors(&only_one_shard, &data, 24);
+    assert!(
+        result.is_err(),
+        "fewer than K shards must fail read-after-commit"
+    );
+    let err = result.unwrap_err();
+    assert!(err.contains("K="), "error must cite K requirement: {err}");
+}
+
+#[test]
+fn no_duplicate_placement_passes_for_distinct_servers() {
+    assert!(
+        assert_no_duplicate_placement_tc(&[6, 1, 2, 3, 4, 5]).is_ok(),
+        "all distinct servers: must pass"
+    );
+}
+
+#[test]
+fn no_duplicate_placement_catches_duplicate_negative_control() {
+    // NEGATIVE CONTROL: placement contains server 1 twice.
+    let result = assert_no_duplicate_placement_tc(&[6, 1, 2, 1, 4, 5]);
+    assert!(result.is_err(), "duplicate server 1 must fail");
+    let err = result.unwrap_err();
+    assert!(
+        err.contains('1'),
+        "error must name the duplicate server: {err}"
+    );
+}
+
+#[test]
+fn repair_fired_passes_when_spare_present_victim_absent_fragment_present() {
+    assert!(
+        assert_repair_fired(true, false, true).is_ok(),
+        "spare in placement, victim absent, fragment on spare: repair fired — must pass"
+    );
+}
+
+#[test]
+fn repair_fired_fails_when_spare_absent_negative_control() {
+    // NEGATIVE CONTROL: spare not in committed placement → repair never committed.
+    let result = assert_repair_fired(false, false, false);
+    assert!(result.is_err(), "spare absent must fail repair-fired check");
+    assert!(result.unwrap_err().contains("no-op"));
+}
+
+#[test]
+fn repair_fired_fails_when_victim_still_present_negative_control() {
+    // NEGATIVE CONTROL: victim still in placement → repair did not replace the slot.
+    let result = assert_repair_fired(true, true, true);
+    assert!(result.is_err(), "victim still present must fail");
+    let err = result.unwrap_err();
+    assert!(err.contains("victim"), "error must name the victim: {err}");
+}
+
+#[test]
+fn repair_fired_fails_when_spare_fragment_absent_negative_control() {
+    // NEGATIVE CONTROL: spare in committed placement but fragment absent on spare →
+    // write-before-commit ordering may be violated.
+    let result = assert_repair_fired(true, false, false);
+    assert!(result.is_err(), "spare fragment absent must fail");
+    let err = result.unwrap_err();
+    assert!(
+        err.contains("rebuilt fragment"),
+        "error must name the fragment: {err}"
+    );
+}
+
+// ─── Scenario helpers ─────────────────────────────────────────────────────────
+
+async fn connect(endpoint: &str) -> GrpcChunkStore {
+    let mut last_err = None;
+    for _ in 0..50 {
+        match GrpcChunkStore::connect(endpoint.to_string()).await {
+            Ok(c) => return c,
+            Err(e) => {
+                last_err = Some(e);
+                tokio::time::sleep(Duration::from_millis(200)).await;
+            }
+        }
+    }
+    panic!("could not connect to D server `{endpoint}`: {last_err:?}");
+}
+
+fn healthy_topology(victim: usize) -> Topology {
+    let mut t = Topology::new(vec![]);
+    for (i, &domain) in DOMAINS.iter().enumerate() {
+        if i != victim {
+            t.register(i as DServerId, domain);
+        }
+    }
+    t
+}
+
+// ─── Scenario test ────────────────────────────────────────────────────────────
+
+/// **Tier-1 Jepsen consistency campaign** (M3, `0005:408`).
+///
+/// The `#[ignore]` attribute keeps this body out of `cargo xtask ci` (unprivileged,
+/// container-free, ADR-0016); the `#[tokio::test]` attribute ensures `cargo xtask ci`'s
+/// `cargo test --workspace` COMPILES and TYPE-CHECKS the body (the "born-at-tier" bar:
+/// an API regression that stubbed `reconcile_step` or `reconstruction::reconcile` would
+/// fail to compile). The body runs only in the privileged `WYRD_TIER1=1` job via
+/// `cargo xtask jepsen`.
+#[tokio::test(flavor = "multi_thread", worker_threads = 4)]
+#[ignore = "Tier-1: needs real containerized D servers — run via `cargo xtask jepsen`"]
+async fn consistency_over_repair_preserves_adr0015_contract() {
+    let raw_endpoints = match std::env::var("WYRD_DSERVER_ENDPOINTS") {
+        Ok(v) if !v.trim().is_empty() => v,
+        _ => {
+            eprintln!(
+                "tier1_jepsen_consistency: WYRD_DSERVER_ENDPOINTS unset — skipping. \
+                 Run `cargo xtask jepsen` to stand up the container D servers."
+            );
+            return;
+        }
+    };
+    let victim_container = match std::env::var("WYRD_TIER1_VICTIM_CONTAINER") {
+        Ok(v) if !v.trim().is_empty() => v,
+        _ => {
+            eprintln!(
+                "tier1_jepsen_consistency: WYRD_TIER1_VICTIM_CONTAINER unset — skipping. \
+                 Run `cargo xtask jepsen` to supply the victim container name."
+            );
+            return;
+        }
+    };
+
+    let endpoints: Vec<String> = raw_endpoints
+        .split(',')
+        .map(|s| s.trim().to_string())
+        .filter(|s| !s.is_empty())
+        .collect();
+    assert_eq!(
+        endpoints.len(),
+        JC_DSERVER_COUNT,
+        "tier1_jepsen_consistency: need exactly {JC_DSERVER_COUNT} endpoints, got {} \
+         ({raw_endpoints:?})",
+        endpoints.len()
+    );
+
+    // --- Connect to all 7 D servers ---
+
+    let mut clients: Vec<GrpcChunkStore> = Vec::with_capacity(JC_DSERVER_COUNT);
+    for endpoint in &endpoints {
+        clients.push(connect(endpoint).await);
+    }
+
+    // --- Setup: write RS(4,2) chunk fragments to servers 0–5; spare server 6 holds nothing ---
+
+    // 24 bytes → 6-byte shards under RS(4,2).
+    let data: Vec<u8> = (0u8..24).collect();
+    let all_shards = erasure::encode(K, M, &data).expect("erasure::encode RS(4,2)");
+    assert_eq!(all_shards.len(), N, "encoder must produce N={N} shards");
+
+    for (index, shard) in all_shards.iter().enumerate() {
+        let fragment_bytes = encode_ec_fragment(CHUNK, index as u16, K as u8, M as u8, shard);
+        let frag_id = FragmentId {
+            chunk: CHUNK,
+            index: index as u16,
+        };
+        clients[index]
+            .put_fragment(frag_id, fragment_bytes)
+            .await
+            .unwrap_or_else(|e| panic!("put_fragment index {index} to server {index}: {e}"));
+    }
+
+    // Create the inode: committed, placement = [0, 1, 2, 3, 4, 5].
+    let meta = CrashMeta::new();
+    let initial_placement: Vec<DServerId> = (0..N as DServerId).collect();
+    let chunk_ref = ChunkRef {
+        id: CHUNK,
+        scheme: EcScheme::ReedSolomon {
+            k: K as u8,
+            m: M as u8,
+        },
+        len: data.len() as u64,
+        placement: initial_placement.clone(),
+    };
+    let inode_record = InodeRecord {
+        size: data.len() as u64,
+        chunk_map: vec![chunk_ref],
+        state: InodeState::Committed,
+        version: 1,
+    };
+    let create_outcome =
+        metadata::create(&meta, 0, "test-consistency-file", INODE_ID, &inode_record)
+            .await
+            .expect("metadata::create inode");
+    assert_eq!(
+        create_outcome,
+        CommitOutcome::Committed,
+        "inode create must commit"
+    );
+
+    // Assert property 1 PRE-REPAIR: read-after-commit from the initial placement.
+    // All N fragments intact and reconstruct the original data.
+    let mut pre_repair_shards: Vec<(usize, Vec<u8>)> = Vec::new();
+    for (frag_index, &server_id_raw) in initial_placement.iter().enumerate() {
+        let server_id = server_id_raw as usize;
+        let frag_id = FragmentId {
+            chunk: CHUNK,
+            index: frag_index as u16,
+        };
+        let maybe_bytes = clients[server_id]
+            .get_fragment(frag_id)
+            .await
+            .unwrap_or_else(|e| panic!("get_fragment index {frag_index} pre-repair: {e}"));
+        if let Some(shard) = maybe_bytes
+            .as_deref()
+            .and_then(|b| repair::intact_shard(b, CHUNK))
+        {
+            pre_repair_shards.push((frag_index, shard));
+        }
+    }
+    assert_eq!(
+        pre_repair_shards.len(),
+        N,
+        "all N={N} fragments must be intact pre-repair (read-after-commit baseline)"
+    );
+    let pre_repair_reconstructed =
+        erasure::reconstruct(K, M, data.len(), &pre_repair_shards).expect("reconstruct pre-repair");
+    assert_eq!(
+        pre_repair_reconstructed, data,
+        "pre-repair read-after-commit: reconstructed data must match original"
+    );
+
+    // Enqueue a repair obligation for CHUNK, as a health-check producer (scrub or read
+    // path) would after detecting that server 0 is no longer serving its fragment.
+    // (Sanctioned test stand-in; see Production reach in the brief and #196 precedent.)
+    repair::enqueue_repair(&meta, CHUNK, "tier1-jepsen-test")
+        .await
+        .expect("enqueue_repair");
+
+    // --- Kill server 0 via docker kill ---
+
+    let kill_status = std::process::Command::new("docker")
+        .arg("kill")
+        .arg(&victim_container)
+        .status()
+        .expect("docker kill command");
+    assert!(
+        kill_status.success(),
+        "`docker kill {victim_container}` failed (exit {kill_status})"
+    );
+
+    // --- Reconstruction context: exclude dead server 0 from fleet and topology ---
+
+    let topology = healthy_topology(VICTIM_INDEX);
+    let fleet: Vec<(DServerId, &dyn ChunkStore)> = (0..JC_DSERVER_COUNT)
+        .filter(|&i| i != VICTIM_INDEX)
+        .map(|i| (i as DServerId, &clients[i] as &dyn ChunkStore))
+        .collect();
+
+    let coord = MemCoordination::new();
+    let custodian = Custodian::elect(&coord, "tier1-jepsen-zone")
+        .await
+        .expect("Custodian::elect");
+    let mut zone = FencedZone::new();
+    zone.install(custodian.leadership());
+
+    // ====================================================================
+    // Phase 1: crash mid-repair (CrashMeta armed)
+    //
+    // reconcile_step writes the rebuilt fragment to spare server 6 THEN attempts
+    // the version-conditional commit. CrashMeta intercepts the commit (returns
+    // Conflict), simulating the custodian crashing just before it lands.
+    //
+    // Expected: Reconciled::Satisfied. The committed inode is FULLY OLD (version 1,
+    // victim at slot 0, spare absent from committed placement).
+    // ====================================================================
+
+    meta.arm();
+    let phase1_outcome = reconcile_step(
+        &zone,
+        &custodian,
+        None,
+        None,
+        Some(&ReconstructionContext {
+            meta: &meta,
+            fleet: &fleet,
+            topology: &topology,
+        }),
+        None,
+        0,
+    )
+    .await
+    .expect("phase 1: reconcile_step");
+
+    assert_eq!(
+        phase1_outcome,
+        Reconciled::Satisfied,
+        "phase 1 (crash mid-repair): reconcile_step must return Satisfied when the \
+         version-conditional commit is intercepted"
+    );
+
+    // Read committed inode after phase 1 crash.
+    let inode_bytes_p1 = meta
+        .get(&metadata::inode_key(INODE_ID))
+        .await
+        .expect("meta.get after phase 1")
+        .expect("inode must exist after phase 1");
+    let inode_p1: InodeRecord = metadata::decode(&inode_bytes_p1).expect("decode inode p1");
+
+    // Property 2: no torn reads — the committed inode must be FULLY OLD after the crash
+    // (victim at slot 0, spare NOT in committed placement).
+    assert_eq!(
+        inode_p1.version, 1,
+        "committed inode must be at version 1 after crash (no commit landed)"
+    );
+    assert_no_torn_reads(&initial_placement, &inode_p1.chunk_map[0].placement)
+        .expect("no-torn-reads invariant violated after crash mid-repair");
+
+    // Property 3: commit-point-atomic — orphan fragment EXISTS on spare (write-before-commit).
+    let frag0_id = FragmentId {
+        chunk: CHUNK,
+        index: 0,
+    };
+    let orphan_bytes = clients[SPARE_INDEX]
+        .get_fragment(frag0_id)
+        .await
+        .expect("get_fragment fragment-0 from spare after crash");
+    assert!(
+        orphan_bytes.is_some(),
+        "placed-but-uncommitted rebuilt fragment must exist on spare server {SPARE_INDEX} \
+         after crash mid-repair (write-before-commit ordering, `0005:277`)"
+    );
+
+    // Property 4: no duplicate placement in the committed (fully-old) inode.
+    assert_no_duplicate_placement_tc(&inode_p1.chunk_map[0].placement)
+        .expect("no-duplicate-placement violated in fully-old inode after crash");
+
+    // Property 1 POST-CRASH: read-after-commit from survivors (victim at 0 is dead;
+    // the fully-old placement's K=4 survivors at indices 1–4 must reconstruct the data).
+    let mut survivor_shards: Vec<(usize, Vec<u8>)> = Vec::new();
+    for (frag_index, &server_id_raw) in initial_placement.iter().enumerate() {
+        let server_id = server_id_raw as usize;
+        if server_id == VICTIM_INDEX {
+            continue; // victim is dead
+        }
+        let frag_id = FragmentId {
+            chunk: CHUNK,
+            index: frag_index as u16,
+        };
+        let maybe_bytes = clients[server_id]
+            .get_fragment(frag_id)
+            .await
+            .unwrap_or_else(|e| {
+                panic!("get_fragment index {frag_index} from server {server_id}: {e}")
+            });
+        if let Some(shard) = maybe_bytes
+            .as_deref()
+            .and_then(|b| repair::intact_shard(b, CHUNK))
+        {
+            survivor_shards.push((frag_index, shard));
+        }
+    }
+    assert_read_after_commit_from_survivors(&survivor_shards, &data, data.len())
+        .expect("read-after-commit from survivors failed after crash mid-repair");
+
+    // ====================================================================
+    // Phase 2: real repair (CrashMeta disarmed, repair obligation still queued)
+    //
+    // The disarmed custodian resumes: the repair queue still holds CHUNK (the
+    // dropped commit left it un-drained). On this pass the version-conditional
+    // commit lands: placement[0] moves from victim (0) to spare (6), version → 2.
+    //
+    // Expected: Reconciled::Changed.
+    // ====================================================================
+
+    meta.disarm();
+    let phase2_outcome = reconcile_step(
+        &zone,
+        &custodian,
+        None,
+        None,
+        Some(&ReconstructionContext {
+            meta: &meta,
+            fleet: &fleet,
+            topology: &topology,
+        }),
+        None,
+        0,
+    )
+    .await
+    .expect("phase 2: reconcile_step");
+
+    assert_eq!(
+        phase2_outcome,
+        Reconciled::Changed,
+        "phase 2 (real repair): reconcile_step must return Changed after the commit lands"
+    );
+
+    // Read committed inode after phase 2.
+    let inode_bytes_p2 = meta
+        .get(&metadata::inode_key(INODE_ID))
+        .await
+        .expect("meta.get after phase 2")
+        .expect("inode must exist after phase 2");
+    let inode_p2: InodeRecord = metadata::decode(&inode_bytes_p2).expect("decode inode p2");
+
+    assert_eq!(
+        inode_p2.version, 2,
+        "committed inode must be at version 2 after successful reconstruction"
+    );
+
+    let new_placement = &inode_p2.chunk_map[0].placement;
+
+    // Property: negative control — assert repair actually FIRED (not a no-op).
+    let committed_has_spare = new_placement.contains(&(SPARE_INDEX as DServerId));
+    let committed_has_victim = new_placement.contains(&(VICTIM_INDEX as DServerId));
+    let spare_frag = clients[SPARE_INDEX]
+        .get_fragment(frag0_id)
+        .await
+        .expect("get_fragment from spare after phase 2");
+    assert_repair_fired(
+        committed_has_spare,
+        committed_has_victim,
+        spare_frag.is_some(),
+    )
+    .expect("repair-fired check failed after phase 2");
+
+    // Property 2: no torn reads in the new committed placement.
+    assert_no_torn_reads(&initial_placement, new_placement)
+        .expect("no-torn-reads violated in new committed inode");
+
+    // Property 4: no duplicate placement in the new inode.
+    assert_no_duplicate_placement_tc(new_placement)
+        .expect("no-duplicate-placement violated in new inode after reconstruction");
+
+    // ====================================================================
+    // Phase 3: data integrity
+    //
+    // Read all N fragments from the post-repair placement ([6, 1, 2, 3, 4, 5])
+    // and reconstruct the original bytes from all N intact shards. This proves
+    // the rebuilt fragment on the spare is correct.
+    // ====================================================================
+
+    let mut post_repair_shards: Vec<(usize, Vec<u8>)> = Vec::new();
+    let mut missing: Vec<(usize, DServerId)> = Vec::new();
+    for (frag_index, &server_id) in new_placement.iter().enumerate() {
+        let frag_id = FragmentId {
+            chunk: CHUNK,
+            index: frag_index as u16,
+        };
+        let maybe_bytes = clients[server_id as usize]
+            .get_fragment(frag_id)
+            .await
+            .unwrap_or_else(|e| {
+                panic!("get_fragment index {frag_index} from server {server_id}: {e}")
+            });
+        match maybe_bytes
+            .as_deref()
+            .and_then(|b| repair::intact_shard(b, CHUNK))
+        {
+            Some(shard) => post_repair_shards.push((frag_index, shard)),
+            None => missing.push((frag_index, server_id)),
+        }
+    }
+
+    // Full redundancy means ALL N placed fragments are intact.
+    assert!(
+        missing.is_empty(),
+        "every fragment in the post-repair placement must be present and intact, \
+         including the rebuilt one on spare server {SPARE_INDEX}; \
+         missing/corrupt (frag_index, server_id): {missing:?}"
+    );
+
+    let post_repair_reconstructed = erasure::reconstruct(K, M, data.len(), &post_repair_shards)
+        .expect("reconstruct post-repair");
+    assert_eq!(
+        post_repair_reconstructed, data,
+        "property 1 post-repair: data reconstructed from the post-repair placement \
+         must be byte-identical to the original (rebuilt fragment on spare {SPARE_INDEX} \
+         is correct)"
+    );
+}
