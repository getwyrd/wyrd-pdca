+name: tier1-jepsen
+
+# **Tier-1 Jepsen consistency campaign** (M3, proposal 0005 §13.2, `0005:408`,
+# issue #250): assert the **ADR-0015 consistency contract** over the production
+# `custodian::reconcile_step` → `reconstruction::reconcile` path against a real
+# containerized D-server cluster under partitions and crashes.
+#
+# Three campaign properties (ADR-0015):
+#   1. Read-after-commit — a committed write is visible to all subsequent reads;
+#      the repair path must not return stale or phantom data.
+#   2. No torn reads — at every observable point during repair the committed inode
+#      is either fully old (victim present, spare absent) or fully new (spare
+#      present, victim absent); never a hybrid of both.
+#   3. Commit-point-atomic repair — a crash before the version-conditional commit
+#      leaves the inode FULLY OLD (the placed-but-uncommitted rebuilt fragment on
+#      the spare is collectable garbage, not a duplicate committed entry).
+#   4. No duplicate placement — the committed placement never contains the same
+#      server twice (`0005:277`, `0005:385-389`).
+#
+# The RS(4,2) cluster (7 servers: 6 for initial N=6 placement + 1 spare) is
+# started via docker-compose (the same compose file as the Tier-2 integration and
+# kill-reconstruct jobs, scaled to 7 servers). The scenario test
+# (`crates/chunkstore-grpc/tests/tier1_jepsen_consistency.rs`) receives the
+# resolved endpoints via `WYRD_DSERVER_ENDPOINTS` and the victim container name
+# via `WYRD_TIER1_VICTIM_CONTAINER`.
+#
+# This job is the **deferred-posture** leg of the M3 Jepsen consistency milestone:
+# the scenario test is compiled and type-checked at Check by `cargo xtask ci`'s
+# `cargo test --workspace` (which compiles `#[ignore]`d bodies); this job provides
+# the supplementary green evidence that the harness runs correctly against a real
+# live cluster. Not a required merge-gate status check (needs Docker + privileged
+# containers); its value is post-merge regression visibility.
+#
+# Opted in via `WYRD_TIER1=1`. Modelled on `tier2-kill-reconstruct.yml` (M3.8,
+# proposal 0005 §13.2, `0005:409-411`).
+
+on:
+  schedule:
+    # 02:00 UTC daily (before tier1-disk-faults at 03:00 and integration-nightly
+    # at 04:00; offset avoids runner contention).
+    - cron: "0 2 * * *"
+  workflow_dispatch: {}
+
+permissions:
+  contents: read
+
+concurrency:
+  group: tier1-jepsen-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  jepsen:
+    runs-on: ubuntu-latest
+    # Cold image build + 7-server cluster + three-phase consistency scenario
+    # (write / crash-mid-repair / real-repair) fit under this bound.
+    # Mirrors tier2-kill-reconstruct.yml's 45-minute timeout.
+    timeout-minutes: 45
+    env:
+      CI: "true"
+      # Opt in to the Tier-1 Jepsen consistency scenario.
+      WYRD_TIER1: "1"
+    steps:
+      - uses: actions/checkout@v7
+
+      - name: Install Rust toolchain
+        run: rustup show active-toolchain || rustup toolchain install
+
+      - name: Cache cargo build
+        uses: Swatinem/rust-cache@v2
+
+      # ubuntu-latest ships Docker with the compose plugin; this confirms the daemon
+      # is reachable (same check as tier2-kill-reconstruct.yml).
+      - name: Docker info
+        run: docker info
+
+      # cargo xtask jepsen opts in when WYRD_TIER1=1, confirms docker is present,
+      # stands up the 7-server compose cluster, then runs the #[ignore]d consistency
+      # scenario via `cargo test -p wyrd-chunkstore-grpc --test
+      # tier1_jepsen_consistency -- --ignored --nocapture`.
+      - name: cargo xtask jepsen
+        run: cargo xtask jepsen
+
+      # Surface container diagnostics captured by finalize_panic_safe before
+      # teardown (#150): compose_logs writes to target/tier2-logs/ on failure so
+      # the diagnostics survive compose_down.
+      - name: Upload container diagnostics
+        if: failure()
+        uses: actions/upload-artifact@v7
+        with:
+          name: tier1-jepsen-logs
+          path: target/tier2-logs/
+          if-no-files-found: ignore
+          retention-days: 14
