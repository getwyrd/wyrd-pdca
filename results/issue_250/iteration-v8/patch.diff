@@ -0,0 +1,361 @@
+//! Tier-1 Jepsen consistency harness orchestration (proposal 0005 §13.2, `0005:408`,
+//! issue #250): the **host-independent** part of the Tier-1 consistency-over-repair
+//! harness — the cargo-test invocation args, the cluster constants, and the
+//! consistency oracle helpers.
+//!
+//! These are pure functions with no privileged I/O (no docker, no gRPC D servers,
+//! no network), so they are unit-testable inside the unprivileged `cargo xtask ci`
+//! gate and compile on any host (ADR-0016).
+//!
+//! The privileged scenario that drives the production `reconcile_step` →
+//! `reconstruction::reconcile` path against live containerized D servers under
+//! partitions and crashes lives at `crates/chunkstore-grpc/tests/
+//! tier1_jepsen_consistency.rs` and is `#[ignore]`d; `cargo xtask jepsen` runs it
+//! via `cargo test --ignored` in the off-Check Tier-1 CI job (`tier1-jepsen.yml`),
+//! opted in by `WYRD_TIER1=1`.
+//!
+//! # Born-at-tier flippable coverage
+//!
+//! `xtask/tests/jepsen_orchestration.rs` imports these helpers and tests them
+//! without any container runtime. When a helper is removed or returns a wrong value,
+//! those tests go RED inside `cargo xtask ci` — the "deferred ≠ unbuilt" bar (the
+//! Verification-posture forcing function from `templates/brief.md.tpl` and INTEGRATION
+//! §"Deferred/off-Check tiers").
+
+// ─── Cargo-test invocation ────────────────────────────────────────────────────
+
+/// The `cargo test` arguments for the Tier-1 Jepsen consistency scenario.
+///
+/// Single source of truth for [`crate::faults::run_jepsen`]'s inner
+/// `run_jepsen_consistency_test` dispatch and the routing test in
+/// `xtask/tests/jepsen_orchestration.rs`. Both callers use this function to ensure
+/// the dispatch wiring and the test assertion target the same in-repo scenario,
+/// not the old external `WYRD_TIER1_JEPSEN_CMD` env command.
+pub fn consistency_test_cargo_args() -> &'static [&'static str] {
+    &[
+        "test",
+        "-p",
+        "wyrd-chunkstore-grpc",
+        "--test",
+        "tier1_jepsen_consistency",
+        "--",
+        "--ignored",
+        "--nocapture",
+    ]
+}
+
+/// The required container-runtime tool for the Tier-1 consistency scenario.
+///
+/// The scenario stands up a real docker-compose D-server cluster (like the
+/// Tier-2 kill-and-reconstruct leg), so `docker` (with the compose plugin) is
+/// the privileged prerequisite — **not** `lein` (the old Clojure/Jepsen
+/// external-command tool the inert `WYRD_TIER1_JEPSEN_CMD` shell-out used).
+pub fn consistency_required_tool() -> &'static str {
+    "docker"
+}
+
+// ─── Cluster constants ────────────────────────────────────────────────────────
+
+/// Number of D-server containers for the Tier-1 consistency cluster.
+///
+/// RS(4,2): k=4 data + m=2 parity = n=6 total fragments per chunk.
+/// One extra spare server (server 6) receives the rebuilt fragment after
+/// the victim (server 0) is killed. Seven servers total.
+pub const JC_DSERVER_COUNT: usize = 7;
+
+/// 0-indexed server that is killed (victim) in the consistency scenario.
+pub const JC_VICTIM_INDEX: usize = 0;
+
+// ─── Consistency oracle (ADR-0015) ────────────────────────────────────────────
+
+/// A single event in the scenario's consistency history.
+///
+/// The scenario records commit and read observations so the oracle can check the
+/// ADR-0015 contract over the repair path without relying on timing or
+/// container-level introspection.
+///
+/// Used by the lib target's integration test (`xtask/tests/jepsen_orchestration.rs`);
+/// the binary target includes this module only for the dispatch helpers, so
+/// `#[allow(dead_code)]` suppresses the false-positive from the binary build.
+#[allow(dead_code)]
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum ConsistencyEvent {
+    /// A value was written and committed (its `write_id` is now durable).
+    WriteCommitted {
+        /// Identifies the committed value (e.g. the inode version).
+        write_id: u64,
+    },
+    /// A read observation: either `Some(write_id)` (found a committed value)
+    /// or `None` (not found / chunk not yet available after repair).
+    ReadObserved {
+        /// The `write_id` the read returned, or `None` if not found.
+        write_id: Option<u64>,
+    },
+}
+
+/// Outcome of a consistency check over a history of events.
+// Same binary-build dead-code suppression as ConsistencyEvent above.
+#[allow(dead_code)]
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum ConsistencyOutcome {
+    /// All checked consistency properties hold.
+    Valid,
+    /// A property was violated; carries a description of the first violation.
+    Violation(String),
+}
+
+/// Check the **read-after-commit** property (ADR-0015) over the event history:
+/// every `ReadObserved { write_id: Some(id) }` must have a preceding
+/// `WriteCommitted { write_id: id }` — a read must never return a value that
+/// was never committed.
+///
+/// This is the core consistency guarantee: the repair path must not invent
+/// values, serve stale data committed before the repair window, or return
+/// torn reads that mix committed and non-committed fragment versions.
+///
+/// # Negative control (planted anomaly)
+///
+/// A history where a read returns a `write_id` with no preceding
+/// `WriteCommitted` entry is a **phantom read** and must be caught.
+/// This guarantees the oracle is load-bearing (not vacuously true).
+// Used by the lib/integration-test target; suppress binary-build false-positive.
+#[allow(dead_code)]
+pub fn check_read_after_commit(history: &[ConsistencyEvent]) -> ConsistencyOutcome {
+    use std::collections::HashSet;
+    let mut committed: HashSet<u64> = HashSet::new();
+    for event in history {
+        match event {
+            ConsistencyEvent::WriteCommitted { write_id } => {
+                committed.insert(*write_id);
+            }
+            ConsistencyEvent::ReadObserved { write_id: Some(id) } => {
+                if !committed.contains(id) {
+                    return ConsistencyOutcome::Violation(format!(
+                        "read returned write_id={id} but no WriteCommitted with that id \
+                         precedes it in the history (phantom read / stale value; \
+                         violates ADR-0015 read-after-commit)"
+                    ));
+                }
+            }
+            ConsistencyEvent::ReadObserved { write_id: None } => {
+                // A not-found read is allowed (chunk not yet available after repair) —
+                // it does not violate read-after-commit.
+            }
+        }
+    }
+    ConsistencyOutcome::Valid
+}
+
+/// Check the **no-duplicate-placement** invariant (proposal 0005, `0005:277`,
+/// `0005:385-389`) over the post-repair committed placement:
+/// every server ID must appear **exactly once**.
+///
+/// A crash mid-repair leaves a placed-but-uncommitted fragment (collectable
+/// garbage), never a duplicate committed placement — the commit-point-atomic
+/// guarantee. Duplicates mean the version-conditional commit violated atomicity.
+///
+/// # Negative control
+///
+/// A placement with a repeated server ID must be caught. This ensures the
+/// oracle is load-bearing and not vacuously true.
+// Used by the lib/integration-test target; suppress binary-build false-positive.
+#[allow(dead_code)]
+pub fn check_no_duplicate_placement(placement: &[u64]) -> ConsistencyOutcome {
+    use std::collections::HashMap;
+    let mut counts: HashMap<u64, usize> = HashMap::new();
+    for &server in placement {
+        *counts.entry(server).or_insert(0) += 1;
+    }
+    for (&server, &count) in &counts {
+        if count > 1 {
+            return ConsistencyOutcome::Violation(format!(
+                "server {server} appears {count} times in the committed placement; \
+                 duplicate committed placement violates commit-point atomicity \
+                 (proposal 0005, `0005:277`, `0005:385-389`)"
+            ));
+        }
+    }
+    ConsistencyOutcome::Valid
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    // ─── consistency_test_cargo_args ─────────────────────────────────────────────
+
+    #[test]
+    fn consistency_test_args_target_in_repo_scenario_not_env_cmd() {
+        let args = consistency_test_cargo_args();
+        // Must name the in-repo scenario file, not the old external env command.
+        assert!(
+            args.contains(&"tier1_jepsen_consistency"),
+            "consistency_test_cargo_args must name the in-repo scenario; got: {args:?}"
+        );
+        // Must use the --ignored flag to run the #[ignore]d scenario body.
+        assert!(
+            args.contains(&"--ignored"),
+            "consistency_test_cargo_args must pass --ignored to run the scenario; got: {args:?}"
+        );
+        // Must NOT reference the old external env command.
+        assert!(
+            !args.iter().any(|a| a.contains("WYRD_TIER1_JEPSEN_CMD")),
+            "consistency_test_cargo_args must not reference the old external env command; \
+             got: {args:?}"
+        );
+    }
+
+    #[test]
+    fn consistency_test_args_target_wyrd_chunkstore_grpc_package() {
+        // The scenario lives in the wyrd-chunkstore-grpc package (sibling to
+        // tier2_kill_reconstruct.rs); the args must select that package.
+        let args = consistency_test_cargo_args();
+        let pkg_pos = args.iter().position(|a| *a == "-p");
+        assert!(
+            pkg_pos.is_some(),
+            "args must have -p <package>; got: {args:?}"
+        );
+        let pkg = args[pkg_pos.unwrap() + 1];
+        assert_eq!(
+            pkg, "wyrd-chunkstore-grpc",
+            "scenario must be in wyrd-chunkstore-grpc (sibling of tier2_kill_reconstruct.rs)"
+        );
+    }
+
+    // ─── consistency_required_tool ───────────────────────────────────────────────
+
+    #[test]
+    fn consistency_required_tool_is_docker_not_lein() {
+        // The in-repo scenario uses docker-compose (not lein/Clojure) for its
+        // D-server cluster. This test binds the tool change from the old inert
+        // external-command approach (lein) to the in-repo scenario (docker).
+        assert_eq!(
+            consistency_required_tool(),
+            "docker",
+            "required tool must be docker (the container runtime for the in-repo scenario), \
+             not lein (the old Clojure/Jepsen external-command prerequisite)"
+        );
+    }
+
+    // ─── check_read_after_commit ─────────────────────────────────────────────────
+
+    #[test]
+    fn read_after_commit_valid_for_empty_history() {
+        assert_eq!(
+            check_read_after_commit(&[]),
+            ConsistencyOutcome::Valid,
+            "empty history: no reads, no violations"
+        );
+    }
+
+    #[test]
+    fn read_after_commit_valid_when_read_follows_commit() {
+        let history = vec![
+            ConsistencyEvent::WriteCommitted { write_id: 1 },
+            ConsistencyEvent::ReadObserved { write_id: Some(1) },
+        ];
+        assert_eq!(
+            check_read_after_commit(&history),
+            ConsistencyOutcome::Valid,
+            "read of write_id=1 after WriteCommitted {{ write_id: 1 }}: must pass"
+        );
+    }
+
+    #[test]
+    fn read_after_commit_valid_for_not_found_read() {
+        // A not-found read (write_id: None) is allowed — the chunk might not be
+        // available yet after repair. It does not violate read-after-commit.
+        let history = vec![
+            ConsistencyEvent::WriteCommitted { write_id: 42 },
+            ConsistencyEvent::ReadObserved { write_id: None },
+        ];
+        assert_eq!(
+            check_read_after_commit(&history),
+            ConsistencyOutcome::Valid,
+            "not-found read with committed write: must pass"
+        );
+    }
+
+    #[test]
+    fn read_after_commit_catches_phantom_read_negative_control() {
+        // NEGATIVE CONTROL (planted anomaly): a read that returns a write_id
+        // never committed is a phantom read — the oracle MUST catch it.
+        // If the oracle misses this, it is vacuously passing (checking its own
+        // bookkeeping, not Wyrd's consistency — the iter-5 advisory).
+        let history = vec![
+            ConsistencyEvent::WriteCommitted { write_id: 1 },
+            ConsistencyEvent::ReadObserved {
+                write_id: Some(99), // 99 was never committed — phantom read
+            },
+        ];
+        let outcome = check_read_after_commit(&history);
+        assert!(
+            matches!(&outcome, ConsistencyOutcome::Violation(msg) if msg.contains("phantom")),
+            "phantom read of uncommitted write_id=99 must be caught; got: {outcome:?}"
+        );
+    }
+
+    #[test]
+    fn read_after_commit_catches_read_before_commit_negative_control() {
+        // NEGATIVE CONTROL: a read that returns write_id=1 BEFORE WriteCommitted
+        // with write_id=1 violates the ordering guarantee.
+        let history = vec![
+            ConsistencyEvent::ReadObserved {
+                write_id: Some(1), // read before the commit!
+            },
+            ConsistencyEvent::WriteCommitted { write_id: 1 },
+        ];
+        let outcome = check_read_after_commit(&history);
+        assert!(
+            matches!(outcome, ConsistencyOutcome::Violation(_)),
+            "read before commit must be caught as a violation: {outcome:?}"
+        );
+    }
+
+    // ─── check_no_duplicate_placement ───────────────────────────────────────────
+
+    #[test]
+    fn no_duplicate_placement_valid_for_distinct_servers() {
+        assert_eq!(
+            check_no_duplicate_placement(&[0, 1, 2, 3, 4, 5]),
+            ConsistencyOutcome::Valid,
+            "all distinct servers: must pass"
+        );
+    }
+
+    #[test]
+    fn no_duplicate_placement_valid_for_empty_placement() {
+        assert_eq!(
+            check_no_duplicate_placement(&[]),
+            ConsistencyOutcome::Valid,
+            "empty placement: must pass"
+        );
+    }
+
+    #[test]
+    fn no_duplicate_placement_catches_duplicate_negative_control() {
+        // NEGATIVE CONTROL (planted anomaly): a committed placement with a repeated
+        // server ID violates commit-point atomicity and must be caught.
+        let outcome = check_no_duplicate_placement(&[0, 1, 2, 2, 3]);
+        assert!(
+            matches!(outcome, ConsistencyOutcome::Violation(_)),
+            "duplicate server 2 in placement must be caught: {outcome:?}"
+        );
+    }
+
+    #[test]
+    fn no_duplicate_placement_violation_names_the_duplicate_server() {
+        let outcome = check_no_duplicate_placement(&[5, 5]);
+        let ConsistencyOutcome::Violation(msg) = outcome else {
+            panic!("expected Violation for duplicate server 5, got Valid");
+        };
+        assert!(
+            msg.contains('5'),
+            "violation message must name the duplicate server: {msg}"
+        );
+        assert!(
+            msg.contains("atomicity") || msg.contains("duplicate"),
+            "violation message must name the atomicity property: {msg}"
+        );
+    }
+}
