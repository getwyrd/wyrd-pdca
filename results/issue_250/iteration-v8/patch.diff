+/// Stand up the Jepsen D-server cluster, run the consistency scenario, and tear
+/// down — mirroring the Tier-2 kill-and-reconstruct orchestration shape.
+///
+/// The cluster reuses the shared `docker-compose.yml` (same compose file as the
+/// Tier-2 integration and kill-reconstruct tests) scaled to
+/// [`crate::jepsen::JC_DSERVER_COUNT`] servers. The scenario test receives the
+/// resolved endpoints via `WYRD_DSERVER_ENDPOINTS` and the victim container
+/// name via `WYRD_TIER1_VICTIM_CONTAINER`.
+fn run_jepsen_scenario() -> Result<(), String> {
+    let compose = crate::workspace_root()
+        .join("crates/chunkstore-grpc/tests/docker-compose.yml")
+        .to_string_lossy()
+        .to_string();
+
+    let victim_index = crate::jepsen::JC_VICTIM_INDEX;
+    // Docker Compose V2 names replicas `<project>-<service>-<1-indexed-replica>`.
+    let victim_container = format!("{}-dserver-{}", crate::TIER2_PROJECT, victim_index + 1);
+
+    crate::compose_up(&compose, crate::jepsen::JC_DSERVER_COUNT)?;
+    crate::finalize_panic_safe(
+        || {
+            let endpoints = crate::resolve_endpoints(&compose, crate::jepsen::JC_DSERVER_COUNT)?;
+            println!(
+                "\nxtask jepsen: {} D servers at {endpoints}; victim container: \
+                 {victim_container}",
+                crate::jepsen::JC_DSERVER_COUNT,
+            );
+            run_jepsen_consistency_test(&endpoints, &victim_container)
+        },
+        |result| {
+            crate::finish_integration(
+                result,
+                || crate::compose_logs(&compose),
+                || crate::compose_down(&compose),
+            )
+        },
+    )?;
+    println!("\nxtask jepsen: Tier-1 consistency-over-repair passed");
+    Ok(())
+}
+
+/// Run the `#[ignore]`d Tier-1 Jepsen consistency scenario test with the resolved
+/// endpoints and victim container exported, so the test dials the live container
+/// cluster and kills the right D server.
+///
+/// Uses [`crate::jepsen::consistency_test_cargo_args`] as the single source of truth
+/// for the `cargo test` invocation — the same args that `xtask/tests/
+/// jepsen_orchestration.rs` asserts over, so the dispatch wiring is always
+/// exercised at Check.
+fn run_jepsen_consistency_test(endpoints: &str, victim_container: &str) -> Result<(), String> {
+    let args = crate::jepsen::consistency_test_cargo_args();
+    crate::print_step(&{
+        let mut display = vec!["cargo"];
+        display.extend_from_slice(args);
+        display
+    });
+    let status = Command::new("cargo")
+        .args(args)
+        .current_dir(crate::workspace_root())
+        .env("WYRD_DSERVER_ENDPOINTS", endpoints)
+        .env("WYRD_TIER1_VICTIM_CONTAINER", victim_container)
+        .status()
+        .map_err(|e| format!("failed to spawn cargo for Tier-1 consistency scenario: {e}"))?;
+    if status.success() {
+        Ok(())
+    } else {
+        Err(format!(
+            "Tier-1 Jepsen consistency scenario failed with {status}"
+        ))
+    }
 }
 
