@@ -0,0 +1,171 @@
+//! Dispatch-routing and consistency-oracle tests for the Tier-1 Jepsen
+//! consistency harness (`xtask::jepsen` — the Check-time flippable coverage,
+//! born at M3, issue #250, proposal 0005 §13.2, `0005:408`).
+//!
+//! **Why these tests exist.** The Tier-1 Jepsen consistency harness is a
+//! "deferred" tier (ADR-0016): its real-cluster scenario
+//! (`crates/chunkstore-grpc/tests/tier1_jepsen_consistency.rs`) requires
+//! `docker` + a live D-server fleet and is `#[ignore]`d in the unprivileged
+//! `cargo xtask ci` gate. "Deferred" means the green run is off-Check; it does
+//! NOT mean the harness is unbuilt.
+//!
+//! These tests exercise the **host-independent** orchestration logic at Check:
+//!
+//! - [`xtask::jepsen::consistency_test_cargo_args`] — the single-sourced
+//!   cargo invocation consumed by `run_jepsen`'s inner dispatch; asserts the
+//!   routing targets the in-repo scenario, NOT the old external
+//!   `WYRD_TIER1_JEPSEN_CMD` env command.
+//! - [`xtask::jepsen::consistency_required_tool`] — must be `"docker"` (not
+//!   `"lein"` the old Clojure/Jepsen prerequisite), exercised at Check to
+//!   bind the tool change to the module.
+//! - [`xtask::jepsen::check_read_after_commit`] /
+//!   [`xtask::jepsen::check_no_duplicate_placement`] — the consistency oracle
+//!   helpers, with **negative-control (planted-anomaly) tests** proving the
+//!   oracle is load-bearing and not checking its own bookkeeping.
+//!
+//! **C4-verify note.** `run-verify.sh` classifies this file as an added test
+//! (`xtask/tests/*.rs` matches `*/tests/*.rs`) and targets it in the RED check:
+//! reverting the production changes removes `xtask/src/jepsen.rs` and reverts
+//! `xtask/src/lib.rs`, making `use xtask::jepsen::*` fail to compile — so the
+//! RED check observes a non-zero exit and declares RED ✓. The full patch applied
+//! makes the tests compile and pass — GREEN ✓.
+
+use xtask::jepsen::{
+    check_no_duplicate_placement, check_read_after_commit, consistency_required_tool,
+    consistency_test_cargo_args, ConsistencyEvent, ConsistencyOutcome,
+};
+
+// ─── dispatch routing ────────────────────────────────────────────────────────
+
+#[test]
+fn jepsen_dispatch_targets_in_repo_scenario_not_external_env_cmd() {
+    // The dispatch args (single-sourced in xtask::jepsen::consistency_test_cargo_args,
+    // consumed by run_jepsen_consistency_test in faults.rs) must name the in-repo
+    // tier1_jepsen_consistency scenario, NOT the old WYRD_TIER1_JEPSEN_CMD shell-out.
+    //
+    // RED pre-fix: this file does not compile without xtask::jepsen (jepsen.rs absent
+    // after run-verify.sh reverts production changes). GREEN post-fix: xtask::jepsen
+    // exists and the args name the in-repo scenario.
+    let args = consistency_test_cargo_args();
+    assert!(
+        args.contains(&"tier1_jepsen_consistency"),
+        "dispatch must target the in-repo scenario; args: {args:?}"
+    );
+    assert!(
+        args.contains(&"--ignored"),
+        "dispatch must pass --ignored to run the #[ignore]d scenario body; args: {args:?}"
+    );
+    assert!(
+        !args.iter().any(|a| a.contains("WYRD_TIER1_JEPSEN_CMD")),
+        "dispatch must not reference the old external env command; args: {args:?}"
+    );
+}
+
+#[test]
+fn jepsen_dispatch_targets_wyrd_chunkstore_grpc_package() {
+    // The scenario is in wyrd-chunkstore-grpc (sibling of tier2_kill_reconstruct.rs);
+    // the dispatch args must select that package.
+    let args = consistency_test_cargo_args();
+    let pkg_idx = args
+        .iter()
+        .position(|a| *a == "-p")
+        .expect("dispatch args must include -p <package>");
+    assert_eq!(
+        args[pkg_idx + 1],
+        "wyrd-chunkstore-grpc",
+        "dispatch must target wyrd-chunkstore-grpc"
+    );
+}
+
+#[test]
+fn jepsen_required_tool_is_docker_not_lein() {
+    // run_jepsen gates on consistency_required_tool(): must be "docker" (the container
+    // runtime for the in-repo scenario), not "lein" (the old Clojure/Jepsen tool).
+    // This test binds the tool change to the xtask::jepsen module — removing
+    // jepsen.rs breaks this file's compilation and makes C4-verify RED.
+    assert_eq!(
+        consistency_required_tool(),
+        "docker",
+        "required tool must be docker for the in-repo consistency scenario"
+    );
+}
+
+// ─── consistency oracle: read-after-commit ───────────────────────────────────
+
+#[test]
+fn read_after_commit_valid_for_normal_history() {
+    let history = vec![
+        ConsistencyEvent::WriteCommitted { write_id: 1 },
+        ConsistencyEvent::ReadObserved { write_id: Some(1) },
+    ];
+    assert_eq!(check_read_after_commit(&history), ConsistencyOutcome::Valid);
+}
+
+#[test]
+fn read_after_commit_valid_for_not_found_read() {
+    // Not-found reads do not violate read-after-commit.
+    let history = vec![
+        ConsistencyEvent::WriteCommitted { write_id: 1 },
+        ConsistencyEvent::ReadObserved { write_id: None },
+    ];
+    assert_eq!(check_read_after_commit(&history), ConsistencyOutcome::Valid);
+}
+
+#[test]
+fn read_after_commit_catches_phantom_read_negative_control() {
+    // NEGATIVE CONTROL / planted anomaly: a read that returns a write_id never
+    // committed must be caught. If the oracle misses this, it is vacuously passing
+    // (checking its own bookkeeping, not Wyrd's consistency — the iter-5 advisory).
+    // This demonstrates red: the oracle is load-bearing, not empty.
+    let history = vec![
+        ConsistencyEvent::WriteCommitted { write_id: 1 },
+        ConsistencyEvent::ReadObserved {
+            write_id: Some(42), // 42 was never committed
+        },
+    ];
+    let outcome = check_read_after_commit(&history);
+    assert!(
+        matches!(outcome, ConsistencyOutcome::Violation(_)),
+        "phantom read of uncommitted write_id=42 must be caught as a violation: {outcome:?}"
+    );
+}
+
+#[test]
+fn read_after_commit_catches_read_before_commit_negative_control() {
+    // NEGATIVE CONTROL: read returns write_id=1 before the commit — ordering violation.
+    let history = vec![
+        ConsistencyEvent::ReadObserved {
+            write_id: Some(1), // before the commit
+        },
+        ConsistencyEvent::WriteCommitted { write_id: 1 },
+    ];
+    assert!(
+        matches!(
+            check_read_after_commit(&history),
+            ConsistencyOutcome::Violation(_)
+        ),
+        "read before commit must be caught"
+    );
+}
+
+// ─── consistency oracle: no-duplicate-placement ──────────────────────────────
+
+#[test]
+fn no_duplicate_placement_valid_for_distinct_servers() {
+    assert_eq!(
+        check_no_duplicate_placement(&[0, 1, 2, 3, 4, 5]),
+        ConsistencyOutcome::Valid
+    );
+}
+
+#[test]
+fn no_duplicate_placement_catches_duplicate_negative_control() {
+    // NEGATIVE CONTROL / planted anomaly: a committed placement with a repeated
+    // server ID violates commit-point atomicity and must be caught.
+    // Demonstrates the oracle is load-bearing (proposal 0005, `0005:385-389`).
+    let outcome = check_no_duplicate_placement(&[0, 1, 2, 2, 3]);
+    assert!(
+        matches!(outcome, ConsistencyOutcome::Violation(_)),
+        "duplicate server 2 in placement must be caught: {outcome:?}"
+    );
+}
