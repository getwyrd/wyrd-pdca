+        let occupied = [FailureDomain::new("A"), FailureDomain::new("B")];
+        let err = select_distinct_domains_excluding(&t, 1, &occupied).unwrap_err();
+        assert_eq!(err, SelectorError::InsufficientDomains { have: 0, need: 1 });
