-            .map_err(ReconcileError::Store),
-        None => Ok(Reconciled::Satisfied),
+            .map_err(ReconcileError::Store)?
+            == Reconciled::Changed
+        {
+            outcome = Reconciled::Changed;
+        }
+    }
+    if let Some(ctx) = scrub {
+        if scrub::reconcile(ctx, now_millis)
+            .await
+            .map_err(ReconcileError::Store)?
+            == Reconciled::Changed
+        {
+            outcome = Reconciled::Changed;
+        }
     }
+    Ok(outcome)
 }
