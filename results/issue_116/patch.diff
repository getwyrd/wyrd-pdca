+        assert_eq!(
+            faults.fault_for(2, FaultPoint::FragmentFetch),
+            Some(NetFault::Corrupt)
+        );
+        assert_eq!(faults.fault_for(0, FaultPoint::FragmentFetch), None);
+    }
 }
