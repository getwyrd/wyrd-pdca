@@ -0,0 +1,74 @@
+# Run a local Wyrd cluster (Milestone 2.8, issue #155).
+#
+# A user-facing, hand-driven cluster — distinct from the CI fixture at
+# `crates/chunkstore-grpc/tests/docker-compose.yml` (that one is scaled by
+# `cargo xtask integration` onto ephemeral host ports and torn down). This one
+# stands up a fixed, named set of D servers on **fixed published ports** with a
+# **persistent volume each**, so a human can dial them from the host with the
+# `wyrd` gateway client mode:
+#
+#   docker compose up --build -d
+#   ENDPOINTS=http://127.0.0.1:50051,http://127.0.0.1:50052,http://127.0.0.1:50053,http://127.0.0.1:50054
+#   wyrd put ./file --key obj/one --endpoints "$ENDPOINTS" --data-dir ./cluster-meta
+#   wyrd get obj/one --out ./out.bin --endpoints "$ENDPOINTS" --data-dir ./cluster-meta
+#
+# Four D servers, not three: the default durability is rs(6,3) — 9 fragments per
+# chunk, needing any k=6 to reconstruct. With three servers each holds 3 fragments,
+# so losing one drops to exactly 6 = no redundancy headroom. A fourth server keeps
+# a single-server loss above k, matching the four-server loopback round-trip test.
+#
+# See the README "Run a local cluster" walk-through for the full flow. Each
+# service is the `d-server` role of the single `wyrd` binary (ADR-0014/ADR-0016),
+# built from the same image the CI fixture uses.
+services:
+  dserver1:
+    build:
+      context: .
+      dockerfile: crates/chunkstore-grpc/tests/dserver/Dockerfile
+    image: wyrd-dserver:local
+    command: ["d-server", "--bind", "0.0.0.0:50051", "--data-dir", "/data"]
+    # Fixed host port so the gateway can be pointed at a stable endpoint list.
+    ports:
+      - "50051:50051"
+    volumes:
+      - dserver1-data:/data
+
+  dserver2:
+    image: wyrd-dserver:local
+    build:
