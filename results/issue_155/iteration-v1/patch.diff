+/// gRPC clients are async (tonic), unlike the sync local-disk paths (pollster).
+fn cluster_runtime() -> Result<tokio::runtime::Runtime, BoxError> {
+    Ok(tokio::runtime::Builder::new_multi_thread()
+        .enable_all()
+        .build()?)
+}
